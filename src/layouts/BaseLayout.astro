---
import '../styles/global.css';
import '@fontsource/geist-sans/400.css';
import '@fontsource/geist-sans/500.css';
import '@fontsource/geist-sans/600.css';
import '@fontsource/geist-mono/400.css';
import '@fontsource/geist-mono/500.css';
import '@fontsource/plus-jakarta-sans/700.css';
import '@fontsource/plus-jakarta-sans/800.css';
import Navbar from '../components/Navbar.tsx';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  hideChrome?: boolean;
  pageType?: 'website' | 'article';
}

const {
  title = 'Ben LaClair — UX/UI & Graphic Designer',
  description = 'UX/UI and graphic designer with 5+ years of experience designing user-centered digital products, brand systems, and AI-driven creative work.',
  ogImage = '/og-image.png',
  hideChrome = false,
  pageType = 'website',
} = Astro.props;

const siteUrl = 'https://benlaclair.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Ben LaClair',
  url: siteUrl,
  jobTitle: 'UX/UI & Graphic Designer',
  knowsAbout: ['UX Design', 'UI Design', 'Brand Identity', 'Web Development', 'AI-Driven Design'],
  sameAs: ['https://www.linkedin.com/in/benlaclair'],
};
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#EFEDE8" />
    <meta property="og:type" content={pageType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteUrl).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, siteUrl).toString()} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-[var(--color-ink)] focus:text-[var(--color-bg)] focus:px-4 focus:py-2">Skip to content</a>
    {!hideChrome && <Navbar pathname={Astro.url.pathname} client:load />}
    <main id="main">
      <slot />
    </main>
    {!hideChrome && <Footer />}
  </body>
</html>
