---
const year = new Date().getFullYear();
---
<footer class="border-t border-[var(--color-line)] mt-24 md:mt-40">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 py-10 md:py-14">
    <div class="grid md:grid-cols-3 gap-8 md:gap-12 mb-10">
      <div>
        <p class="font-serif text-2xl text-[var(--color-ink)] mb-2">Ben LaClair</p>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed max-w-xs">
          UX/UI &amp; Graphic Designer based in the Northeast US. Available for select projects in {year}.
        </p>
      </div>
      <div>
        <p class="eyebrow mb-4">Site</p>
        <ul class="flex flex-col gap-2">
          <li><a href="/work" class="text-sm text-[var(--color-ink)] hover:text-[var(--color-pop)] transition-colors">Work</a></li>
          <li><a href="/tools" class="text-sm text-[var(--color-ink)] hover:text-[var(--color-pop)] transition-colors">Tools</a></li>
          <li><a href="/about" class="text-sm text-[var(--color-ink)] hover:text-[var(--color-pop)] transition-colors">About</a></li>
          <li><a href="/contact" class="text-sm text-[var(--color-ink)] hover:text-[var(--color-pop)] transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <p class="eyebrow mb-4">Elsewhere</p>
        <ul class="flex flex-col gap-2">
          <li>
            <a href="https://www.linkedin.com/in/benlaclair" target="_blank" rel="noopener noreferrer"
              class="text-sm text-[var(--color-ink)] hover:text-[var(--color-pop)] transition-colors">LinkedIn ↗</a>
          </li>
          <li>
            <a href="mailto:hello@benlaclair.com"
              class="text-sm text-[var(--color-ink)] hover:text-[var(--color-pop)] transition-colors">hello@benlaclair.com</a>
          </li>
          <li>
            <a href="/resume.pdf" target="_blank" rel="noopener noreferrer"
              class="text-sm text-[var(--color-ink)] hover:text-[var(--color-pop)] transition-colors">Resume ↗</a>
          </li>
        </ul>
      </div>
    </div>
    <div class="pt-8 border-t border-[var(--color-line)] flex flex-col md:flex-row md:items-center md:justify-between gap-3">
      <p class="text-xs text-[var(--color-muted)]">
        © {year} Ben LaClair. Designed and built from scratch.
      </p>
      <p class="text-xs text-[var(--color-muted)] font-mono">
        v2.0 · Astro + GSAP
      </p>
    </div>
  </div>
</footer>
