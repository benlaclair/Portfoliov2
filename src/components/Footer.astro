---
const year = new Date().getFullYear();
---
<footer class="footer-mark-section is-dark" data-section-mode="dark">
  <div class="wrap" style="padding-top: 80px; padding-bottom: 40px; border-top: 1px solid var(--color-dark-line)">
    <div
      style="display: flex; justify-content: space-between; align-items: flex-end; gap: 60px; flex-wrap: wrap"
    >
      <!-- SVG B-mark + wordmark -->
      <div class="footer-mark" style="transform-origin: left bottom">
        <svg
          viewBox="0 0 96 96"
          aria-hidden="true"
          style="width: clamp(64px, 8vw, 96px); height: clamp(64px, 8vw, 96px); color: var(--color-dark-ink); display: block; margin-bottom: 16px"
        >
          <path d="M20 68V22h24c10 0 16 5 16 12.5 0 4.8-2.5 8.3-6.8 10.2C59 46.4 63 50.7 63 57c0 8-6.4 11-17.2 11H20Z" fill="currentColor" />
          <path d="M32 41h10c3.5 0 5.4-1.5 5.4-4.2 0-2.6-2-4-5.6-4H32v8.2Z" fill="var(--color-dark-bg)" />
          <path d="M32 58h12.5c3.8 0 5.8-1.7 5.8-4.7 0-2.8-2.1-4.5-6.1-4.5H32V58Z" fill="var(--color-dark-bg)" />
          <circle cx="70" cy="25" r="7" fill="var(--color-accent)" />
        </svg>
        <div
          style="font-family: var(--font-display); font-weight: 600; font-size: clamp(32px, 5vw, 56px); line-height: 0.95; letter-spacing: -0.03em; color: var(--color-dark-ink)"
        >
          Ben LaClair
        </div>
      </div>

      <div
        class="footer-info"
        style="display: grid; grid-template-columns: repeat(2, auto); gap: 32px 60px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase"
      >
        <div data-reveal>
          <div style="color: var(--color-dark-muted); margin-bottom: 8px">Index</div>
          <div style="color: var(--color-dark-ink)">{year}</div>
        </div>
        <div data-reveal>
          <div style="color: var(--color-dark-muted); margin-bottom: 8px">Built with</div>
          <div style="color: var(--color-dark-ink)">Astro &middot; GSAP</div>
        </div>
        <div data-reveal>
          <div style="color: var(--color-dark-muted); margin-bottom: 8px">Elsewhere</div>
          <a
            href="https://www.linkedin.com/in/benlaclair"
            target="_blank"
            rel="noopener noreferrer"
            data-cursor="open"
            style="color: var(--color-dark-ink); border-bottom: 1px solid currentColor; padding-bottom: 1px"
          >LinkedIn ↗</a>
        </div>
        <div data-reveal>
          <div style="color: var(--color-dark-muted); margin-bottom: 8px">Reach</div>
          <a
            href="mailto:hello@benlaclair.com"
            data-cursor="email"
            style="color: var(--color-dark-ink); border-bottom: 1px solid currentColor; padding-bottom: 1px"
          >hello@benlaclair.com</a>
        </div>
      </div>
    </div>

    <div
      style="margin-top: 80px; padding-top: 24px; border-top: 1px solid var(--color-dark-line); display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-dark-muted)"
    >
      <span>&copy; {year} Ben LaClair</span>
      <span>Designed &amp; built from scratch</span>
      <span>v2.0</span>
    </div>
  </div>
</footer>

<script>
  import { gsap, ease, reduceMotion } from '../lib/motion';

  const mark = document.querySelector<HTMLElement>('.footer-mark');
  if (mark && !reduceMotion.current) {
    gsap.from(mark, {
      y: 60,
      scale: 0.96,
      opacity: 0,
      duration: 1.1,
      ease: ease.expo,
      scrollTrigger: { trigger: mark, start: 'top 92%' },
    });
  }
</script>
