---
const year = new Date().getFullYear();
---
<footer class="is-dark" data-section-mode="dark">

  <!-- Closing statement -->
  <div class="footer-cta">
    <div class="wrap" style="padding-top: clamp(56px, 7vh, 88px); padding-bottom: clamp(32px, 4vh, 52px)">
      <p class="footer-eyebrow" data-reveal>Available for new work</p>

      <h2 class="footer-headline" aria-label="Let's make something worth making.">
        <div class="clip-wrap"><span>Let's make something</span></div>
        <div class="clip-wrap footer-accent-line"><span>worth making.</span></div>
      </h2>

      <a
        href="mailto:hello@benlaclair.com"
        class="footer-email"
        data-cursor="email"
        data-reveal
      >
        hello@benlaclair.com
        <span class="footer-email-arrow" aria-hidden="true">↗</span>
      </a>
    </div>
  </div>

  <!-- Bottom nav row -->
  <div class="footer-bottom">
    <div
      class="wrap"
      style="padding-top: 24px; padding-bottom: 32px; border-top: 1px solid var(--color-dark-line); display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap"
    >
      <nav class="footer-nav" aria-label="Footer navigation">
        <a href="/work">Work</a>
        <a href="/tools">Tools</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <a href="https://www.linkedin.com/in/benlaclair" target="_blank" rel="noopener noreferrer" data-cursor="open">
          LinkedIn ↗
        </a>
      </nav>
      <span class="footer-copy">&copy; {year} Ben LaClair</span>
    </div>
  </div>

</footer>

<style>
  .footer-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: clamp(32px, 4vw, 56px);
  }

  .footer-headline {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(40px, 5.5vw, 88px);
    line-height: 0.96;
    letter-spacing: -0.04em;
    color: var(--color-dark-ink);
    margin-bottom: clamp(28px, 3.5vw, 48px);
  }

  /* Last line uses the accent colour */
  .footer-accent-line > span {
    color: var(--color-accent);
  }

  .footer-email {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(16px, 1.8vw, 28px);
    letter-spacing: -0.02em;
    color: var(--color-dark-ink-2);
    border-bottom: 1px solid var(--color-dark-line);
    padding-bottom: 4px;
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .footer-email:hover {
    color: var(--color-dark-ink);
    border-color: var(--color-dark-ink);
  }
  .footer-email-arrow {
    display: inline-block;
    transition: transform 0.5s cubic-bezier(.7, 0, .2, 1);
  }
  .footer-email:hover .footer-email-arrow {
    transform: translate(5px, -5px);
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 32px;
  }
  .footer-nav a {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-dark-muted);
    transition: color 0.25s ease;
  }
  .footer-nav a:hover { color: var(--color-dark-ink); }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-dark-muted);
  }
</style>

<script>
  import { gsap, ease, reduceMotion } from '../lib/motion';

  const headline = document.querySelector<HTMLElement>('.footer-headline');
  if (headline && !reduceMotion.current) {
    const spans = headline.querySelectorAll<HTMLElement>('.clip-wrap > span');
    gsap.fromTo(
      spans,
      { yPercent: 110 },
      {
        yPercent: 0,
        duration: 1.1,
        ease: ease.expo,
        stagger: 0.08,
        scrollTrigger: { trigger: headline, start: 'top 88%' },
      }
    );
  }
</script>
