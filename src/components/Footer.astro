---
const year = new Date().getFullYear();
---
<footer class="border-t border-[var(--color-line)]">
  <div class="wrap py-14 md:py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-12">
      <!-- Name + tagline -->
      <div>
        <p
          class="text-[var(--color-ink)] mb-3"
          style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(2rem, 4vw, 3.25rem); letter-spacing: -0.03em; line-height: 1.0"
        >
          Ben LaClair
        </p>
        <p class="text-sm text-[var(--color-muted)] max-w-xs leading-relaxed">
          UX/UI &amp; Graphic Designer. Available for select projects in {year}.
        </p>
      </div>

      <!-- Links -->
      <div class="flex gap-14">
        <div>
          <p
            class="mb-5 text-[var(--color-muted)]"
            style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase"
          >Pages</p>
          <ul class="flex flex-col gap-3">
            {['/work', '/tools', '/about', '/contact'].map((href) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors duration-200"
                >
                  {href.slice(1).replace(/^./, (c) => c.toUpperCase())}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <p
            class="mb-5 text-[var(--color-muted)]"
            style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase"
          >Connect</p>
          <ul class="flex flex-col gap-3">
            <li>
              <a
                href="https://www.linkedin.com/in/benlaclair"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors duration-200"
              >LinkedIn ↗</a>
            </li>
            <li>
              <a
                href="mailto:hello@benlaclair.com"
                class="text-sm text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors duration-200"
              >Email ↗</a>
            </li>
            <li>
              <a
                href="/resume.pdf"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors duration-200"
              >Résumé ↗</a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div
      class="mt-14 pt-6 border-t border-[var(--color-line)] flex flex-col md:flex-row md:items-center md:justify-between gap-2"
    >
      <p style="font-family: 'Geist Mono', monospace; font-size: 0.65rem; color: var(--color-muted)">
        &copy; {year} Ben LaClair
      </p>
      <p style="font-family: 'Geist Mono', monospace; font-size: 0.65rem; color: var(--color-muted)">
        Astro &middot; GSAP &middot; Tailwind
      </p>
    </div>
  </div>
</footer>
