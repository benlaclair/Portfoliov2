---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  index?: number;
}

const { project, index = 0 } = Astro.props;
const num = '/' + String(index + 1).padStart(2, '0');
---

<article class="project-row" data-project>
  <a
    href={`/work/${project.slug}`}
    data-cursor="read"
    style="display: grid; grid-template-columns: 80px 1fr 1fr 40px; gap: 60px; padding: 60px 0; border-top: 1px solid var(--color-line); align-items: start"
  >
    <div
      class="project-num"
      style="font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.12em; color: var(--color-ink-2); padding-top: 8px"
    >{num}</div>

    <div class="project-meta" style="padding-top: 4px">
      <div
        style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; color: var(--color-accent); text-transform: uppercase; margin-bottom: 16px"
      >{project.category} &middot; {project.year}</div>
      <h3
        class="project-title"
        style="font-family: var(--font-display); font-weight: 500; font-size: clamp(36px, 4.4vw, 64px); line-height: 1.0; letter-spacing: -0.03em; margin-bottom: 24px"
      >
        {project.shortTitle}
      </h3>
      <p style="font-size: 15px; line-height: 1.6; color: var(--color-ink-2); max-width: 480px; margin-bottom: 28px">
        {project.description}
      </p>
      <span
        class="project-link"
        style="display: inline-flex; align-items: center; gap: 12px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink)"
      >
        Read case
        <span class="arrow" style="display: inline-block; transition: transform 0.5s cubic-bezier(.7,0,.2,1)">→</span>
      </span>
    </div>

    <div
      class="project-visual"
      style="aspect-ratio: 4/3; background: var(--color-paper); position: relative; overflow: hidden; border-radius: 2px"
    >
      <div class="pv-inner" style="position: absolute; inset: -10%; will-change: transform">
        {project.coverImage ? (
          <img
            src={project.coverImage}
            alt={project.shortTitle}
            width="800"
            height="600"
            loading="lazy"
            decoding="async"
            style="width: 100%; height: 100%; object-fit: cover"
          />
        ) : (
          <div
            style={`width: 100%; height: 100%; background: linear-gradient(135deg, ${project.coverColor}30, ${project.coverColor}10); display: grid; place-items: center`}
          >
            <span
              style={`font-family: var(--font-display); font-size: 96px; color: ${project.coverColor}; opacity: 0.5; letter-spacing: -0.04em`}
            >
              {project.shortTitle}
            </span>
          </div>
        )}
      </div>
      <div
        style="position: absolute; left: 16px; bottom: 14px; font-family: var(--font-mono); font-size: 10px; color: rgba(22,20,15,0.45); letter-spacing: 0.08em; text-transform: uppercase; z-index: 2"
      >{project.category} · {project.year}</div>
    </div>

    <span
      class="project-arrow"
      style="align-self: center; font-size: 18px; color: var(--color-ink-2); transition: transform 0.4s ease"
    >→</span>
  </a>
</article>

<style>
  @media (max-width: 900px) {
    .project-row > a {
      grid-template-columns: 60px 1fr !important;
      gap: 24px !important;
    }
    .project-row .project-visual,
    .project-row .project-arrow {
      grid-column: 1 / -1;
      margin-top: 16px;
    }
    .project-row .project-arrow { display: none; }
  }
  .project-row:hover .project-arrow { transform: translateX(8px); color: var(--color-accent); }
  .project-row:hover .project-link .arrow { transform: translateX(8px); }
</style>

<script>
  import { gsap, ease, reduceMotion } from '../lib/motion';

  if (reduceMotion.current) {
    // Without GSAP touching these, the markup renders fully visible already.
    // Bail to avoid leaving inline opacity/transform from gsap.from().
  } else {
    document.querySelectorAll<HTMLElement>('[data-project]').forEach((p) => {
      const meta = p.querySelector('.project-meta');
      const num = p.querySelector('.project-num');
      const visual = p.querySelector<HTMLElement>('.project-visual');
      const inner = p.querySelector<HTMLElement>('.pv-inner');
      if (!meta || !num || !visual || !inner) return;

      gsap.from([num, meta], {
        y: 30,
        opacity: 0,
        duration: 1.0,
        stagger: 0.08,
        ease: ease.expo,
        scrollTrigger: { trigger: p, start: 'top 75%' },
      });
      gsap.from(visual, {
        y: 60,
        opacity: 0,
        duration: 1.2,
        ease: ease.expo,
        scrollTrigger: { trigger: p, start: 'top 75%' },
      });
      gsap.fromTo(
        inner,
        { yPercent: -8 },
        {
          yPercent: 8,
          ease: 'none',
          scrollTrigger: { trigger: visual, start: 'top bottom', end: 'bottom top', scrub: 0.8 },
        }
      );
    });
  }
</script>
