---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  index?: number;
}

const { project, index = 0 } = Astro.props;
---

<article
  class="project-card group"
  data-index={index}
  style={`--delay: ${index * 0.08}s`}
>
  <a href={`/work/${project.slug}`} class="block">
    <!-- Cover -->
    <div class="relative overflow-hidden rounded-2xl aspect-[16/10] mb-5 bg-[var(--color-line-soft)]">
      {project.coverImage ? (
        <img
          src={project.coverImage}
          alt={project.shortTitle}
          width="800"
          height="500"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
        />
      ) : (
        <div
          class="w-full h-full flex items-center justify-center"
          style={`background: linear-gradient(135deg, ${project.coverColor}18 0%, ${project.coverColor}08 100%)`}
        >
          <span class="font-serif text-4xl md:text-5xl tracking-tight" style={`color: ${project.coverColor}`}>
            {project.shortTitle}
          </span>
        </div>
      )}

      <!-- Hover overlay -->
      <div class="absolute inset-0 bg-[var(--color-ink)]/0 group-hover:bg-[var(--color-ink)]/6 transition-colors duration-300" />
    </div>

    <!-- Meta -->
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <p class="eyebrow mb-1.5">{project.category} &middot; {project.year}</p>
        <h3 class="font-serif text-xl md:text-2xl text-[var(--color-ink)] leading-snug group-hover:text-[var(--color-pop)] transition-colors">
          {project.shortTitle}
        </h3>
        <p class="text-sm text-[var(--color-muted)] mt-2 leading-relaxed line-clamp-2">
          {project.description}
        </p>
      </div>
      <span
        aria-hidden="true"
        class="shrink-0 mt-1 text-[var(--color-muted-soft)] group-hover:text-[var(--color-pop)] group-hover:translate-x-0.5 transition-all duration-200 text-lg leading-none"
      >
        &rarr;
      </span>
    </div>
  </a>
</article>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const cards = document.querySelectorAll<HTMLElement>('.project-card');
  cards.forEach((card) => {
    const delay = parseFloat(card.dataset.index ?? '0') * 0.08;
    gsap.from(card, {
      opacity: 0,
      y: 20,
      duration: 0.6,
      delay,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: card,
        start: 'top 88%',
        once: true,
      },
    });
  });
</script>
