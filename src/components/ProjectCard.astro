---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  index?: number;
}

const { project, index = 0 } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<article class="project-card group border-b border-[var(--color-line)]" data-index={index}>
  <a href={`/work/${project.slug}`} class="flex flex-col md:flex-row md:items-center gap-6 md:gap-10 py-8 md:py-10">

    <!-- Number -->
    <span
      class="shrink-0 text-[var(--color-muted)]"
      style="font-family: 'Geist Mono', monospace; font-size: 0.7rem; letter-spacing: 0.06em; min-width: 2rem"
    >{num}</span>

    <!-- Title + description -->
    <div class="flex-1 min-w-0">
      <p
        class="mb-1.5 text-[var(--color-muted)]"
        style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase"
      >{project.category} &middot; {project.year}</p>
      <h3
        class="text-[var(--color-ink)] group-hover:text-[var(--color-accent)] transition-colors duration-300 mb-2"
        style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(1.4rem, 2.8vw, 2.25rem); letter-spacing: -0.025em; line-height: 1.1"
      >{project.shortTitle}</h3>
      <p class="text-sm text-[var(--color-muted)] leading-relaxed max-w-xl hidden md:block">
        {project.description}
      </p>
    </div>

    <!-- Thumbnail -->
    <div
      class="shrink-0 w-full md:w-44 lg:w-52 aspect-[4/3] md:aspect-auto md:h-32 lg:h-36 overflow-hidden bg-[var(--color-surface)]"
    >
      {project.coverImage ? (
        <img
          src={project.coverImage}
          alt={project.shortTitle}
          width="208"
          height="144"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.05]"
        />
      ) : (
        <div
          class="w-full h-full flex items-center justify-center"
          style={`background: ${project.coverColor}18`}
        >
          <span
            style={`color: ${project.coverColor}; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.25rem; letter-spacing: -0.02em`}
          >{project.shortTitle.slice(0, 2).toUpperCase()}</span>
        </div>
      )}
    </div>

    <!-- Arrow -->
    <span
      class="hidden md:block shrink-0 text-[var(--color-muted)] group-hover:text-[var(--color-accent)] group-hover:translate-x-1 transition-all duration-200"
    >→</span>
  </a>
</article>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const cards = document.querySelectorAll<HTMLElement>('.project-card');
  cards.forEach((card) => {
    gsap.from(card, {
      opacity: 0,
      y: 28,
      duration: 0.65,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: card,
        start: 'top 92%',
        once: true,
      },
    });
  });
</script>
