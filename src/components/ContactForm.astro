---
const fieldStyle = "width: 100%; background: var(--color-paper); border: 1px solid var(--color-line); padding: 14px 16px; color: var(--color-ink); font-size: 14px; font-family: var(--font-body); outline: none; border-radius: 0;";
---

<div data-contact-root>
  <form data-contact-form style="display: flex; flex-direction: column; gap: 14px;">
    <input type="text" name="_gotcha" style="display: none;" tabindex="-1" autocomplete="off" />

    <div class="cf-name-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px;">
      <input type="text" name="name" placeholder="Your name" required class="cf-field" style={fieldStyle} />
      <input type="email" name="email" placeholder="your@email.com" required class="cf-field" style={fieldStyle} />
    </div>

    <textarea
      name="message"
      placeholder="Tell me about your project…"
      required
      rows="6"
      class="cf-field"
      style={`${fieldStyle} resize: none;`}
    ></textarea>

    <div style="display: flex; align-items: center; gap: 20px; margin-top: 8px;">
      <button
        type="submit"
        class="cf-submit"
        style="display: inline-flex; align-items: center; gap: 12px; color: var(--color-paper); font-size: 14px; font-weight: 500; padding: 14px 28px; border: none; border-radius: 0; cursor: pointer;"
      >
        <span data-submit-text>Send message</span>
        <span>→</span>
      </button>
      <p data-contact-error style="display: none; font-size: 13px; color: #c2410c;">
        Something went wrong.{' '}
        <button
          type="button"
          data-contact-retry
          style="text-decoration: underline; background: transparent; border: none; color: inherit; cursor: pointer;"
        >
          Try again
        </button>
      </p>
    </div>
  </form>

  <div
    data-contact-sent
    style="display: none; border: 1px solid var(--color-line); padding: 60px 40px; text-align: center; background: var(--color-paper);"
  >
    <p style="font-family: var(--font-display); font-weight: 600; font-size: 40px; color: var(--color-ink); margin-bottom: 12px; letter-spacing: -0.02em;">
      Message sent.
    </p>
    <p style="font-size: 14px; color: var(--color-ink-2); margin-bottom: 32px;">
      I'll get back to you soon.
    </p>
    <button
      type="button"
      data-contact-reset
      style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-2); border: none; background: transparent; cursor: pointer; border-bottom: 1px solid var(--color-line); padding-bottom: 4px;"
    >
      Send another →
    </button>
  </div>
</div>

<style>
  .cf-field:focus {
    border-color: var(--color-ink);
  }
  .cf-submit {
    background: var(--color-ink);
    transition: background 0.4s ease, opacity 0.2s ease;
  }
  .cf-submit:not(:disabled):hover {
    background: var(--color-accent);
  }
  .cf-submit:disabled {
    opacity: 0.5;
  }
  @media (max-width: 600px) {
    .cf-name-row { grid-template-columns: 1fr !important; }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-contact-root]');
  if (root) {
    const form = root.querySelector<HTMLFormElement>('[data-contact-form]');
    const sentMsg = root.querySelector<HTMLElement>('[data-contact-sent]');
    const submit = root.querySelector<HTMLButtonElement>('.cf-submit');
    const submitText = root.querySelector<HTMLElement>('[data-submit-text]');
    const errorMsg = root.querySelector<HTMLElement>('[data-contact-error]');
    const retry = root.querySelector<HTMLButtonElement>('[data-contact-retry]');
    const reset = root.querySelector<HTMLButtonElement>('[data-contact-reset]');
    const nameInput = form?.querySelector<HTMLInputElement>('input[name="name"]') ?? null;

    if (form && submit && submitText && errorMsg && sentMsg) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        submit.disabled = true;
        submitText.textContent = 'Sending…';
        errorMsg.style.display = 'none';

        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            body: new FormData(form),
          });
          if (res.ok) {
            form.reset();
            form.style.display = 'none';
            sentMsg.style.display = 'block';
          } else {
            errorMsg.style.display = 'block';
          }
        } catch {
          errorMsg.style.display = 'block';
        } finally {
          submit.disabled = false;
          submitText.textContent = 'Send message';
        }
      });
    }

    retry?.addEventListener('click', () => {
      if (errorMsg) errorMsg.style.display = 'none';
    });

    reset?.addEventListener('click', () => {
      if (sentMsg) sentMsg.style.display = 'none';
      if (form) form.style.display = 'flex';
      requestAnimationFrame(() => nameInput?.focus());
    });
  }
</script>
