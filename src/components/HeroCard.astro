---
export interface Props {
  src?: string;
  alt?: string;
}
const { src, alt = '' } = Astro.props;
---

<div class="hero-card-stage">
  {src
    ? <img src={src} alt={alt} class="hero-card-img" />
    : <div class="hero-card-img hero-card-placeholder"></div>
  }
</div>

<style is:global>
  /* Immediate parent — perspective only */
  .hero-card-stage {
    position: absolute;
    right: -4vw;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    pointer-events: none;
    perspective: 1000px;
    width: min(800px, 55vw);
    aspect-ratio: 16 / 10;
    border-radius: 10px;
    overflow: hidden;
  }

  /* Image / placeholder — 3D tilt lives here */
  .hero-card-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 10px;
    transform: rotateY(-20deg) rotateX(6deg);
    transform-style: preserve-3d;
    filter: drop-shadow(0 40px 60px rgba(0,0,0,0.6));
    transition: transform 500ms ease-out;
  }

  .hero-card-placeholder {
    background: linear-gradient(135deg, #0e4a3a, #1a4450);
  }

  @media (hover: hover) {
    .hero-card-stage:hover .hero-card-img {
      transform: rotateY(-8deg) rotateX(2deg);
    }
  }

  @media (max-width: 767px) {
    .hero-card-stage {
      width: min(400px, 80vw);
      right: -2vw;
      top: auto;
      bottom: -4vw;
      transform: none;
    }
    .hero-card-img {
      transform: rotateY(-10deg) rotateX(3deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-card-img {
      transform: none !important;
      transition: none;
      filter: none;
    }
  }
</style>
