---
import SectionShell from './SectionShell.astro';
import Grid from './Grid.astro';
import type { OutcomeItem } from '../../data/caseStudies/types';

interface Props {
  label: string;
  items: OutcomeItem[];
}
const { label, items } = Astro.props;
---
{items.length > 0 && (
  <SectionShell label={label}>
    <Grid columns={3}>
      {items.map((o) => (
        <div class="cs-outcome">
          <p style="font-family: var(--font-mono); font-size: 11px; color: var(--color-accent); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 16px">{o.label}</p>
          <p style="font-family: var(--font-display); font-weight: 500; font-size: 22px; line-height: 1.25; letter-spacing: -0.02em; color: var(--color-ink)">{o.value}</p>
        </div>
      ))}
    </Grid>
  </SectionShell>
)}
