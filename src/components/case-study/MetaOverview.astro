---
import type { Project } from '../../data/projects';

interface Props {
  project: Project;
}
const { project } = Astro.props;
---
<div
  class="cs-meta-grid"
  style="padding: 0 40px 100px; max-width: 1440px; margin-inline: auto; display: grid; grid-template-columns: 240px 1fr; gap: 80px"
>
  <aside style="display: flex; flex-direction: column; gap: 28px; padding-top: 8px">
    <div>
      <div style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-muted); margin-bottom: 6px">Role</div>
      <p style="font-size: 14px; color: var(--color-ink)">{project.role}</p>
    </div>
    {project.client && (
      <div>
        <div style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-muted); margin-bottom: 6px">Client</div>
        <p style="font-size: 14px; color: var(--color-ink)">{project.client}</p>
      </div>
    )}
    <div>
      <div style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-muted); margin-bottom: 6px">Year</div>
      <p style="font-size: 14px; color: var(--color-ink)">{project.year}</p>
    </div>
    <div>
      <div style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-muted); margin-bottom: 6px">Tools</div>
      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px">
        {project.tools.map((t) => (<li style="font-size: 13px; color: var(--color-ink-2)">{t}</li>))}
      </ul>
    </div>
  </aside>

  <div>
    <div
      style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-ink-2); margin-bottom: 24px"
    >— Overview</div>
    <p style="font-size: 18px; line-height: 1.55; color: var(--color-ink-2); margin-bottom: 32px">{project.overview}</p>
    {project.problem && (
      <>
        <div
          style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-ink-2); margin: 40px 0 24px"
        >— The challenge</div>
        <p style="font-size: 16px; line-height: 1.65; color: var(--color-ink-2)">{project.problem}</p>
      </>
    )}
  </div>
</div>
