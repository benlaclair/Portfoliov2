---
import SectionShell from './SectionShell.astro';
import RowList from './RowList.astro';
import type { ChallengeItem } from '../../data/caseStudies/types';

interface Props {
  label: string;
  items: ChallengeItem[];
}
const { label, items } = Astro.props;
---
{items.length > 0 && (
  <SectionShell label={label}>
    <RowList cols="80px 1fr" pad="28px">
      {items.map((c) => (
        <div class="cs-challenge" data-reveal>
          <p style="font-family: var(--font-mono); font-size: 11px; color: var(--color-ink-2); letter-spacing: 0.12em; padding-top: 4px">{c.number}</p>
          <div>
            <h3 style="font-family: var(--font-display); font-weight: 500; font-size: 22px; letter-spacing: -0.025em; line-height: 1.2; margin-bottom: 10px">{c.title}</h3>
            <p style="font-size: 15px; line-height: 1.6; color: var(--color-ink-2); max-width: 800px">{c.body}</p>
          </div>
        </div>
      ))}
    </RowList>
  </SectionShell>
)}
