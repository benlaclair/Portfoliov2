---
import SectionShell from './SectionShell.astro';
import Grid from './Grid.astro';
import type { StatItem } from '../../data/caseStudies/types';

interface Props {
  items: StatItem[];
}
const { items } = Astro.props;
---
{items.length > 0 && (
  <SectionShell>
    <Grid columns={4} cellPad="40px 32px">
      {items.map((s) => (
        <div class="cs-stat" data-reveal>
          <p
            style="font-family: var(--font-display); font-weight: 500; font-size: clamp(40px, 5vw, 72px); line-height: 1; letter-spacing: -0.02em; color: var(--color-ink); margin-bottom: 12px"
          >{s.value}</p>
          <p class="text-eyebrow">{s.label}</p>
        </div>
      ))}
    </Grid>
  </SectionShell>
)}
