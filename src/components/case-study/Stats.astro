---
import SectionShell from './SectionShell.astro';
import type { StatItem } from '../../data/caseStudies/types';

interface Props {
  items: StatItem[];
}
const { items } = Astro.props;
---
{items.length > 0 && (
  <SectionShell>
    <div
      class="cs-stats"
      style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--color-line)"
    >
      {items.map((s) => (
        <div class="cs-stat" style="background: var(--color-bg); padding: 40px 32px">
          <p
            style="font-family: var(--font-display); font-weight: 500; font-size: clamp(40px, 5vw, 72px); line-height: 1; letter-spacing: -0.04em; color: var(--color-ink); margin-bottom: 12px"
          >{s.value}</p>
          <p
            style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-2)"
          >{s.label}</p>
        </div>
      ))}
    </div>
  </SectionShell>
)}
