---
import SectionShell from './SectionShell.astro';
import type { DecisionItem } from '../../data/caseStudies/types';

interface Props {
  label: string;
  items: DecisionItem[];
}
const { label, items } = Astro.props;
---
{items.length > 0 && (
  <SectionShell label={label}>
    <div style="display: flex; flex-direction: column">
      {items.map((d) => (
        <div
          class="cs-decision"
          style="display: grid; grid-template-columns: 200px 1fr; gap: 60px; padding: 40px 0; border-top: 1px solid var(--color-line)"
        >
          <div>
            <p style="font-family: var(--font-mono); font-size: 11px; color: var(--color-ink-2); margin-bottom: 6px">{d.number}</p>
            <p style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-accent)">{d.label}</p>
          </div>
          <div>
            <h3 style="font-family: var(--font-display); font-weight: 500; font-size: clamp(24px, 3vw, 40px); letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 16px">{d.title}</h3>
            <p style="font-size: 15px; line-height: 1.65; color: var(--color-ink-2); margin-bottom: 20px">{d.description}</p>
            {d.before && d.after && (
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--color-line); margin-top: 20px">
                <div style="background: var(--color-paper); padding: 20px">
                  <p style="font-family: var(--font-mono); font-size: 10px; color: var(--color-muted); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 10px">Before</p>
                  <p style="font-size: 14px; color: var(--color-ink-2)">{d.before}</p>
                </div>
                <div style="background: var(--color-paper); padding: 20px; border-left: 2px solid var(--color-accent)">
                  <p style="font-family: var(--font-mono); font-size: 10px; color: var(--color-accent); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 10px">After</p>
                  <p style="font-size: 14px; color: var(--color-ink)">{d.after}</p>
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </SectionShell>
)}
