---
/**
 * StickyBackground — sticky bg layer stack for ScrollStage.
 *
 * Sits at position: sticky; top: 0 so it glues to the viewport
 * while the ScrollStage foreground scrolls past it. Each bg layer
 * fades in/out via IntersectionObserver driven from the parent
 * ScrollStage script — this component is purely presentational.
 *
 * Layer IDs must match the `bg` values in ScrollStage's headlines prop
 * and any post-stage sections that adopt the same crossfade.
 */

import HeroCarousel from './HeroCarousel.astro';

export interface Props {
  /** which layer is active on mount (default 'hero') */
  initialLayer?: string;
}

const { initialLayer = 'hero' } = Astro.props;
---

<div class="sticky-bg" aria-hidden="true">

  <div class="bg-stack">

    <div class="bg-layer" data-bg-layer="hero" class:list={[{ 'is-active': initialLayer === 'hero' }]}>
      <div class="bg-orb bg-orb--hero"></div>
      <HeroCarousel />
    </div>

    <div class="bg-layer" data-bg-layer="tagline" class:list={[{ 'is-active': initialLayer === 'tagline' }]}>
      <div class="bg-orb bg-orb--tagline"></div>
    </div>

    <div class="bg-layer" data-bg-layer="intent" class:list={[{ 'is-active': initialLayer === 'intent' }]}>
      <div class="bg-orb bg-orb--intent"></div>
    </div>

    <div class="bg-layer" data-bg-layer="work" class:list={[{ 'is-active': initialLayer === 'work' }]}>
      <div class="bg-orb bg-orb--work"></div>
    </div>

    <div class="bg-layer" data-bg-layer="contact" class:list={[{ 'is-active': initialLayer === 'contact' }]}>
      <div class="bg-orb bg-orb--contact"></div>
    </div>

    <div class="bg-noise"></div>

  </div>

</div>

<style is:global>
  .sticky-bg {
    position: sticky;
    top: 0;
    height: 100svh;
    z-index: 0;
    pointer-events: none;
    /* Negative margin pulls the next sibling up to overlap — foreground stack
       sits on top via z-index: 1 in ScrollStage */
    margin-bottom: -100svh;
  }

  .bg-stack {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .bg-layer {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 800ms ease-in-out;
    will-change: opacity;
  }
  .bg-layer.is-active { opacity: 1; }

  /* Base canvas per section */
  .bg-layer[data-bg-layer="hero"]    { background: #0a1230; }
  .bg-layer[data-bg-layer="tagline"] { background: #1a1a16; }
  .bg-layer[data-bg-layer="intent"]  { background: #0d1a1a; }
  .bg-layer[data-bg-layer="work"]    { background: #1a0d22; }
  .bg-layer[data-bg-layer="contact"] { background: #0a0d12; }

  /* Drifting blurred orb inside each layer */
  .bg-orb {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 75vw;
    height: 75vw;
    max-width: 1200px;
    max-height: 1200px;
    filter: blur(140px);
    will-change: transform;
    animation: bg-orb-drift 16s ease-in-out infinite alternate;
    pointer-events: none;
  }
  @keyframes bg-orb-drift {
    0%   { transform: translate(-68%, -54%) scale(1.00); }
    50%  { transform: translate(-52%, -48%) scale(1.12); }
    100% { transform: translate(-64%, -52%) scale(1.05); }
  }

  /* Per-section orb gradients */
  /* Hero orb is upsized + brighter to read as a strong indigo glow behind
     the carousel. The base 140px blur smears the stops into a soft halo. */
  .bg-orb--hero {
    width: 110vw;
    height: 110vw;
    max-width: 1800px;
    max-height: 1800px;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(123, 138, 200, 0.85) 0%,
      rgba(91, 108, 171, 0.55) 25%,
      rgba(60, 75, 130, 0.30) 50%,
      rgba(10, 18, 48, 0)     75%
    );
  }
  .bg-orb--tagline { background: radial-gradient(circle at 50% 50%, #ece6d6 0%, #6b6450 35%, #1a1a16 65%, transparent 80%); }
  .bg-orb--intent  { background: radial-gradient(circle at 50% 50%, #3fd9b0 0%, #1a4450 30%, #0d1a1a 60%, transparent 80%); }
  .bg-orb--work    { background: radial-gradient(circle at 50% 50%, #9b59ff 0%, #4a2270 30%, #1a0d22 60%, transparent 80%); }
  .bg-orb--contact { background: radial-gradient(circle at 50% 50%, #5b6cab 0%, #2a3155 30%, #0a0d12 60%, transparent 80%); }

  /* SVG noise overlay — sits above rings (z:1) and card (z:2) */
  .bg-noise {
    position: absolute;
    inset: 0;
    z-index: 3;
    opacity: 0.15;
    mix-blend-mode: overlay;
    pointer-events: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='100%' height='100%' filter='url(%23n)' opacity='0.85'/></svg>");
    background-repeat: repeat;
    background-size: 200px 200px;
  }

  /* Reduced motion — freeze orb drift */
  @media (prefers-reduced-motion: reduce) {
    .bg-orb {
      animation: none;
      transform: translate(-50%, -50%);
    }
  }
</style>
