---
import { Image } from 'astro:assets';
import type { Project } from '../data/projects';
import { PROJECTS } from '../data/projects';

export interface Props {
  /** 'stack' (default) renders cards in normal flow with per-card scrub.
      'reel' renders cards for absolute-positioned use inside a parent
      pinned timeline (#reel in index.astro), with no internal scroll triggers. */
  variant?: 'stack' | 'reel';
}
const { variant = 'stack' } = Astro.props;
const featured: Project[] = PROJECTS.slice(0, 3);
---

<section class="hwork" id="hwork" data-variant={variant}>
  <div class="hwork-stack">
    {featured.map((p, i) => {
      const num = String(i + 1).padStart(2, '0');
      const isDark = i === 1;
      return (
        <article
          class="hwork-panel"
          data-panel
          data-index={i}
          data-section-mode={isDark ? 'dark' : undefined}
        >
          <a href={`/work/${p.slug}`} class="hwork-panel-inner">
            <div class="hwork-meta">
              <div class="hwork-meta-num">{num} / 03</div>
              <div class="hwork-meta-cat">{p.category} &middot; {p.year}</div>
              <h3 class="hwork-title" data-title>
                <span class="line"><span>{p.shortTitle}</span></span>
              </h3>
              <p class="hwork-desc">{p.description}</p>
              <span class="hwork-link">
                Read case
                <span class="arrow">→</span>
              </span>
            </div>
            <div class="hwork-visual" data-visual>
              <div class="hwork-visual-inner" data-inner>
                {p.coverImage && p.coverWidth && p.coverHeight ? (
                  <Image
                    src={p.coverImage}
                    alt={p.shortTitle}
                    width={p.coverWidth}
                    height={p.coverHeight}
                    widths={[600, 1200, 1800]}
                    sizes="(max-width: 900px) 100vw, 50vw"
                    format="webp"
                    loading="lazy"
                  />
                ) : (
                  <div
                    class="hwork-fallback"
                    style={`background: linear-gradient(135deg, ${p.coverColor}25, ${p.coverColor}08)`}
                  >
                    <span style={`color: ${p.coverColor}; font-family: var(--font-display);`}>
                      {p.shortTitle}
                    </span>
                  </div>
                )}
              </div>
              <div class="hwork-visual-label">{p.category} &middot; {p.year}</div>
            </div>
          </a>
        </article>
      );
    })}
  </div>
</section>

<style>
  .hwork { position: relative; }

  /* Stack — vertical three-room rhythm: Light · Dark · Mid-tone */
  .hwork-stack {
    display: flex;
    flex-direction: column;
    gap: 80px;
    padding: 0 40px 120px;
  }
  .hwork-panel {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
  }
  .hwork-panel[data-index="0"] { background: var(--color-bg); }
  .hwork-panel[data-index="1"] { background: var(--color-dark-bg); color: var(--color-dark-ink); }
  .hwork-panel[data-index="2"] { background: var(--color-bg-2); }

  /* Dark middle panel text overrides */
  .hwork-panel[data-index="1"] .hwork-meta-num { color: var(--color-dark-muted); }
  .hwork-panel[data-index="1"] .hwork-desc { color: var(--color-dark-ink-2); }
  .hwork-panel[data-index="1"] .hwork-title,
  .hwork-panel[data-index="1"] .hwork-link { color: var(--color-dark-ink); }
  .hwork-panel[data-index="1"] .hwork-visual-label { color: rgba(244, 239, 228, 0.55); }

  .hwork-panel-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding: clamp(40px, 5vw, 64px);
    border-radius: 24px;
    background: var(--color-paper);
    border: 1px solid var(--color-line-soft);
    box-shadow: var(--shadow-card);
    will-change: transform, box-shadow, opacity;
    transform-origin: center center;
    transition: box-shadow 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Dark room: 2px accent stroke defines the edge against the near-identical
     #0d0c0a room and signals this card as the dramatic anchor. */
  .hwork-panel[data-index="1"] .hwork-panel-inner {
    background: var(--color-dark-bg-alt);
    border: 2px solid var(--color-accent);
    box-shadow: var(--shadow-card-dark);
  }

  .hwork-panel-inner.is-active {
    box-shadow: var(--shadow-card-active);
  }
  .hwork-panel[data-index="1"] .hwork-panel-inner.is-active {
    box-shadow: var(--shadow-card-dark-active);
  }

  .hwork-meta-num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--color-ink-2);
    text-transform: uppercase;
    margin-bottom: 32px;
  }
  .hwork-meta-cat {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .hwork-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(48px, 6vw, 96px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin-bottom: 32px;
  }
  .hwork-desc {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-ink-2);
    max-width: 480px;
    margin-bottom: 32px;
  }
  .hwork-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink);
  }
  .hwork-link .arrow {
    transition: transform 0.5s cubic-bezier(.7,0,.2,1);
  }
  .hwork-panel-inner:hover .hwork-link .arrow { transform: translateX(8px); }

  .hwork-visual {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    background: var(--color-paper);
    overflow: hidden;
    border-radius: 2px;
    clip-path: inset(0 100% 0 0);
    transform-origin: center center;
    will-change: transform, clip-path;
    transition: clip-path 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hwork-visual.in { clip-path: inset(0 0 0 0); }
  .hwork-visual-inner {
    position: absolute;
    inset: -8%;
    will-change: transform;
  }
  .hwork-visual-inner img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .hwork-fallback {
    width: 100%; height: 100%;
    display: grid; place-items: center;
    font-size: clamp(56px, 8vw, 120px);
    font-style: italic;
    letter-spacing: -0.04em;
    opacity: 0.5;
  }
  .hwork-visual-label {
    position: absolute;
    left: 16px; bottom: 14px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: rgba(22,20,15,0.45);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    z-index: 2;
  }

  @media (max-width: 900px) {
    .hwork-header { padding-block: 80px 40px; }
    .hwork-stack { gap: 48px; padding: 0 24px 80px; }
    .hwork-panel-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>

<script>
  import { gsap, ScrollTrigger, ease, reduceMotion } from '../lib/motion';

  const root = document.querySelector<HTMLElement>('.hwork');
  const variant = root?.dataset.variant ?? 'stack';
  const panels = gsap.utils.toArray<HTMLElement>('[data-panel]');
  const cards = panels.map((p) => p.querySelector<HTMLElement>('.hwork-panel-inner'));

  // Reel variant: cards are driven by the parent #reel timeline in index.astro.
  // Set all visuals + title lines to their final state immediately so cards
  // are fully painted whenever the reel timeline slides them on stage.
  if (variant === 'reel') {
    panels.forEach((panel, i) => {
      const card = cards[i];
      const visual = panel.querySelector<HTMLElement>('[data-visual]');
      const titleSpan = panel.querySelector<HTMLElement>('[data-title] .line > span');
      if (titleSpan) gsap.set(titleSpan, { y: 0 });
      if (visual) visual.classList.add('in');
      if (card) card.classList.add('is-active');
    });
  } else if (panels.length) {
    panels.forEach((panel, i) => {
      const card = cards[i];
      const visual = panel.querySelector<HTMLElement>('[data-visual]');
      const inner = panel.querySelector<HTMLElement>('[data-inner]');
      const titleSpan = panel.querySelector<HTMLElement>('[data-title] .line > span');

      if (reduceMotion.current) {
        // Static fallback — all cards full, no motion
        if (titleSpan) gsap.set(titleSpan, { y: 0 });
        if (visual) visual.classList.add('in');
        if (card) card.classList.add('is-active');
        return;
      }

      if (titleSpan) gsap.set(titleSpan, { y: '110%' });

      // Card enter: scale + y + opacity as it rises into focus.
      // Card 0 is snapped to final state (driven by the intro-stage
      // scrubbed timeline in index.astro). Cards 1+ use the normal scrub.
      if (i === 0) {
        gsap.set(card, { scale: 1, yPercent: 0, opacity: 1 });
      } else {
        gsap.fromTo(card, {
          scale: 0.92,
          yPercent: 12,
          opacity: 0.6,
        }, {
          scale: 1,
          yPercent: 0,
          opacity: 1,
          ease: 'none',
          scrollTrigger: {
            trigger: panel,
            start: 'top 85%',
            end: 'center 55%',
            scrub: 0.8,
          },
        });
      }

      // Card exit: scale back as it recedes from focus (ALL cards)
      gsap.fromTo(card, {
        scale: 1,
        yPercent: 0,
        opacity: 1,
      }, {
        scale: 0.96,
        yPercent: -8,
        opacity: 0.7,
        ease: 'none',
        scrollTrigger: {
          trigger: panel,
          start: 'center 45%',
          end: 'bottom 15%',
          scrub: 0.8,
        },
      });

      // One-shot reveal of clip-path + title line when card enters focal range
      ScrollTrigger.create({
        trigger: panel,
        start: 'top 70%',
        once: true,
        onEnter: () => {
          if (visual) visual.classList.add('in');
          if (titleSpan) gsap.to(titleSpan, { y: '0%', duration: 0.9, ease: ease.expo });
        },
      });

      // Inner image parallax across the card's viewport lifetime
      if (inner) {
        gsap.fromTo(inner, { yPercent: -8 }, {
          yPercent: 8,
          ease: 'none',
          scrollTrigger: {
            trigger: panel,
            start: 'top bottom',
            end: 'bottom top',
            scrub: true,
          },
        });
      }
    });

    // Active-card detection via IntersectionObserver — most-visible panel wins.
    // .is-active just toggles the elevated shadow; body[data-mode] is handled
    // by BaseLayout's data-section-mode ScrollTrigger on the dark middle panel.
    if (!reduceMotion.current) {
      const visibility = new Map<Element, number>();
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => visibility.set(e.target, e.intersectionRatio));
          let best: Element | null = null;
          let bestRatio = 0;
          visibility.forEach((r, el) => {
            if (r > bestRatio) {
              bestRatio = r;
              best = el;
            }
          });
          cards.forEach((c, ci) => {
            const isActive = panels[ci] === best && bestRatio > 0.25;
            c?.classList.toggle('is-active', isActive);
          });
        },
        { threshold: Array.from({ length: 11 }, (_, i) => i / 10) },
      );
      panels.forEach((p) => observer.observe(p));
    }
  }
</script>
