---
const items = [
  'UI/UX DESIGN',
  'BRAND IDENTITY',
  'VISUAL DESIGN',
  'TYPOGRAPHY',
  'INTERACTION DESIGN',
  'LOGO SYSTEMS',
  'PACKAGING',
  'DESIGN STRATEGY',
];
---
<div class="bg-grad py-4 overflow-hidden">
  <div class="marquee-track flex whitespace-nowrap will-change-transform" style="width: max-content;">
    {[0, 1, 2, 3].map(() =>
      items.map((item) => (
        <span class="text-[#080B0F] font-extrabold text-sm tracking-widest uppercase shrink-0">
          <span class="opacity-40 mx-6">·</span>
          {item}
        </span>
      ))
    )}
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  const tracks = document.querySelectorAll<HTMLElement>('.marquee-track');
  tracks.forEach((track) => {
    const total = track.scrollWidth;
    gsap.to(track, {
      x: -total / 4,
      duration: 30,
      ease: 'none',
      repeat: -1,
    });
  });
</script>
