---
interface Props {
  items?: string[];
  speed?: number;
  separator?: string;
}

const {
  items = ['UX / UI', 'Brand Identity', 'AI Video', 'Web Development', 'Editorial', 'Motion', 'Graphic Design'],
  speed = 40,
  separator = '—',
} = Astro.props;

const content = items.join(`  ${separator}  `);
---
<div class="marquee" data-speed={speed}>
  <div class="marquee-track" data-marquee-track>
    {/* Render content multiple times so the loop is seamless */}
    {[0, 1, 2, 3].map(() => (
      <span class="marquee-item">
        {content}
        <span class="marquee-sep">  {separator}  </span>
      </span>
    ))}
  </div>
</div>

<style>
  .marquee {
    overflow: hidden;
    white-space: nowrap;
    border-block: 1px solid var(--color-line);
    padding: 28px 0;
    background: var(--color-bg);
  }
  .marquee-track {
    display: inline-flex;
    gap: 0;
    will-change: transform;
  }
  .marquee-item {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(28px, 4vw, 56px);
    letter-spacing: -0.02em;
    color: var(--color-ink);
    flex-shrink: 0;
    padding-inline: 8px;
  }
  .marquee-sep {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-style: normal;
  }
</style>

<script>
  import { gsap, reduceMotion } from '../lib/motion';

  if (reduceMotion.current) {
    // Static fallback: leave the track in place. The duplicated content is
    // already visible; an infinite loop would conflict with reduced-motion intent.
  } else {
    document.querySelectorAll<HTMLElement>('.marquee').forEach((el) => {
      const track = el.querySelector<HTMLElement>('[data-marquee-track]');
      if (!track) return;
      const speed = parseFloat(el.dataset.speed || '40');
      const totalWidth = track.scrollWidth;
      const distance = totalWidth / 4; // we duplicated 4x; one cycle is 1/4
      const tween = gsap.to(track, {
        x: -distance,
        duration: distance / speed,
        ease: 'none',
        repeat: -1,
      });
      el.addEventListener('mouseenter', () => tween.timeScale(0.2));
      el.addEventListener('mouseleave', () => tween.timeScale(1));
    });
  }
</script>
