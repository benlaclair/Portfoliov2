---
// 25 circles per group, radii 30–750 in steps of 30
const radii = Array.from({ length: 25 }, (_, i) => 30 + i * 30);
---

<div class="hero-rings-wrap" aria-hidden="true">
  <svg
    viewBox="0 0 1000 1000"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g class="rings-a" style="will-change: transform; transform-origin: 50% 50%;">
      {radii.map(r => (
        <circle cx="500" cy="500" r={r} fill="none" stroke="currentColor" stroke-width="0.6" />
      ))}
    </g>
    <g class="rings-b" style="will-change: transform; transform-origin: 50% 50%;">
      {radii.map(r => (
        <circle cx="500" cy="500" r={r + 15} fill="none" stroke="currentColor" stroke-width="0.6" />
      ))}
    </g>
  </svg>
</div>

<style is:global>
  .hero-rings-wrap {
    --ring-color: rgba(255, 255, 255, 0.08);
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    color: var(--ring-color);
    mask-image: radial-gradient(ellipse at 60% 50%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at 60% 50%, black 30%, transparent 80%);
  }

  .hero-rings-wrap svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .rings-a {
    animation: ring-breathe-a 14s ease-in-out infinite;
  }

  .rings-b {
    opacity: 0.6;
    animation: ring-breathe-b 14s ease-in-out infinite;
    animation-delay: -7s;
  }

  @keyframes ring-breathe-a {
    0%, 100% { transform: scale(1);    }
    50%       { transform: scale(1.12); }
  }

  @keyframes ring-breathe-b {
    0%, 100% { transform: scale(1.12); }
    50%       { transform: scale(1);    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rings-a, .rings-b {
      animation: none;
      transform: scale(1);
    }
  }
</style>
