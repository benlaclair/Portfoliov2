---
/**
 * HeroCarousel — Three.js WebGL rotating 3D ring of graphic-design pieces.
 * Images passed via data-attribute (define:vars breaks ES module imports).
 */
import { DESIGN_GROUPS } from '../data/graphicDesign';

const allImages = DESIGN_GROUPS.flatMap(g => g.images);
const N = 8;
const stride = Math.max(1, Math.floor(allImages.length / N));
const ringImages = Array.from({ length: N }, (_, i) => allImages[i * stride] ?? allImages[i % allImages.length]);
const srcs = ringImages.map(img => img.src);
---

<canvas
  id="hc-canvas"
  aria-hidden="true"
  data-srcs={JSON.stringify(srcs)}
></canvas>

<style>
  #hc-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
    z-index: 2;
    /* Overall softening so the carousel reads as background atmosphere
       layered with the per-card depth blur from the shader. */
    filter: blur(14px);
    opacity: 0.78;
  }

  @media (prefers-reduced-motion: reduce) {
    #hc-canvas { display: none; }
  }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('hc-canvas') as HTMLCanvasElement;
  if (!canvas) throw new Error('hc-canvas missing');

  const srcs: string[] = JSON.parse(canvas.dataset.srcs ?? '[]');

  // ── Renderer ──────────────────────────────────────────────────────────────
  function getSize() {
    const parent = canvas.parentElement;
    return parent
      ? { w: parent.clientWidth || window.innerWidth, h: parent.clientHeight || window.innerHeight }
      : { w: window.innerWidth, h: window.innerHeight };
  }

  const { w: initW, h: initH } = getSize();

  const renderer = new THREE.WebGLRenderer({
    canvas,
    antialias: true,
    alpha: true,
    powerPreference: 'high-performance',
  });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));
  renderer.setSize(initW, initH);
  renderer.outputColorSpace = THREE.SRGBColorSpace;
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.1;

  // ── Scene / Camera ────────────────────────────────────────────────────────
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(48, initW / initH, 0.1, 200);
  camera.position.set(0, 0, 22);
  camera.lookAt(0, 0, 0);

  // ── Lights ────────────────────────────────────────────────────────────────
  // Ambient only — drop the cool-blue DirectionalLight so it doesn't cast on
  // the card textures. Card brightness lives in the fragment shader now.
  scene.add(new THREE.AmbientLight(0xffffff, 1.2));

  // ── Ring group ────────────────────────────────────────────────────────────
  // Tuning levers (apechain reference):
  //   RADIUS            — wider = fewer cards visible, back curves off-screen
  //   CARD_W / CARD_H   — 16:9 cinematic card aspect
  //   camera.position.z — closer = larger front card, sharper side angles
  //   camera.fov        — wider = more of the ring in frame
  //   ring.rotation.x   — subtle forward tilt only; no Z roll
  // Two-group hierarchy so the spin happens IN the tilted frame.
  // Outer container holds the diagonal Z tilt. Inner ring holds the forward
  // X tilt AND the Y spin. Without this nesting, Three.js's default 'XYZ'
  // Euler order makes the Y spin run around the WORLD Y axis (X·Y·Z matrix
  // product applies Y after Z), so cards trace horizontal circles instead
  // of the tilted ring path.
  const ringContainer = new THREE.Group();
  ringContainer.rotation.z = THREE.MathUtils.degToRad(60);
  scene.add(ringContainer);

  const ring = new THREE.Group();
  ring.rotation.x = THREE.MathUtils.degToRad(3);
  ringContainer.add(ring);

  // Layout. RADIUS is hand-tuned for the close-up "in your face" framing
  // (front card ~8 units from camera, fills ~76% viewport vertical). H
  // (constant card height) is DERIVED below from the ring-closing
  // constraint so per-card aspect-correct widths still close the ring
  // exactly with a constant angular GAP:
  //   sum(W_i)/R + N*GAP = 2π
  //   H · sum(aspects) / R + N*GAP = 2π
  //   H = R · (2π - N*GAP) / sum(aspects)
  // Tuning levers:
  //   RADIUS — close-up framing; bigger = front card fills more of viewport
  //   GAP    — angular spacing between adjacent cards
  // H is derived; lots of wide content → shorter cards; lots of square
  // content → taller cards. Aspect ratios per card are always preserved.
  const RADIUS = 14;
  const GAP = THREE.MathUtils.degToRad(5);

  const loader = new THREE.TextureLoader();
  const meshes: THREE.Mesh[] = [];

  // True cylindrical wrap: each flat plane is bent around a cylinder of radius
  // uRadius whose axis sits at local (0, *, -uRadius). The card surface lies
  // ON the ring surface — not a fake sin() bump.
  // vDist passes world-space camera distance to the fragment shader for the
  // depth-blur LOD bias.
  const vertexShader = /* glsl */`
    varying vec2 vUv;
    varying float vDist;
    uniform float uRadius;
    void main() {
      vUv = uv;
      float theta = position.x / uRadius;
      vec3 wrapped = vec3(
        uRadius * sin(theta),
        position.y,
        uRadius * cos(theta) - uRadius
      );
      vec4 worldPos = modelMatrix * vec4(wrapped, 1.0);
      vDist = length(worldPos.xyz - cameraPosition);
      gl_Position = projectionMatrix * viewMatrix * worldPos;
    }
  `;

  const fragmentShader = /* glsl */`
    varying vec2 vUv;
    varying float vDist;
    uniform sampler2D uMap;
    uniform float uFront;
    uniform float uLoaded;

    // Gradient-map palette — compressed to stay in the cool indigo range
    // so the carousel never produces bright cream highlights that fight
    // the foreground text. G_LIGHT is now a mid-bright indigo instead of
    // cream — the carousel reads as a unified blue atmospheric wash.
    const vec3 G_DARK  = vec3(0.039, 0.071, 0.188); // #0a1230 navy
    const vec3 G_MID   = vec3(0.357, 0.424, 0.671); // #5b6cab indigo accent
    const vec3 G_LIGHT = vec3(0.502, 0.565, 0.784); // #8090c8 light indigo

    // Depth-blur falloff. Tune these to taste.
    const float BLUR_NEAR = 8.0;   // distance where blur starts (sharp)
    const float BLUR_FAR  = 32.0;  // distance where blur peaks
    const float BLUR_MAX  = 8.0;   // max mip LOD bias

    // Atmospheric perspective — distant cards fade toward background navy.
    // Pairs with the depth blur to create perceived spatial depth.
    const float ATMOS_START = 8.0;
    const float ATMOS_END   = 32.0;
    const float ATMOS_AMT   = 0.92;

    void main() {
      // Depth-of-field via mipmap LOD bias — far cards sample blurrier mips.
      float blur = smoothstep(BLUR_NEAR, BLUR_FAR, vDist) * BLUR_MAX;

      vec4 placeholder = vec4(0.08, 0.08, 0.14, 1.0);
      vec4 tex = texture2D(uMap, vUv, blur);
      vec4 col = mix(placeholder, tex, uLoaded);

      // Gradient map — collapse the card's luminance onto the site palette.
      float lum = dot(col.rgb, vec3(0.299, 0.587, 0.114));
      col.rgb = mix(
        mix(G_DARK, G_MID, smoothstep(0.0, 0.5, lum)),
        G_LIGHT,
        smoothstep(0.5, 1.0, lum)
      );

      // Atmospheric fade — distant cards lose contrast toward background.
      float atmos = smoothstep(ATMOS_START, ATMOS_END, vDist) * ATMOS_AMT;
      col.rgb = mix(col.rgb, G_DARK, atmos);

      // Subtle gloss highlight on the front card after gradient mapping.
      float gloss = pow(max(0.0, 0.5 - abs(vUv.x - 0.5)), 3.0) * 0.2 * uFront;
      col.rgb += gloss;

      gl_FragColor = col;
    }
  `;

  // Preload every image to extract its natural aspect ratio. We need this
  // before building geometry so each card's WIDTH matches its source art.
  // The texture object returned here is the same one we'll use as uMap.
  function loadCardData(src: string): Promise<{ texture: THREE.Texture; aspect: number }> {
    return new Promise((resolve, reject) => {
      loader.load(
        src,
        (texture) => {
          texture.colorSpace = THREE.SRGBColorSpace;
          texture.anisotropy = renderer.capabilities.getMaxAnisotropy();
          const img = texture.image as HTMLImageElement;
          const aspect = (img.naturalWidth || 1) / (img.naturalHeight || 1);
          resolve({ texture, aspect });
        },
        undefined,
        reject,
      );
    });
  }

  const cardData = await Promise.all(srcs.map(loadCardData));
  const N_ACTUAL = cardData.length;
  const sumAspects = cardData.reduce((s, d) => s + d.aspect, 0);

  // Derive H from target RADIUS so the ring closes exactly with constant gap.
  const H = RADIUS * (Math.PI * 2 - N_ACTUAL * GAP) / sumAspects;
  const widths = cardData.map((d) => H * d.aspect);

  // Walk the ring placing each card's center at the midpoint of its arc slot.
  const centerAngles: number[] = [];
  {
    let cursor = 0;
    for (let i = 0; i < N_ACTUAL; i++) {
      const arc = widths[i] / RADIUS;
      centerAngles.push(cursor + arc / 2);
      cursor += arc + GAP;
    }
  }

  cardData.forEach(({ texture }, i) => {
    // Per-card geometry: width matches source-image aspect, height is shared.
    // 64 width segments stay smooth for the cylindrical wrap at any width.
    const cardGeo = new THREE.PlaneGeometry(widths[i], H, 64, 4);

    const mat = new THREE.ShaderMaterial({
      uniforms: {
        uMap:    { value: texture },
        uRadius: { value: RADIUS },
        uFront:  { value: 0 },
        uLoaded: { value: 1 },
      },
      transparent: true,
      // DoubleSide: back-of-ring cards stay visible as they arc behind the
      // camera, reading as continuous ring depth. Back faces render the
      // texture mirrored (we're looking at the back of a UV-mapped plane);
      // the diagonal tilt offsets them into the corners so the mirror reads
      // as background atmosphere rather than broken focal content.
      side: THREE.DoubleSide,
      vertexShader,
      fragmentShader,
    });

    const mesh = new THREE.Mesh(cardGeo, mat);
    const angle = centerAngles[i];
    mesh.position.set(Math.sin(angle) * RADIUS, 0, Math.cos(angle) * RADIUS);
    mesh.rotation.y = angle;
    ring.add(mesh);
    meshes.push(mesh);
  });

  // ── Auto-rotate ───────────────────────────────────────────────────────────
  let ringAngle = 0;
  let targetAngle = 0;
  const AUTO_SPEED = 0.00007;   // inner ring spin (~90s per cycle)
  const TILT_SPEED = 0.00002;   // outer Z-tilt precession (~5min per cycle)
  let lastTime = performance.now();

  // ── Resize ────────────────────────────────────────────────────────────────
  const ro = new ResizeObserver(() => {
    const { w, h } = getSize();
    renderer.setSize(w, h);
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
  });
  ro.observe(canvas.parentElement ?? document.body);

  // ── Animate ───────────────────────────────────────────────────────────────
  const camDir = new THREE.Vector3();

  function animate(now: number) {
    const dt = Math.min(30, now - lastTime);
    lastTime = now;

    targetAngle -= AUTO_SPEED * dt;
    ringAngle += (targetAngle - ringAngle) * (1 - Math.pow(0.0001, dt * 0.001));
    ring.rotation.y = ringAngle;

    // Slow precession — the diagonal direction itself rotates over ~5min.
    ringContainer.rotation.z += TILT_SPEED * dt;

    camera.getWorldDirection(camDir);
    meshes.forEach((mesh, i) => {
      const angle = centerAngles[i] + ringAngle;
      const dot = Math.max(0, -camDir.x * Math.sin(angle) + -camDir.z * Math.cos(angle));
      const mat = mesh.material as THREE.ShaderMaterial;
      mat.uniforms.uFront.value += (dot - mat.uniforms.uFront.value) * 0.06;
    });

    renderer.render(scene, camera);
    requestAnimationFrame(animate);
  }

  requestAnimationFrame(animate);
</script>
