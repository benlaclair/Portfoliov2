---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { PROJECTS } from '../../data/projects';
---

<BaseLayout
  title="Work — Ben LaClair"
  description="Selected UX/UI, brand, AI creative, and graphic design work."
>
  <div style="padding: 140px 40px 80px; max-width: 1440px; margin-inline: auto">

    <div style="border-bottom: 1px solid var(--color-line); padding-bottom: 60px; margin-bottom: 0">
      <div class="section-num" style="margin-bottom: 40px">— Selected work</div>
      <div
        class="work-head"
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end"
      >
        <h1 class="work-h1 text-display-xl">
          <span class="line"><span>Selected <span class="accent">work.</span></span></span>
        </h1>
        <p style="font-size: 16px; line-height: 1.6; color: var(--color-ink-2); max-width: 460px; padding-bottom: 16px">
          UX/UI, brand identity, AI creative, and graphic design — four projects across five years.
        </p>
      </div>
    </div>

    {PROJECTS.map((project, i) => (
      <ProjectCard project={project} index={i} />
    ))}

  </div>
</BaseLayout>

<style>
  @media (max-width: 900px) {
    .work-head { grid-template-columns: 1fr !important; gap: 24px !important; }
  }
</style>

<script>
  import { revealLines } from '../../lib/motion';
  revealLines('.work-h1 .line span');
</script>
