---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { PROJECTS } from '../../data/projects';
---

<BaseLayout
  title="Work — Ben LaClair"
  description="Selected UX/UI, brand, AI creative, and graphic design work."
>
  <div style="padding: 140px 40px 80px; max-width: 1440px; margin-inline: auto">

    <div style="border-bottom: 1px solid var(--color-line); padding-bottom: 60px; margin-bottom: 0">
      <div
        style="font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-ink-2); margin-bottom: 40px"
      >— Selected work</div>
      <div
        class="work-head"
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end"
      >
        <h1
          class="work-h1"
          style="font-family: 'Inter Tight Variable', 'Inter Tight', sans-serif; font-weight: 500; font-size: clamp(72px, 13vw, 200px); letter-spacing: -0.045em; line-height: 0.92"
        >
          <span class="line"><span>Selected <em>work.</em></span></span>
        </h1>
        <p style="font-size: 16px; line-height: 1.6; color: var(--color-ink-2); max-width: 460px; padding-bottom: 16px">
          UX/UI, brand identity, AI creative, and graphic design — four projects across five years.
        </p>
      </div>
    </div>

    {PROJECTS.map((project, i) => (
      <ProjectCard project={project} index={i} />
    ))}

  </div>
</BaseLayout>

<style>
  @media (max-width: 900px) {
    .work-head { grid-template-columns: 1fr !important; gap: 24px !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  gsap.set('.work-h1 .line span', { y: '110%' });
  gsap.to('.work-h1 .line span', { y: '0%', duration: 1.1, ease: 'expo.out', delay: 0.1 });
</script>
