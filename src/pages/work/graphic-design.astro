---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { DESIGN_GROUPS, totalImages } from '../../data/graphicDesign';
---

<BaseLayout
  title="Graphic Design — Ben LaClair"
  description="A curated selection of brand, editorial, and visual design work spanning esports, ESPN-affiliated tournaments, and brand systems."
>
  <div class="px-6 md:px-12 pt-16 pb-24">
    <div class="max-w-[1200px] mx-auto">

      <!-- Header -->
      <div class="mb-16">
        <a href="/work" class="inline-flex items-center gap-2 text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)] transition-colors mb-8 block">
          &larr; All work
        </a>
        <p class="eyebrow mb-5">Graphic Design &middot; 2020–2026</p>
        <h1 class="font-serif text-5xl md:text-6xl text-[var(--color-ink)] mb-5">
          Brand &amp; Editorial
        </h1>
        <p class="text-base text-[var(--color-muted)] max-w-lg leading-relaxed">
          {totalImages} pieces across esports, ESPN-affiliated tournaments, and brand work.
          Stream overlays, event posters, email campaigns, logos, and wayfinding systems.
        </p>
      </div>

      <!-- Groups -->
      {DESIGN_GROUPS.map((group) => (
        <section class="mb-20 md:mb-28">
          <div class="flex items-baseline justify-between mb-6 pb-4 border-b border-[var(--color-line)]">
            <div>
              <h2 class="font-serif text-2xl md:text-3xl text-[var(--color-ink)]">{group.title}</h2>
              <p class="text-sm text-[var(--color-muted)] mt-1 max-w-md">{group.description}</p>
            </div>
            <span class="eyebrow shrink-0">{group.images.length} pieces</span>
          </div>

          <div class="columns-2 md:columns-3 gap-3 md:gap-4">
            {group.images.map((img, i) => (
              <button
                class="gallery-thumb w-full mb-3 md:mb-4 break-inside-avoid block rounded-xl overflow-hidden bg-[var(--color-line-soft)] group cursor-zoom-in"
                data-src={img.src}
                data-alt={img.alt}
                data-index={i}
                aria-label={`View: ${img.alt}`}
              >
                <img
                  src={img.src}
                  alt={img.alt}
                  width="600"
                  height="600"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-auto block transition-transform duration-500 group-hover:scale-[1.02]"
                />
              </button>
            ))}
          </div>
        </section>
      ))}

    </div>
  </div>

  <!-- Lightbox (vanilla JS, no React needed) -->
  <div
    id="lightbox"
    class="fixed inset-0 z-50 bg-[var(--color-ink)]/90 backdrop-blur-md hidden items-center justify-center p-4 md:p-12"
    role="dialog"
    aria-modal="true"
    aria-label="Image lightbox"
  >
    <button
      id="lb-close"
      class="absolute top-4 right-4 md:top-6 md:right-6 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors"
      aria-label="Close"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <button
      id="lb-prev"
      class="absolute left-3 md:left-6 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors"
      aria-label="Previous"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </button>
    <button
      id="lb-next"
      class="absolute right-3 md:right-6 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors"
      aria-label="Next"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </button>
    <img
      id="lb-img"
      src=""
      alt=""
      class="max-w-full max-h-[85vh] object-contain rounded-xl shadow-2xl"
    />
  </div>
</BaseLayout>

<script>
  const thumbs = Array.from(document.querySelectorAll<HTMLButtonElement>('.gallery-thumb'));
  const lb = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  let current = 0;

  function openLightbox(index: number) {
    current = index;
    const btn = thumbs[current];
    lbImg.src = btn.dataset.src!;
    lbImg.alt = btn.dataset.alt!;
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.style.overflow = 'hidden';
    document.getElementById('lb-close')?.focus();
  }

  function closeLightbox() {
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    document.body.style.overflow = '';
    thumbs[current]?.focus();
  }

  function navigate(dir: 1 | -1) {
    current = (current + dir + thumbs.length) % thumbs.length;
    lbImg.src = thumbs[current].dataset.src!;
    lbImg.alt = thumbs[current].dataset.alt!;
  }

  thumbs.forEach((btn, i) => btn.addEventListener('click', () => openLightbox(i)));
  document.getElementById('lb-close')!.addEventListener('click', closeLightbox);
  document.getElementById('lb-prev')!.addEventListener('click', () => navigate(-1));
  document.getElementById('lb-next')!.addEventListener('click', () => navigate(1));
  lb.addEventListener('click', (e) => { if (e.target === lb) closeLightbox(); });

  document.addEventListener('keydown', (e) => {
    if (lb.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') navigate(-1);
    if (e.key === 'ArrowRight') navigate(1);
  });
</script>
