---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroGallery from '../../components/HeroGallery.astro';
import { totalImages } from '../../data/graphicDesign';
---

<BaseLayout
  title="Graphic Design — Ben LaClair"
  description="A curated selection of brand, editorial, and visual design work spanning esports, ESPN-affiliated tournaments, and brand systems."
>
  <div class="gd-header">
    <div class="wrap">
      <a href="/work" data-cursor="back" class="gd-back">← All work</a>
      <h1 class="gd-h1 text-display-xl">
        <span class="line"><span>Brand &amp; <span class="accent">editorial.</span></span></span>
      </h1>
      <p class="gd-desc">
        {totalImages} pieces across esports, ESPN-affiliated tournaments, and brand work —
        stream overlays, event posters, email campaigns, logos, and wayfinding systems.
      </p>
    </div>
  </div>

  <div class="gd-gallery">
    <HeroGallery fullPage />
  </div>
</BaseLayout>

<style>
  .gd-header {
    padding: 140px 0 80px;
  }
  .gd-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-2);
    margin-bottom: 40px;
  }
  .gd-h1 {
    margin-bottom: 32px;
  }
  .gd-desc {
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-ink-2);
    max-width: 600px;
  }
  /* Gallery viewport — full-page browse rhythm; height grows with content,
     HeroGallery's columns scroll independently inside their fixed-height
     parent. Use a tall container so the looping ticker has room to breathe. */
  .gd-gallery {
    position: relative;
    height: 200vh;
    margin-bottom: 80px;
    overflow: hidden;
  }
  @media (max-width: 900px) {
    .gd-header { padding: 100px 0 60px; }
    .gd-gallery { height: 150vh; }
  }
</style>

<script>
  import { revealLines } from '../../lib/motion';
  revealLines('.gd-h1 .line span');
</script>
