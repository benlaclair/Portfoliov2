---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PROJECTS } from '../../data/projects';

export function getStaticPaths() {
  return PROJECTS.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;

const currentIdx = PROJECTS.findIndex((p) => p.slug === project.slug);
const nextProject = PROJECTS[(currentIdx + 1) % PROJECTS.length];

let stats: { value: string; label: string }[] = [];
let process: { step: string; title: string; description: string }[] = [];
let decisions: { number: string; label: string; title: string; description: string; before?: string; after?: string }[] = [];
let outcomes: { label: string; value: string }[] = [];
let extraSections: Record<string, unknown> = {};

if (project.slug === 'vlier') {
  const d = await import('../../data/vlierCaseStudyData');
  stats = d.vlierStats;
  decisions = d.vlierDecisions;
  outcomes = d.vlierOutcomes;
  extraSections = { problems: d.vlierProblems, personas: d.vlierPersonas };
} else if (project.slug === 'veo-olympics') {
  const d = await import('../../data/veoCaseStudyData');
  stats = d.veoStats;
  process = d.veoProcess;
  outcomes = d.veoOutcomes;
  extraSections = { scenes: d.veoScenes, challenges: d.veoChallenges };
} else if (project.slug === 'portfolio') {
  const d = await import('../../data/caseStudyData');
  stats = d.portfolioStats;
  decisions = d.portfolioDecisions;
}

const isVeo = project.slug === 'veo-olympics';
const isVlier = project.slug === 'vlier';
const isGraphicDesign = project.slug === 'graphic-design';

const mono = "font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase";
const displayStyle = "font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; letter-spacing: -0.03em; line-height: 1.0";
---

<BaseLayout
  title={`${project.shortTitle} — Ben LaClair`}
  description={project.description}
  pageType="article"
>
  <!-- Back -->
  <div class="px-5 md:px-12 lg:px-20 pt-20" style="max-width: 1360px; margin-inline: auto">
    <a
      href="/work"
      class="inline-flex items-center gap-2 text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)] transition-colors duration-200"
    >← All work</a>
  </div>

  <!-- Hero -->
  <header class="px-5 md:px-12 lg:px-20 pt-12 pb-16 md:pb-20" style="max-width: 1360px; margin-inline: auto" id="cs-hero">
    <p
      class="text-[var(--color-muted)] mb-6 cs-el"
      style={mono}
    >{project.category} &middot; {project.year}</p>
    <h1
      class="text-[var(--color-ink)] max-w-5xl cs-el"
      style={`${displayStyle}; font-size: clamp(2.25rem, 6vw, 5.5rem); line-height: 1.0`}
    >{project.title}</h1>
    <p class="text-lg text-[var(--color-muted)] max-w-2xl mt-8 leading-relaxed cs-el">
      {project.description}
    </p>
  </header>

  <!-- Cover image -->
  {project.coverImage && (
    <div class="px-5 md:px-12 lg:px-20 mb-16 md:mb-24" style="max-width: 1360px; margin-inline: auto">
      <div class="overflow-hidden aspect-[16/9] bg-[var(--color-surface)]">
        <img
          src={project.coverImage}
          alt={project.shortTitle}
          width="1360"
          height="765"
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  )}

  <!-- VEO: Video -->
  {isVeo && project.videoUrl && (
    <div class="px-5 md:px-12 lg:px-20 mb-16 md:mb-24" style="max-width: 1360px; margin-inline: auto">
      <p class="text-[var(--color-muted)] mb-5" style={mono}>The spot</p>
      <div class="overflow-hidden aspect-video bg-[var(--color-ink)]">
        <video
          src={project.videoUrl}
          controls
          poster={project.coverImage}
          class="w-full h-full object-cover"
          preload="metadata"
        >
          Your browser doesn’t support HTML5 video.
        </video>
      </div>
      <p class="text-xs text-[var(--color-muted)] mt-4" style="font-family: 'Geist Mono', monospace; font-size: 0.65rem">
        15-second AI-generated broadcast spot. Aired on traditional TV and CTV during Winter Olympics coverage.
      </p>
    </div>
  )}

  <!-- Stats -->
  {stats.length > 0 && (
    <div class="px-5 md:px-12 lg:px-20 mb-16 md:mb-24" style="max-width: 1360px; margin-inline: auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-[var(--color-line)]">
        {stats.map((stat) => (
          <div class="bg-[var(--color-bg)] px-8 py-10 stat-item">
            <p
              class="text-[var(--color-ink)] mb-2"
              style={`${displayStyle}; font-size: clamp(2rem, 4vw, 3.5rem)`}
            >{stat.value}</p>
            <p class="text-[var(--color-muted)]" style={mono}>{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Metadata + Overview -->
  <div class="px-5 md:px-12 lg:px-20 mb-16 md:mb-24 border-y border-[var(--color-line)] py-12" style="max-width: 1360px; margin-inline: auto">
    <div class="grid md:grid-cols-[200px_1fr] gap-12 md:gap-16">
      <!-- Sidebar -->
      <aside class="flex flex-col gap-7">
        <div>
          <p class="text-[var(--color-muted)] mb-2" style={mono}>Role</p>
          <p class="text-sm text-[var(--color-ink)]">{project.role}</p>
        </div>
        {project.client && (
          <div>
            <p class="text-[var(--color-muted)] mb-2" style={mono}>Client</p>
            <p class="text-sm text-[var(--color-ink)]">{project.client}</p>
          </div>
        )}
        <div>
          <p class="text-[var(--color-muted)] mb-2" style={mono}>Year</p>
          <p class="text-sm text-[var(--color-ink)]">{project.year}</p>
        </div>
        <div>
          <p class="text-[var(--color-muted)] mb-2" style={mono}>Tools</p>
          <ul class="flex flex-col gap-1.5">
            {project.tools.map((t) => (
              <li class="text-sm text-[var(--color-ink)]">{t}</li>
            ))}
          </ul>
        </div>
      </aside>

      <!-- Overview -->
      <div>
        <p class="text-[var(--color-muted)] mb-5" style={mono}>Overview</p>
        <p class="text-base md:text-lg leading-relaxed mb-8" style="color: var(--color-ink-2)">{project.overview}</p>
        {project.problem && (
          <>
            <p class="text-[var(--color-muted)] mb-5" style={mono}>The challenge</p>
            <p class="text-base text-[var(--color-muted)] leading-relaxed">{project.problem}</p>
          </>
        )}
      </div>
    </div>
  </div>

  <!-- VEO: Scenes -->
  {isVeo && extraSections.scenes && (
    <div class="px-5 md:px-12 lg:px-20 mb-16 md:mb-24" style="max-width: 1360px; margin-inline: auto">
      <p class="text-[var(--color-muted)] mb-10" style={mono}>Scene breakdown</p>
      <div class="grid md:grid-cols-2 gap-px bg-[var(--color-line)]">
        {(extraSections.scenes as {number:string;title:string;description:string}[]).map((scene) => (
          <div class="bg-[var(--color-bg)] p-8">
            <p class="text-[var(--color-muted)] mb-3" style="font-family: 'Geist Mono', monospace; font-size: 0.65rem">Scene {scene.number}</p>
            <h3
              class="text-[var(--color-ink)] mb-3"
              style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.15rem; letter-spacing: -0.02em"
            >{scene.title}</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">{scene.description}</p>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Vlier: Personas -->
  {isVlier && extraSections.personas && (
    <div class="px-5 md:px-12 lg:px-20 mb-16 md:mb-24" style="max-width: 1360px; margin-inline: auto">
      <p class="text-[var(--color-muted)] mb-10" style={mono}>Two users, one page</p>
      <div class="grid md:grid-cols-2 gap-px bg-[var(--color-line)]">
        {(extraSections.personas as {role:string;description:string}[]).map((persona) => (
          <div class="bg-[var(--color-bg)] p-8">
            <h3
              class="text-[var(--color-ink)] mb-3"
              style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.15rem; letter-spacing: -0.02em"
            >{persona.role}</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">{persona.description}</p>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Key decisions -->
  {decisions.length > 0 && (
    <div class="px-5 md:px-12 lg:px-20 mb-16 md:mb-24" style="max-width: 1360px; margin-inline: auto">
      <p class="text-[var(--color-muted)] mb-10" style={mono}>Key decisions</p>
      <div class="divide-y divide-[var(--color-line)]">
        {decisions.map((d) => (
          <div class="py-10">
            <div class="grid md:grid-cols-[160px_1fr] gap-6 md:gap-12">
              <div>
                <p class="text-[var(--color-muted)] mb-1" style="font-family: 'Geist Mono', monospace; font-size: 0.7rem">{d.number}</p>
                <p class="text-[var(--color-muted)]" style={mono}>{d.label}</p>
              </div>
              <div>
                <h3
                  class="text-[var(--color-ink)] mb-3"
                  style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(1.15rem, 2vw, 1.5rem); letter-spacing: -0.02em; line-height: 1.2"
                >{d.title}</h3>
                <p class="text-sm text-[var(--color-muted)] leading-relaxed mb-6">{d.description}</p>
                {d.before && d.after && (
                  <div class="grid md:grid-cols-2 gap-px bg-[var(--color-line)]">
                    <div class="bg-[var(--color-bg)] border-t-2 border-red-400 px-6 py-5">
                      <p class="mb-2" style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; color: #ef4444">Before</p>
                      <p class="text-sm leading-relaxed" style="color: var(--color-ink-2)">{d.before}</p>
                    </div>
                    <div class="bg-[var(--color-bg)] border-t-2 border-emerald-500 px-6 py-5">
                      <p class="mb-2" style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; color: #10b981">After</p>
                      <p class="text-sm leading-relaxed" style="color: var(--color-ink-2)">{d.after}</p>
                    </div>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Process -->
  {process.length > 0 && (
    <div class="px-5 md:px-12 lg:px-20 mb-16 md:mb-24" style="max-width: 1360px; margin-inline: auto">
      <p class="text-[var(--color-muted)] mb-10" style={mono}>Process</p>
      <div class="divide-y divide-[var(--color-line)]">
        {process.map((step) => (
          <div class="grid md:grid-cols-[160px_1fr] gap-6 md:gap-12 py-8">
            <p class="text-[var(--color-muted)]" style="font-family: 'Geist Mono', monospace; font-size: 0.7rem">{step.step}</p>
            <div>
              <h3
                class="text-[var(--color-ink)] mb-2"
                style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.1rem; letter-spacing: -0.02em"
              >{step.title}</h3>
              <p class="text-sm text-[var(--color-muted)] leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- VEO: Challenges -->
  {isVeo && extraSections.challenges && (
    <div class="px-5 md:px-12 lg:px-20 mb-16 md:mb-24" style="max-width: 1360px; margin-inline: auto">
      <p class="text-[var(--color-muted)] mb-10" style={mono}>Constraints &amp; solutions</p>
      <div class="divide-y divide-[var(--color-line)]">
        {(extraSections.challenges as {number:string;title:string;body:string}[]).map((c) => (
          <div class="grid md:grid-cols-[160px_1fr] gap-6 md:gap-12 py-8">
            <p class="text-[var(--color-muted)]" style="font-family: 'Geist Mono', monospace; font-size: 0.7rem">{c.number}</p>
            <div>
              <h3
                class="text-[var(--color-ink)] mb-2"
                style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.1rem; letter-spacing: -0.02em"
              >{c.title}</h3>
              <p class="text-sm text-[var(--color-muted)] leading-relaxed">{c.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Outcomes -->
  {outcomes.length > 0 && (
    <div class="px-5 md:px-12 lg:px-20 mb-16 md:mb-24" style="max-width: 1360px; margin-inline: auto">
      <p class="text-[var(--color-muted)] mb-10" style={mono}>Outcomes</p>
      <div class="grid md:grid-cols-3 gap-px bg-[var(--color-line)]">
        {outcomes.map((o) => (
          <div class="bg-[var(--color-bg)] px-8 py-8">
            <p class="text-[var(--color-muted)] mb-3" style={mono}>{o.label}</p>
            <p
              class="text-[var(--color-ink)] leading-snug"
              style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 1.05rem; letter-spacing: -0.01em"
            >{o.value}</p>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Graphic design: Gallery link -->
  {isGraphicDesign && (
    <div class="px-5 md:px-12 lg:px-20 mb-16 md:mb-24" style="max-width: 1360px; margin-inline: auto">
      <p class="text-[var(--color-muted)] mb-6" style={mono}>Selected pieces</p>
      <a
        href="/work/graphic-design"
        class="text-sm text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors duration-200"
      >Explore the full gallery →</a>
    </div>
  )}

  <!-- Next project -->
  <div class="px-5 md:px-12 lg:px-20 py-16 md:py-24 border-t border-[var(--color-line)]" style="max-width: 1360px; margin-inline: auto">
    <p class="text-[var(--color-muted)] mb-8" style={mono}>Next project</p>
    <a href={`/work/${nextProject.slug}`} class="group block">
      <h2
        class="text-[var(--color-ink)] group-hover:text-[var(--color-accent)] transition-colors duration-300"
        style={`${displayStyle}; font-size: clamp(2.5rem, 7vw, 7rem)`}
      >
        {nextProject.shortTitle}&nbsp;→
      </h2>
      <p class="text-sm text-[var(--color-muted)] mt-4 max-w-xl leading-relaxed">{nextProject.description}</p>
    </a>
  </div>

</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.cs-el', {
    opacity: 0,
    y: 20,
    duration: 0.65,
    stagger: 0.1,
    ease: 'power3.out',
    delay: 0.05,
  });

  gsap.utils.toArray<HTMLElement>('.stat-item').forEach((el) => {
    gsap.from(el, {
      opacity: 0,
      y: 16,
      duration: 0.5,
      ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 90%', once: true },
    });
  });
</script>
