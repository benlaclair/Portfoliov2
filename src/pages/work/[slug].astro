---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PROJECTS } from '../../data/projects';

export function getStaticPaths() {
  return PROJECTS.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;

const currentIdx = PROJECTS.findIndex((p) => p.slug === project.slug);
const nextProject = PROJECTS[(currentIdx + 1) % PROJECTS.length];

// Load per-project case study data
let stats: { value: string; label: string }[] = [];
let process: { step: string; title: string; description: string }[] = [];
let decisions: { number: string; label: string; title: string; description: string; before?: string; after?: string }[] = [];
let outcomes: { label: string; value: string }[] = [];
let extraSections: Record<string, unknown> = {};

if (project.slug === 'vlier') {
  const d = await import('../../data/vlierCaseStudyData');
  stats = d.vlierStats;
  decisions = d.vlierDecisions;
  outcomes = d.vlierOutcomes;
  extraSections = { problems: d.vlierProblems, personas: d.vlierPersonas };
} else if (project.slug === 'veo-olympics') {
  const d = await import('../../data/veoCaseStudyData');
  stats = d.veoStats;
  process = d.veoProcess;
  outcomes = d.veoOutcomes;
  extraSections = { scenes: d.veoScenes, challenges: d.veoChallenges };
} else if (project.slug === 'portfolio') {
  const d = await import('../../data/caseStudyData');
  stats = d.portfolioStats;
  decisions = d.portfolioDecisions;
}

const isVeo = project.slug === 'veo-olympics';
const isVlier = project.slug === 'vlier';
const isGraphicDesign = project.slug === 'graphic-design';
---

<BaseLayout
  title={`${project.shortTitle} — Ben LaClair`}
  description={project.description}
  pageType="article"
>
  <!-- Back -->
  <div class="px-6 md:px-12 pt-8">
    <div class="max-w-[1200px] mx-auto">
      <a
        href="/work"
        class="inline-flex items-center gap-2 text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)] transition-colors"
      >
        <span>&larr;</span> All work
      </a>
    </div>
  </div>

  <!-- Hero -->
  <header class="px-6 md:px-12 pt-10 pb-16 md:pb-24" id="cs-hero">
    <div class="max-w-[1200px] mx-auto">
      <p class="eyebrow mb-5 cs-el">{project.category} &middot; {project.year}</p>
      <h1 class="font-serif text-4xl md:text-6xl text-[var(--color-ink)] max-w-4xl text-pretty cs-el">
        {project.title}
      </h1>
      <p class="text-lg text-[var(--color-muted)] max-w-2xl mt-6 leading-relaxed cs-el">
        {project.description}
      </p>

      {project.client && (
        <p class="text-sm text-[var(--color-muted-soft)] mt-4 cs-el">
          Client: <span class="text-[var(--color-ink)]">{project.client}</span>
        </p>
      )}
    </div>
  </header>

  <!-- Cover image -->
  {project.coverImage && (
    <div class="px-6 md:px-12 mb-16 md:mb-24">
      <div class="max-w-[1200px] mx-auto">
        <div class="rounded-2xl overflow-hidden aspect-[16/9] bg-[var(--color-line-soft)]">
          <img
            src={project.coverImage}
            alt={project.shortTitle}
            width="1200"
            height="675"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  )}

  <!-- VEO: Video embed -->
  {isVeo && project.videoUrl && (
    <div class="px-6 md:px-12 mb-16 md:mb-24">
      <div class="max-w-[1200px] mx-auto">
        <p class="eyebrow mb-4">The spot</p>
        <div class="rounded-2xl overflow-hidden aspect-video bg-[var(--color-accent)]">
          <video
            src={project.videoUrl}
            controls
            poster={project.coverImage}
            class="w-full h-full object-cover"
            preload="metadata"
          >
            Your browser doesn't support HTML5 video.
          </video>
        </div>
        <p class="text-xs text-[var(--color-muted)] mt-3">
          15-second AI-generated broadcast spot. Aired on traditional TV and CTV during Winter Olympics coverage.
        </p>
      </div>
    </div>
  )}

  <!-- Stats row -->
  {stats.length > 0 && (
    <div class="px-6 md:px-12 mb-16 md:mb-24">
      <div class="max-w-[1200px] mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-[var(--color-line)] rounded-2xl overflow-hidden">
          {stats.map((stat) => (
            <div class="bg-white px-8 py-8 stat-item">
              <p class="font-serif text-3xl md:text-4xl text-[var(--color-ink)] mb-1">{stat.value}</p>
              <p class="eyebrow">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- Metadata + Overview -->
  <div class="px-6 md:px-12 mb-16 md:mb-24">
    <div class="max-w-[1200px] mx-auto grid md:grid-cols-3 gap-12">
      <!-- Sidebar -->
      <aside class="flex flex-col gap-6">
        <div>
          <p class="eyebrow mb-2">Role</p>
          <p class="text-sm text-[var(--color-ink)]">{project.role}</p>
        </div>
        {project.client && (
          <div>
            <p class="eyebrow mb-2">Client</p>
            <p class="text-sm text-[var(--color-ink)]">{project.client}</p>
          </div>
        )}
        <div>
          <p class="eyebrow mb-2">Year</p>
          <p class="text-sm text-[var(--color-ink)]">{project.year}</p>
        </div>
        <div>
          <p class="eyebrow mb-2">Tools</p>
          <div class="flex flex-wrap gap-1.5">
            {project.tools.map((t) => (
              <span class="text-xs font-medium border border-[var(--color-line)] rounded-full px-3 py-1 text-[var(--color-ink)]">{t}</span>
            ))}
          </div>
        </div>
      </aside>

      <!-- Overview -->
      <div class="md:col-span-2">
        <p class="eyebrow mb-4">Overview</p>
        <p class="text-base md:text-lg text-[var(--color-ink-soft)] leading-relaxed">{project.overview}</p>
        {project.problem && (
          <>
            <p class="eyebrow mt-8 mb-4">The challenge</p>
            <p class="text-base text-[var(--color-muted)] leading-relaxed">{project.problem}</p>
          </>
        )}
      </div>
    </div>
  </div>

  <!-- VEO: Scene breakdown -->
  {isVeo && extraSections.scenes && (
    <div class="px-6 md:px-12 mb-16 md:mb-24">
      <div class="max-w-[1200px] mx-auto">
        <p class="eyebrow mb-8">Scene breakdown</p>
        <div class="grid md:grid-cols-2 gap-6">
          {(extraSections.scenes as {number:string;title:string;description:string}[]).map((scene) => (
            <div class="border border-[var(--color-line)] rounded-2xl p-7 bg-white">
              <p class="font-mono text-xs text-[var(--color-muted-soft)] mb-3">Scene {scene.number}</p>
              <h3 class="font-serif text-xl text-[var(--color-ink)] mb-3">{scene.title}</h3>
              <p class="text-sm text-[var(--color-muted)] leading-relaxed">{scene.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- Vlier: Personas -->
  {isVlier && extraSections.personas && (
    <div class="px-6 md:px-12 mb-16 md:mb-24">
      <div class="max-w-[1200px] mx-auto">
        <p class="eyebrow mb-8">Two users, one page</p>
        <div class="grid md:grid-cols-2 gap-6">
          {(extraSections.personas as {role:string;description:string}[]).map((persona) => (
            <div class="border border-[var(--color-line)] rounded-2xl p-7 bg-white">
              <h3 class="font-serif text-xl text-[var(--color-ink)] mb-3">{persona.role}</h3>
              <p class="text-sm text-[var(--color-muted)] leading-relaxed">{persona.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- Decisions / Key choices -->
  {decisions.length > 0 && (
    <div class="px-6 md:px-12 mb-16 md:mb-24">
      <div class="max-w-[1200px] mx-auto">
        <p class="eyebrow mb-8">Key decisions</p>
        <div class="flex flex-col gap-6">
          {decisions.map((d) => (
            <div class="border border-[var(--color-line)] rounded-2xl p-7 md:p-9 bg-white">
              <div class="flex flex-col md:flex-row md:items-start gap-6">
                <div class="shrink-0">
                  <p class="font-mono text-xs text-[var(--color-muted-soft)] mb-1">{d.number}</p>
                  <p class="eyebrow">{d.label}</p>
                </div>
                <div class="flex-1">
                  <h3 class="font-serif text-xl md:text-2xl text-[var(--color-ink)] mb-3">{d.title}</h3>
                  <p class="text-sm text-[var(--color-muted)] leading-relaxed mb-5">{d.description}</p>
                  {d.before && d.after && (
                    <div class="grid md:grid-cols-2 gap-4">
                      <div class="rounded-xl bg-red-50 border border-red-100 px-5 py-4">
                        <p class="text-xs font-mono text-red-400 mb-2">Before</p>
                        <p class="text-sm text-red-700">{d.before}</p>
                      </div>
                      <div class="rounded-xl bg-emerald-50 border border-emerald-100 px-5 py-4">
                        <p class="text-xs font-mono text-emerald-600 mb-2">After</p>
                        <p class="text-sm text-emerald-800">{d.after}</p>
                      </div>
                    </div>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- Process steps -->
  {process.length > 0 && (
    <div class="px-6 md:px-12 mb-16 md:mb-24">
      <div class="max-w-[1200px] mx-auto">
        <p class="eyebrow mb-8">Process</p>
        <div class="flex flex-col">
          {process.map((step, i) => (
            <div class="flex gap-8 pb-10 relative">
              {i < process.length - 1 && (
                <div class="absolute left-5 top-8 bottom-0 w-px bg-[var(--color-line)]" />
              )}
              <div class="shrink-0 w-10 h-10 rounded-full border border-[var(--color-line)] bg-white flex items-center justify-center z-10">
                <span class="font-mono text-xs text-[var(--color-muted)]">{step.step}</span>
              </div>
              <div class="pt-2">
                <h3 class="font-serif text-lg text-[var(--color-ink)] mb-2">{step.title}</h3>
                <p class="text-sm text-[var(--color-muted)] leading-relaxed">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- VEO: Challenges -->
  {isVeo && extraSections.challenges && (
    <div class="px-6 md:px-12 mb-16 md:mb-24">
      <div class="max-w-[1200px] mx-auto">
        <p class="eyebrow mb-8">Constraints & solutions</p>
        <div class="flex flex-col gap-4">
          {(extraSections.challenges as {number:string;title:string;body:string}[]).map((c) => (
            <div class="flex gap-6 border border-[var(--color-line)] rounded-2xl p-6 bg-white">
              <p class="font-mono text-xs text-[var(--color-muted-soft)] shrink-0 pt-0.5">{c.number}</p>
              <div>
                <h3 class="font-serif text-lg text-[var(--color-ink)] mb-2">{c.title}</h3>
                <p class="text-sm text-[var(--color-muted)] leading-relaxed">{c.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- Outcomes -->
  {outcomes.length > 0 && (
    <div class="px-6 md:px-12 mb-16 md:mb-24">
      <div class="max-w-[1200px] mx-auto">
        <p class="eyebrow mb-8">Outcomes</p>
        <div class="grid md:grid-cols-3 gap-6">
          {outcomes.map((o) => (
            <div class="border border-[var(--color-line)] rounded-2xl p-6 bg-white">
              <p class="eyebrow mb-3">{o.label}</p>
              <p class="font-serif text-lg text-[var(--color-ink)] leading-snug">{o.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- Graphic design: Gallery link -->
  {isGraphicDesign && (
    <div class="px-6 md:px-12 mb-16 md:mb-24">
      <div class="max-w-[1200px] mx-auto">
        <p class="eyebrow mb-6">Selected pieces</p>
        <a href="/work/graphic-design" class="group inline-flex items-center gap-2 border border-[var(--color-line)] rounded-full px-6 py-3 text-sm font-medium text-[var(--color-ink)] hover:border-[var(--color-pop)] hover:text-[var(--color-pop)] transition-colors">
          Explore the full gallery &rarr;
        </a>
      </div>
    </div>
  )}

  <!-- Next project -->
  <div class="px-6 md:px-12 py-16 md:py-24 border-t border-[var(--color-line)]">
    <div class="max-w-[1200px] mx-auto">
      <p class="eyebrow mb-4">Next project</p>
      <a href={`/work/${nextProject.slug}`} class="group block">
        <h2 class="font-serif text-3xl md:text-5xl text-[var(--color-ink)] group-hover:text-[var(--color-pop)] transition-colors">
          {nextProject.title} &rarr;
        </h2>
        <p class="text-sm text-[var(--color-muted)] mt-3">{nextProject.description}</p>
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.cs-el', {
    opacity: 0,
    y: 16,
    duration: 0.6,
    stagger: 0.1,
    ease: 'power3.out',
    delay: 0.05,
  });

  gsap.utils.toArray<HTMLElement>('.stat-item, .border.rounded-2xl').forEach((el) => {
    gsap.from(el, {
      opacity: 0,
      y: 12,
      duration: 0.5,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 88%',
        once: true,
      },
    });
  });
</script>
