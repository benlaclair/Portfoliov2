---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PROJECTS } from '../../data/projects';
import { getCaseStudy } from '../../data/caseStudies';
import MetaOverview from '../../components/case-study/MetaOverview.astro';
import Section from '../../components/case-study/Section.astro';

export function getStaticPaths() {
  return PROJECTS
    .filter((p) => p.slug !== 'graphic-design')
    .map((p) => ({
      params: { slug: p.slug },
      props: { project: p },
    }));
}

const { project } = Astro.props;

const currentIdx = PROJECTS.findIndex((p) => p.slug === project.slug);
const nextProject = PROJECTS[(currentIdx + 1) % PROJECTS.length];

const caseStudy = getCaseStudy(project.slug);
const preSections = caseStudy?.pre ?? [];
const postSections = caseStudy?.post ?? [];
---

<BaseLayout
  title={`${project.shortTitle} — Ben LaClair`}
  description={project.description}
  pageType="article"
>
  <!-- Back -->
  <div style="padding: 100px 40px 0; max-width: 1440px; margin-inline: auto">
    <a
      href="/work"
      style="display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-2)"
    >← All work</a>
  </div>

  <!-- Hero -->
  <header style="padding: 60px 40px 100px; max-width: 1440px; margin-inline: auto">
    <div class="cs-meta text-eyebrow-accent" style="letter-spacing: 0.14em; margin-bottom: 32px">{project.category} &middot; {project.year}</div>
    <h1
      class="cs-title"
      style="font-family: var(--font-display); font-weight: 500; font-size: clamp(48px, 8vw, 128px); letter-spacing: -0.04em; line-height: 0.96; max-width: 1100px; margin-bottom: 32px"
    >
      <span class="line"><span>{project.title}</span></span>
    </h1>
    <p
      class="cs-desc"
      style="font-size: clamp(18px, 2.2vw, 28px); line-height: 1.4; color: var(--color-ink-2); max-width: 800px; letter-spacing: -0.01em"
    >
      {project.description}
    </p>
  </header>

  <!-- Cover image -->
  {project.coverImage && project.coverWidth && project.coverHeight && (
    <div style="padding: 0 40px 100px; max-width: 1440px; margin-inline: auto">
      <div
        class="cs-cover"
        style="aspect-ratio: 16/9; overflow: hidden; background: var(--color-paper); position: relative; clip-path: inset(0 100% 0 0)"
      >
        <Image
          src={project.coverImage}
          alt={project.shortTitle}
          width={project.coverWidth}
          height={project.coverHeight}
          widths={[800, 1440, 2160]}
          sizes="(max-width: 1440px) 100vw, 1440px"
          format="webp"
          style="width: 100%; height: 100%; object-fit: cover"
        />
      </div>
    </div>
  )}

  <!-- Sections rendered before the meta + overview block (typically video, stats) -->
  {preSections.map((section) => <Section section={section} project={project} />)}

  <!-- Metadata + Overview -->
  <MetaOverview project={project} />

  <!-- Sections rendered after the meta + overview block -->
  {postSections.map((section) => <Section section={section} project={project} />)}

  <!-- Next project -->
  <div style="padding: 80px 40px 120px; max-width: 1440px; margin-inline: auto; border-top: 1px solid var(--color-line)">
    <div class="text-eyebrow" style="letter-spacing: 0.14em; margin-bottom: 24px">— Next project</div>
    <a
      href={`/work/${nextProject.slug}`}
      class="cs-next"
      style="display: block"
    >
      <h2
        style="font-family: var(--font-display); font-weight: 500; font-size: clamp(40px, 6vw, 88px); letter-spacing: -0.04em; line-height: 1; color: var(--color-ink); transition: color 0.4s ease"
      >{nextProject.title} <span style="color: var(--color-accent)">→</span></h2>
      <p style="font-size: 15px; line-height: 1.6; color: var(--color-ink-2); margin-top: 16px; max-width: 600px">{nextProject.description}</p>
    </a>
  </div>
</BaseLayout>

<style is:global>
  /* Mobile collapse for the meta+overview grid (the rest is now owned by
     case-study/Grid.astro and case-study/RowList.astro). */
  @media (max-width: 900px) {
    .cs-meta-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
  }
  .cs-next:hover h2 { color: var(--color-accent); }
</style>

<script>
  import { gsap, ease, reduceMotion } from '../../lib/motion';

  if (!reduceMotion.current) {
    // Hero entrance
    gsap.set('.cs-title .line span', { y: '110%' });
    gsap.timeline({ delay: 0.1 })
      .from('.cs-meta', { y: 20, opacity: 0, duration: 0.5, ease: ease.out })
      .to('.cs-title .line span', { y: '0%', duration: 1.1, ease: ease.expo }, '-=0.3')
      .from('.cs-desc', { y: 20, opacity: 0, duration: 0.6, ease: ease.out }, '-=0.5');

    // Cover clip-path entrance
    const cover = document.querySelector<HTMLElement>('.cs-cover');
    if (cover) {
      gsap.to(cover, {
        clipPath: 'inset(0 0 0 0)',
        duration: 1.2,
        ease: ease.expo,
        delay: 0.4,
      });
    }

    // cs-stat / cs-decision / cs-process / cs-challenge reveals are
    // handled by the [data-reveal] IntersectionObserver in BaseLayout.
  } else {
    // Reduced-motion fallback: cover starts with clip-path: inset(0 100% 0 0);
    // open it immediately so the image is visible.
    const cover = document.querySelector<HTMLElement>('.cs-cover');
    if (cover) cover.style.clipPath = 'inset(0 0 0 0)';
  }
</script>
