---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TOOLS } from '../data/tools';
---

<BaseLayout
  title="Tools — Ben LaClair"
  description="AI-powered tools built to solve real problems in design, content, and workflow."
>
  <div class="px-5 md:px-12 lg:px-20 pt-28 pb-28" style="max-width: 1360px; margin-inline: auto">

    <!-- Header -->
    <div class="border-b border-[var(--color-line)] pb-16 mb-16">
      <p
        class="text-[var(--color-muted)] mb-10"
        style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase"
      >Built things &middot; 2025–2026</p>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <h1
          class="text-[var(--color-ink)]"
          style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(3.25rem, 9vw, 9.5rem); letter-spacing: -0.03em; line-height: 0.95"
        >Tools</h1>
        <p class="text-sm text-[var(--color-muted)] max-w-xs leading-relaxed md:mb-2">
          Production tools built to solve real problems in design, content, and workflow.
        </p>
      </div>
    </div>

    <!-- Tool list -->
    <div class="divide-y divide-[var(--color-line)]">
      {TOOLS.map((tool, i) => (
        <article class="tool-detail py-12 md:py-14" data-index={i}>
          <div class="grid md:grid-cols-[120px_1fr] gap-8 md:gap-14">

            <!-- Number + status -->
            <div>
              <p
                class="text-[var(--color-muted)] mb-3"
                style="font-family: 'Geist Mono', monospace; font-size: 0.7rem"
              >{tool.number}</p>
              <p
                class="text-[var(--color-muted)]"
                style={`font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; color: ${tool.accentColor}`}
              >{tool.status === 'live' ? 'Live' : tool.status === 'beta' ? 'Beta' : 'Soon'}</p>
            </div>

            <!-- Content -->
            <div>
              <h2
                class="text-[var(--color-ink)] mb-3"
                style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(1.5rem, 3vw, 2.5rem); letter-spacing: -0.025em; line-height: 1.1"
              >{tool.name}</h2>

              <p class="text-base text-[var(--color-muted)] leading-relaxed mb-6 max-w-2xl">{tool.tagline}</p>

              <!-- Problem quote -->
              <div
                class="border-l-2 pl-5 mb-8"
                style={`border-color: ${tool.accentColor}`}
              >
                <p class="text-sm text-[var(--color-muted)] leading-relaxed italic">&ldquo;{tool.problem}&rdquo;</p>
              </div>

              <!-- Tech + link -->
              <div class="flex flex-wrap items-center gap-6">
                {tool.url && (
                  <a
                    href={tool.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors duration-200"
                  >Open tool ↗</a>
                )}
                <div class="flex flex-wrap gap-x-4 gap-y-1">
                  {tool.tech.map((t) => (
                    <span
                      class="text-[var(--color-muted)]"
                      style="font-family: 'Geist Mono', monospace; font-size: 0.65rem"
                    >{t}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>('.tool-detail').forEach((el) => {
    gsap.from(el, {
      opacity: 0,
      y: 24,
      duration: 0.65,
      ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 92%', once: true },
    });
  });
</script>
