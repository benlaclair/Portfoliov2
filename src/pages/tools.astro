---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TOOLS } from '../data/tools';
---

<BaseLayout title="Tools — Ben LaClair" description="AI-powered tools built to solve real problems in design, content, and workflow.">
  <div class="px-6 md:px-12 pt-16 pb-24">
    <div class="max-w-[1200px] mx-auto">

      <div class="mb-16">
        <p class="eyebrow mb-5">Built things · 2025–2026</p>
        <h1 class="font-serif text-5xl md:text-6xl text-[var(--color-ink)] mb-5">Tools</h1>
        <p class="text-base text-[var(--color-muted)] max-w-md leading-relaxed">
          Production tools I built to solve real problems in design, content, and workflow.
          Each one started as a pain point — and ended as something I actually use.
        </p>
      </div>

      <div class="flex flex-col gap-6">
        {TOOLS.map((tool, i) => (
          <article class="tool-detail border border-[var(--color-line)] rounded-2xl p-8 md:p-10 bg-white" data-index={i}>
            <div class="flex flex-col md:flex-row md:items-start gap-8">
              <!-- Left: Number + accent bar -->
              <div class="shrink-0">
                <div class="w-1 h-16 rounded-full mb-3" style={`background: ${tool.accentColor}`} />
                <p class="font-mono text-xs text-[var(--color-muted-soft)]">{tool.number}</p>
              </div>

              <!-- Content -->
              <div class="flex-1">
                <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
                  <h2 class="font-serif text-2xl md:text-3xl text-[var(--color-ink)]">{tool.name}</h2>
                  <span class="text-xs font-medium px-3 py-1.5 rounded-full border"
                    style={`color: ${tool.accentColor}; border-color: ${tool.accentColor}40; background: ${tool.accentColor}10`}>
                    {tool.status === 'live' ? 'Live' : tool.status === 'beta' ? 'Beta' : 'Coming soon'}
                  </span>
                </div>

                <p class="text-base text-[var(--color-muted)] leading-relaxed mb-4 max-w-2xl">{tool.tagline}</p>

                <div class="border-l-2 pl-5 mb-6" style={`border-color: ${tool.accentColor}60`}>
                  <p class="text-sm text-[var(--color-muted)] leading-relaxed italic">"{tool.problem}"</p>
                </div>

                <div class="flex flex-wrap items-center gap-4">
                  {tool.url && (
                    <a
                      href={tool.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="bg-[var(--color-ink)] text-[var(--color-bg)] text-sm font-medium px-5 py-2.5 rounded-full hover:bg-[var(--color-pop)] transition-colors"
                    >
                      Open tool ↗
                    </a>
                  )}
                  <div class="flex flex-wrap gap-1.5">
                    {tool.tech.map((t) => (
                      <span class="text-xs font-mono border border-[var(--color-line)] rounded-full px-2.5 py-1 text-[var(--color-muted)]">{t}</span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>('.tool-detail').forEach((el) => {
    const i = parseInt(el.dataset.index ?? '0', 10);
    gsap.from(el, {
      opacity: 0,
      y: 16,
      duration: 0.55,
      delay: i * 0.06,
      ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 90%', once: true },
    });
  });
</script>
