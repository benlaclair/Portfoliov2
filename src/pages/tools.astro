---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TOOLS } from '../data/tools';
---

<BaseLayout
  title="Tools — Ben LaClair"
  description="AI-powered tools built to solve real problems in design, content, and workflow."
>
  <div style="padding: 140px 40px 80px; max-width: 1440px; margin-inline: auto">

    <div style="border-bottom: 1px solid var(--color-line); padding-bottom: 60px; margin-bottom: 0">
      <div
        style="font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-ink-2); margin-bottom: 40px"
      >— Built things &middot; 2025–2026</div>
      <div
        class="tools-head"
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end"
      >
        <h1
          class="tools-h1"
          style="font-family: 'Inter Tight Variable', 'Inter Tight', sans-serif; font-weight: 500; font-size: clamp(72px, 13vw, 200px); letter-spacing: -0.045em; line-height: 0.92"
        >
          <span class="line"><span><em>Tools</em> I built.</span></span>
        </h1>
        <p style="font-size: 16px; line-height: 1.6; color: var(--color-ink-2); max-width: 460px; padding-bottom: 16px">
          Production tools built to solve real problems in design, content, and workflow. Each one started as a pain point.
        </p>
      </div>
    </div>

    {TOOLS.map((tool, i) => {
      const num = String(i + 1).padStart(2, '0');
      return (
        <article
          class="tool-row"
          data-tool
          style="display: grid; grid-template-columns: 80px 1fr 1fr 40px; gap: 60px; padding: 60px 0; border-top: 1px solid var(--color-line); align-items: start"
        >
          <div
            style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.12em; color: var(--color-ink-2); padding-top: 8px"
          >/{num}</div>

          <div style="padding-top: 4px">
            <div
              style={`font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; color: ${tool.accentColor}; text-transform: uppercase; margin-bottom: 16px`}
            >{tool.status === 'live' ? 'Live' : tool.status === 'beta' ? 'Beta' : 'Coming soon'} &middot; {tool.year}</div>
            <h3
              style="font-family: 'Inter Tight Variable', 'Inter Tight', sans-serif; font-weight: 500; font-size: clamp(36px, 4.4vw, 64px); line-height: 1.0; letter-spacing: -0.03em; margin-bottom: 24px"
            >
              {tool.name}
            </h3>
            <p style="font-size: 16px; line-height: 1.6; color: var(--color-ink-2); max-width: 540px; margin-bottom: 24px">
              {tool.tagline}
            </p>
            <div
              style={`border-left: 2px solid ${tool.accentColor}80; padding-left: 20px; margin-bottom: 28px`}
            >
              <p style="font-size: 14px; line-height: 1.55; color: var(--color-ink-2); font-style: italic">
                “{tool.problem}”
              </p>
            </div>
            <div style="display: flex; flex-wrap: wrap; gap: 16px; align-items: center">
              {tool.url && (
                <a
                  href={tool.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-cursor="Open"
                  data-magnetic="0.3"
                  style="display: inline-flex; align-items: center; gap: 12px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink); border-bottom: 1px solid var(--color-ink); padding-bottom: 4px"
                >Open tool ↗</a>
              )}
              <div style="display: flex; flex-wrap: wrap; gap: 6px">
                {tool.tech.map((t) => (
                  <span
                    style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.06em; padding: 4px 10px; border: 1px solid var(--color-line); color: var(--color-muted)"
                  >{t}</span>
                ))}
              </div>
            </div>
          </div>

          <div
            style={`aspect-ratio: 4/3; background: linear-gradient(135deg, ${tool.accentColor}25, ${tool.accentColor}08); position: relative; overflow: hidden; display: grid; place-items: center`}
          >
            <span
              style={`color: ${tool.accentColor}; font-family: 'Instrument Serif', serif; font-style: italic; font-size: clamp(48px, 6vw, 96px); letter-spacing: -0.04em; opacity: 0.6; text-align: center; padding: 20px`}
            >
              {tool.name.split(' ')[0]}
            </span>
          </div>

          <span
            style="align-self: center; font-size: 18px; color: var(--color-ink-2)"
          >→</span>
        </article>
      );
    })}

  </div>
</BaseLayout>

<style>
  @media (max-width: 900px) {
    .tools-head { grid-template-columns: 1fr !important; gap: 24px !important; }
    .tool-row { grid-template-columns: 60px 1fr !important; gap: 24px !important; }
    .tool-row > :nth-child(3), .tool-row > :nth-child(4) {
      grid-column: 1 / -1; margin-top: 16px;
    }
    .tool-row > :nth-child(4) { display: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.set('.tools-h1 .line span', { y: '110%' });
  gsap.to('.tools-h1 .line span', { y: '0%', duration: 1.1, ease: 'expo.out', delay: 0.1 });

  document.querySelectorAll<HTMLElement>('[data-tool]').forEach((el) => {
    gsap.from(el, {
      y: 40,
      opacity: 0,
      duration: 0.9,
      ease: 'expo.out',
      scrollTrigger: { trigger: el, start: 'top 85%' },
    });
  });
</script>
