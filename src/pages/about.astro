---
import BaseLayout from '../layouts/BaseLayout.astro';

const experience = [
  {
    role: 'Graphic / AI Designer',
    org: 'Market Mentors LLC — Springfield, MA',
    period: '2026 — Present',
    type: 'work',
    bullets: [
      'Utilizing evolving Generative AI platforms for graphic, video, and web development purposes',
      'Spearheading UX/UI redesigns for new and existing clients',
      'Meeting social, print, and digital needs for 40+ clients',
      'Creating design systems and atomic design standards for client branding',
    ],
  },
  {
    role: 'UX/UI Analyst, CMS Web Dev & Graphic Design Intern',
    org: 'Metropolitan YMCA of New Jersey — Maplewood, NJ',
    period: '2024 — 2025',
    type: 'work',
    bullets: [
      'Analyzed user flow and experience on 4+ childcare and event sites',
      'Created infographics, logos, and t-shirt designs that increased social engagement',
      'Led creation of 2 new CMS-centered websites',
    ],
  },
  {
    role: 'Multimedia Designer & WordPress Developer',
    org: 'The Gazelle Group — Princeton, NJ',
    period: '2023 — 2024',
    type: 'work',
    bullets: [
      'Designed branded assets for 5+ ESPN-affiliated tournaments',
      'Created 150+ real-time social posts driving 10,000+ interactions',
      'Built reusable Adobe components and led updates on 11 WordPress sites',
      'Ran A/B testing on CTAs, improving click-through rates by 10%',
    ],
  },
  {
    role: 'Graphic Design Intern',
    org: 'Sweet Sign Systems — Jackson, NJ',
    period: '2020 — 2023',
    type: 'work',
    bullets: [
      'Designed install guides for 30+ signage projects, reducing field errors',
      'Standardized layout templates to improve consistency across 30+ designs',
    ],
  },
  {
    role: 'UX/UI Design Certificate',
    org: 'Skillcrush Academy — Remote',
    period: '2024 — 2025',
    type: 'education',
    bullets: [],
  },
  {
    role: 'B.A. Design & Interactive Media',
    org: 'Seton Hall University — South Orange, NJ',
    period: '2018 — 2022',
    type: 'education',
    bullets: [],
  },
];

const skills = [
  'Figma', 'Photoshop', 'Illustrator', 'InDesign',
  'UX Research', 'Wireframing', 'Prototyping', 'A/B Testing', 'Accessibility (WCAG)',
  'HTML / CSS', 'React', 'Astro', 'GSAP',
  'Google Flow', 'Gemini API', 'Claude',
];
---

<BaseLayout
  title="About — Ben LaClair"
  description="5+ years of UX/UI and graphic design. Currently at Market Mentors LLC."
>
  <div class="px-5 md:px-12 lg:px-20 pt-28 pb-28" style="max-width: 1360px; margin-inline: auto">

    <!-- Page header -->
    <div class="border-b border-[var(--color-line)] pb-16 mb-16">
      <p
        class="text-[var(--color-muted)] mb-10"
        style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase"
      >About</p>
      <h1
        class="text-[var(--color-ink)]"
        style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(3.25rem, 9vw, 9.5rem); letter-spacing: -0.03em; line-height: 0.95"
      >Hey, I'm Ben.</h1>
    </div>

    <!-- Bio + Skills -->
    <div class="grid md:grid-cols-[1fr_320px] gap-16 md:gap-24 mb-24">
      <div>
        <div class="flex items-center gap-2 mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span>
          <span class="text-sm text-emerald-700">Open to new opportunities</span>
        </div>
        <p class="text-lg leading-relaxed mb-5" style="color: var(--color-ink-2, #2C2C2A)">
          I'm a UX/UI and Graphic Designer with
          <strong class="text-[var(--color-ink)] font-semibold">5+ years of experience</strong>
          in user-centered design, research-based problem solving, and web content management.
        </p>
        <p class="text-lg leading-relaxed mb-5" style="color: var(--color-ink-2, #2C2C2A)">
          I've designed for <strong class="text-[var(--color-ink)] font-semibold">ESPN-affiliated tournaments</strong>,
          redesigned program sites for the
          <strong class="text-[var(--color-ink)] font-semibold">Metropolitan YMCA of NJ</strong>, and currently
          lead graphic and AI design work at
          <strong class="text-[var(--color-ink)] font-semibold">Market Mentors LLC</strong> serving 40+ clients.
        </p>
        <p class="text-lg leading-relaxed mb-10" style="color: var(--color-ink-2, #2C2C2A)">
          I actively integrate <strong class="text-[var(--color-ink)] font-semibold">Generative AI</strong>
          into my workflow — treating it as an opportunity to push design further, faster.
        </p>
        <div class="flex flex-wrap gap-6">
          <a
            href="/contact"
            class="text-sm text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors duration-200"
          >Work with me →</a>
          <a
            href="/resume.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)] transition-colors duration-200"
          >View résumé ↗</a>
        </div>
      </div>

      <!-- Skills list -->
      <div>
        <p
          class="text-[var(--color-muted)] mb-5"
          style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase"
        >Tools &amp; Skills</p>
        <ul class="divide-y divide-[var(--color-line)]">
          {skills.map((s) => (
            <li class="py-2.5 text-sm text-[var(--color-ink)]">{s}</li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Timeline -->
    <div class="border-t border-[var(--color-line)] pt-16">
      <p
        class="text-[var(--color-muted)] mb-12"
        style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase"
      >Experience &amp; Education</p>

      <div class="divide-y divide-[var(--color-line)]">
        {experience.map((item) => (
          <div class="grid md:grid-cols-[180px_1fr] gap-4 md:gap-12 py-9">
            <div>
              <p
                class="text-[var(--color-muted)] mb-1"
                style="font-family: 'Geist Mono', monospace; font-size: 0.65rem"
              >{item.period}</p>
              <p
                style={`font-family: 'Geist Mono', monospace; font-size: 0.65rem; color: ${item.type === 'work' ? 'var(--color-accent)' : 'var(--color-muted)'}`}
              >{item.type === 'work' ? 'Work' : 'Education'}</p>
            </div>
            <div>
              <p class="font-semibold text-[var(--color-ink)] mb-0.5 text-base">{item.role}</p>
              <p class="text-sm text-[var(--color-muted)] mb-3">{item.org}</p>
              {item.bullets.length > 0 && (
                <ul class="flex flex-col gap-2 mt-3">
                  {item.bullets.map((b) => (
                    <li class="text-sm text-[var(--color-muted)] flex gap-2.5">
                      <span class="shrink-0">—</span>
                      <span>{b}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</BaseLayout>
