---
import BaseLayout from '../layouts/BaseLayout.astro';

const experience = [
  {
    role: 'Graphic / AI Designer',
    org: 'Market Mentors LLC — Springfield, MA',
    period: '2026 — Present',
    type: 'work',
    bullets: [
      'Utilizing evolving Generative AI platforms for graphic, video, and web development purposes',
      'Spearheading UX/UI redesigns for new and existing clients',
      'Meeting social, print, and digital needs for 40+ clients',
      'Creating design systems and atomic design standards for client branding',
    ],
  },
  {
    role: 'UX/UI Analyst, CMS Web Dev & Graphic Design Intern',
    org: 'Metropolitan YMCA of New Jersey — Maplewood, NJ',
    period: '2024 — 2025',
    type: 'work',
    bullets: [
      'Analyzed user flow and experience on 4+ childcare and event sites',
      'Created infographics, logos, and t-shirt designs that increased social engagement',
      'Led creation of 2 new CMS-centered websites',
    ],
  },
  {
    role: 'Multimedia Designer & WordPress Developer',
    org: 'The Gazelle Group — Princeton, NJ',
    period: '2023 — 2024',
    type: 'work',
    bullets: [
      'Designed branded assets for 5+ ESPN-affiliated tournaments',
      'Created 150+ real-time social posts driving 10,000+ interactions',
      'Built reusable Adobe components and led updates on 11 WordPress sites',
      'Ran A/B testing on CTAs, improving click-through rates by 10%',
    ],
  },
  {
    role: 'Graphic Design Intern',
    org: 'Sweet Sign Systems — Jackson, NJ',
    period: '2020 — 2023',
    type: 'work',
    bullets: [
      'Designed install guides for 30+ signage projects, reducing field errors',
      'Standardized layout templates to improve consistency across 30+ designs',
    ],
  },
  {
    role: 'UX/UI Design Certificate',
    org: 'Skillcrush Academy — Remote',
    period: '2024 — 2025',
    type: 'education',
    bullets: [],
  },
  {
    role: 'B.A. Design & Interactive Media',
    org: 'Seton Hall University — South Orange, NJ',
    period: '2018 — 2022',
    type: 'education',
    bullets: [],
  },
];

const skills = [
  'Figma', 'Photoshop', 'Illustrator', 'InDesign',
  'UX Research', 'Wireframing', 'Prototyping', 'A/B Testing', 'Accessibility (WCAG)',
  'HTML / CSS', 'React', 'Astro', 'GSAP',
  'Google Flow', 'Gemini API', 'Claude',
];

const stats = [
  { value: 5, suffix: '+', label: 'Years' },
  { value: 86, suffix: '', label: 'Designs' },
  { value: 40, suffix: '+', label: 'Clients' },
  { value: 11, suffix: '', label: 'Sites shipped' },
];
---

<BaseLayout title="About — Ben LaClair" description="5+ years of UX/UI and graphic design. Currently at Market Mentors LLC.">
  <div class="about-page" style="padding: 140px 40px 80px; max-width: 1440px; margin-inline: auto">

    <!-- Header -->
    <div style="border-bottom: 1px solid var(--color-line); padding-bottom: 80px; margin-bottom: 80px">
      <div class="section-num" style="margin-bottom: 40px">— About</div>
      <h1 class="about-h1 text-display-xl">
        <span class="line"><span>Hey, I'm <span class="accent">Ben.</span></span></span>
      </h1>
    </div>

    <!-- Stats row -->
    <div
      class="stats-row"
      style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--color-line); margin-bottom: 100px"
    >
      {stats.map((s) => (
        <div
          class="stat"
          data-stat
          data-target={s.value}
          data-suffix={s.suffix}
          style="background: var(--color-bg); padding: 40px 32px"
        >
          <div
            class="stat-num"
            style="font-family: var(--font-display); font-weight: 500; font-size: clamp(48px, 6vw, 88px); letter-spacing: -0.04em; line-height: 1"
          >0</div>
          <div class="text-eyebrow" style="margin-top: 12px">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Bio + Skills -->
    <div style="display: grid; grid-template-columns: 1fr 320px; gap: 80px; margin-bottom: 120px" class="bio-grid">
      <div>
        <p style="font-size: 20px; line-height: 1.55; color: var(--color-ink-2); margin-bottom: 28px; max-width: 640px">
          I'm a UX/UI and Graphic Designer with <strong style="color: var(--color-ink); font-weight: 600">5+ years of experience</strong> in user-centered design,
          research-based problem solving, and web content management.
        </p>
        <p style="font-size: 20px; line-height: 1.55; color: var(--color-ink-2); margin-bottom: 28px; max-width: 640px">
          I've designed for <strong style="color: var(--color-ink); font-weight: 600">ESPN-affiliated tournaments</strong>,
          redesigned program sites for the
          <strong style="color: var(--color-ink); font-weight: 600">Metropolitan YMCA of NJ</strong>, and currently lead
          graphic and AI design work at
          <strong style="color: var(--color-ink); font-weight: 600">Market Mentors LLC</strong> serving 40+ clients.
        </p>
        <p style="font-size: 20px; line-height: 1.55; color: var(--color-ink-2); margin-bottom: 40px; max-width: 640px">
          I actively integrate <span class="accent">Generative AI</span> into my workflow — treating it as an opportunity
          to push design further, faster.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 28px">
          <a href="/contact" data-magnetic="0.3" style="font-size: 14px; color: var(--color-ink); border-bottom: 1px solid var(--color-ink); padding-bottom: 2px">
            Work with me →
          </a>
          <a href="/resume.pdf" target="_blank" rel="noopener noreferrer" style="font-size: 14px; color: var(--color-ink-2); border-bottom: 1px solid var(--color-line); padding-bottom: 2px">
            View résumé ↗
          </a>
        </div>
      </div>

      <div>
        <div class="section-num" style="margin-bottom: 24px">Tools &amp; Skills</div>
        <ul style="list-style: none; padding: 0; margin: 0">
          {skills.map((s) => (
            <li
              style="padding: 12px 0; border-bottom: 1px solid var(--color-line); font-size: 14px; color: var(--color-ink)"
            >{s}</li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Timeline -->
    <div style="border-top: 1px solid var(--color-line); padding-top: 80px">
      <div class="section-num" style="margin-bottom: 60px">— Experience &amp; Education</div>

      <div>
        {experience.map((item) => (
          <div style="display: grid; grid-template-columns: 200px 1fr; gap: 60px; padding: 36px 0; border-bottom: 1px solid var(--color-line)" class="exp-row" data-reveal>
            <div>
              <div style="font-family: var(--font-mono); font-size: 12px; color: var(--color-ink-2); margin-bottom: 4px">{item.period}</div>
              <div style={`font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: ${item.type === 'work' ? 'var(--color-accent)' : 'var(--color-muted)'}`}>{item.type === 'work' ? 'Work' : 'Education'}</div>
            </div>
            <div>
              <div style="font-size: 18px; font-weight: 500; color: var(--color-ink); margin-bottom: 4px">{item.role}</div>
              <div style="font-size: 14px; color: var(--color-muted); margin-bottom: 16px">{item.org}</div>
              {item.bullets.length > 0 && (
                <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px">
                  {item.bullets.map((b) => (
                    <li style="font-size: 14px; color: var(--color-ink-2); display: flex; gap: 12px">
                      <span style="color: var(--color-muted)">—</span><span>{b}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  @media (max-width: 900px) {
    .stats-row { grid-template-columns: repeat(2, 1fr) !important; }
    .bio-grid { grid-template-columns: 1fr !important; gap: 48px !important; }
    .exp-row { grid-template-columns: 1fr !important; gap: 16px !important; }
  }
</style>

<script>
  import { gsap, ease, reduceMotion, revealLines } from '../lib/motion';

  revealLines('.about-h1 .line span');

  // exp-row reveals handled by [data-reveal] IntersectionObserver in BaseLayout.

  // Stat number tick-up on scroll-into-view. Under reduced motion we still
  // surface the final value (no animated count), so the numbers aren't stuck
  // at 0.
  document.querySelectorAll<HTMLElement>('[data-stat]').forEach((el) => {
    const target = parseInt(el.dataset.target || '0', 10);
    const suffix = el.dataset.suffix || '';
    const num = el.querySelector<HTMLElement>('.stat-num');
    if (!num) return;
    if (reduceMotion.current) {
      num.textContent = target.toString() + suffix;
      return;
    }
    const obj = { v: 0 };
    gsap.to(obj, {
      v: target,
      duration: 1.6,
      ease: ease.power2,
      onUpdate: () => {
        num.textContent = Math.floor(obj.v).toString() + suffix;
      },
      scrollTrigger: { trigger: el, start: 'top 85%', once: true },
    });
  });
</script>
