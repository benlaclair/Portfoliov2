---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.tsx';
---

<BaseLayout
  title="Contact — Ben LaClair"
  description="Get in touch to discuss a project or collaboration."
>
  <div class="px-5 md:px-12 lg:px-20 pt-28 pb-28" style="max-width: 1360px; margin-inline: auto">

    <!-- Header -->
    <div class="border-b border-[var(--color-line)] pb-16 mb-16">
      <p
        class="text-[var(--color-muted)] mb-10"
        style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase"
      >Say hello</p>
      <h1
        class="text-[var(--color-ink)]"
        style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(3.25rem, 9vw, 9.5rem); letter-spacing: -0.03em; line-height: 0.95"
      >Let's talk.</h1>
    </div>

    <div class="grid md:grid-cols-[1fr_300px] gap-16 md:gap-24">

      <!-- Form -->
      <div>
        <p class="text-base text-[var(--color-muted)] leading-relaxed mb-10 max-w-md">
          Have a project in mind, want to collaborate, or just want to say hi?
          My inbox is open.
        </p>
        <ContactForm client:load />
      </div>

      <!-- Direct links -->
      <div class="md:pt-4">
        <p
          class="text-[var(--color-muted)] mb-6"
          style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase"
        >Or find me here</p>
        <div class="flex flex-col gap-4">
          <a
            href="https://www.linkedin.com/in/benlaclair"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors duration-200"
          >LinkedIn ↗</a>
          <a
            href="mailto:hello@benlaclair.com"
            class="text-sm text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors duration-200"
          >hello@benlaclair.com ↗</a>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>
