---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact — Ben LaClair"
  description="Get in touch to discuss a project or collaboration."
>
  <div style="padding: 140px 40px 80px; max-width: 880px; margin-inline: auto">

    <div style="margin-bottom: 80px">
      <div class="section-num" style="margin-bottom: 40px">— 05 / Reach out</div>
      <h1 class="contact-h1 text-display-xl" style="margin-bottom: 32px">
        <span class="line"><span>Have something</span></span>
        <span class="line"><span><span class="accent">worth making?</span></span></span>
      </h1>
      <p style="font-size: 18px; line-height: 1.55; color: var(--color-ink-2); max-width: 540px">
        Project, collaboration, or just hello — inbox is open. Replies usually within a day.
      </p>
    </div>

    <div style="margin-bottom: 80px">
      <ContactForm />
    </div>

    <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 32px">
      <div style="height: 1px; flex: 1; background: var(--color-line)"></div>
      <span class="section-num">Or find me here</span>
      <div style="height: 1px; flex: 1; background: var(--color-line)"></div>
    </div>

    <div style="display: flex; flex-wrap: wrap; gap: 32px; align-items: center">
      <a
        href="mailto:hello@benlaclair.com"
        data-magnetic="0.4"
        class="contact-link"
        style="display: inline-flex; align-items: center; gap: 16px; font-size: 20px; font-weight: 500; padding: 16px 0; border-bottom: 1px solid var(--color-ink); color: var(--color-ink)"
      >
        hello@benlaclair.com
        <span class="contact-arrow" style="width: 40px; height: 40px; border-radius: 50%; background: var(--color-ink); color: var(--color-paper); display: grid; place-items: center; transition: transform 0.6s cubic-bezier(.7,0,.2,1), background 0.4s ease">→</span>
      </a>
      <a
        href="https://www.linkedin.com/in/benlaclair"
        target="_blank"
        rel="noopener noreferrer"
        data-magnetic="0.3"
        style="font-size: 16px; color: var(--color-ink-2); border-bottom: 1px solid var(--color-line); padding-bottom: 2px"
      >LinkedIn ↗</a>
    </div>

  </div>
</BaseLayout>

<style>
  .contact-link:hover .contact-arrow { transform: rotate(-45deg); background: var(--color-accent); }
</style>

<script>
  import { revealLines } from '../lib/motion';
  revealLines('.contact-h1 .line span', { stagger: 0.08 });
</script>
