---
import BaseLayout from '../layouts/BaseLayout.astro';
import HorizontalWork from '../components/HorizontalWork.astro';
import HeroGallery from '../components/HeroGallery.astro';
---

<BaseLayout initialMode="dark">

  <!-- ============ LOADER (dark) ============ -->
  <div class="loader" id="loader">
    <div class="loader-top">
      <span>Index — 2026</span>
      <span id="loader-pct">000</span>
    </div>
    <div class="loader-mid">
      <div class="loader-svg">
        <svg
          class="loader-b"
          viewBox="0 0 96 96"
          aria-hidden="true"
          style="stroke: var(--color-dark-ink); fill: none; stroke-linecap: round; stroke-linejoin: round;"
        >
          <path class="loader-path" d="M20 68V22h24c10 0 16 5 16 12.5 0 4.8-2.5 8.3-6.8 10.2C59 46.4 63 50.7 63 57c0 8-6.4 11-17.2 11H20Z" stroke-width="3"/>
          <path class="loader-path" d="M32 41h10c3.5 0 5.4-1.5 5.4-4.2 0-2.6-2-4-5.6-4H32v8.2Z" stroke-width="3"/>
          <path class="loader-path" d="M32 58h12.5c3.8 0 5.8-1.7 5.8-4.7 0-2.8-2.1-4.5-6.1-4.5H32V58Z" stroke-width="3"/>
          <circle cx="70" cy="25" r="7" fill="var(--color-accent)" stroke="none"/>
        </svg>
      </div>
    </div>
    <div class="loader-foot">
      <div class="loader-bar"><i id="loader-bar-fill"></i></div>
      <div class="loader-bot">
        <span>Loading portfolio</span>
        <span>Astro &middot; GSAP</span>
      </div>
    </div>
  </div>

  <!-- ============ HERO — 3-screen scroll sequence ============ -->
  <!-- 300vh runway; ScrollTrigger pins .hero-stage so each panel fills the viewport -->
  <div class="hero-runway" id="hero-runway" data-section-mode="dark">
    <div class="hero-stage" id="hero-stage">

      <!-- Hidden SVG noise filter shared by all glow layers -->
      <svg width="0" height="0" aria-hidden="true" style="position:absolute">
        <defs>
          <filter id="hero-noise">
            <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" result="noise"/>
            <feColorMatrix type="saturate" values="0" in="noise" result="grey"/>
            <feBlend in="SourceGraphic" in2="grey" mode="overlay" result="blend"/>
            <feComposite in="blend" in2="SourceGraphic" operator="in"/>
          </filter>
        </defs>
      </svg>

      <!-- Screen 1: Logo only -->
      <div class="hero-panel" id="hero-s1" data-screen="1" aria-hidden="true">
        <div class="hero-glow" aria-hidden="true"></div>
        <div class="hero-s1-logo">
          <svg viewBox="0 0 96 96" aria-label="Ben LaClair" role="img" style="fill:none;stroke:var(--color-dark-ink);stroke-linecap:round;stroke-linejoin:round;">
            <path d="M20 68V22h24c10 0 16 5 16 12.5 0 4.8-2.5 8.3-6.8 10.2C59 46.4 63 50.7 63 57c0 8-6.4 11-17.2 11H20Z" stroke-width="2.5"/>
            <path d="M32 41h10c3.5 0 5.4-1.5 5.4-4.2 0-2.6-2-4-5.6-4H32v8.2Z" stroke-width="2.5"/>
            <path d="M32 58h12.5c3.8 0 5.8-1.7 5.8-4.7 0-2.8-2.1-4.5-6.1-4.5H32V58Z" stroke-width="2.5"/>
            <circle cx="70" cy="25" r="7" fill="var(--color-accent)" stroke="none"/>
          </svg>
        </div>
        <div class="hero-scroll-indicator" aria-hidden="true">
          <span class="hero-scroll-dot"></span>
          <span class="hero-scroll-line"></span>
        </div>
      </div>

      <!-- Screen 2: Hi, I'm Ben. -->
      <div class="hero-panel" id="hero-s2" data-screen="2">
        <div class="hero-glow" aria-hidden="true"></div>
        <div class="hero-s2-content">
          <p class="hero-s2-eyebrow">UX/UI &amp; Graphic Designer</p>
          <h1 class="hero-s2-name">
            <span class="word"><span>Hi,</span></span>
            <span class="word"><span>I'm</span></span>
            <span class="word"><span>Ben.</span></span>
          </h1>
        </div>
        <div class="hero-scroll-indicator" aria-hidden="true">
          <span class="hero-scroll-dot"></span>
          <span class="hero-scroll-line"></span>
        </div>
      </div>

      <!-- Screen 3: Tagline + gallery + CTA -->
      <div class="hero-panel is-dark" id="hero-s3" data-screen="3" data-section-mode="dark">
        <div class="hero-gallery" id="hero-gallery">
          <HeroGallery />
          <div class="hero-gallery-scrim" aria-hidden="true"></div>
        </div>
        <div class="hero-phrase" id="hero-phrase">
          <h2 class="hero-phrase-text" id="hero-phrase-text">
            <span class="word"><span>Type</span></span> <span class="word"><span>that</span></span> <span class="word"><span>reads.</span></span>
            <br/>
            <span class="word"><span>Motion</span></span> <span class="word"><span>that</span></span> <span class="word"><span>means</span></span> <span class="word"><span>something.</span></span>
          </h2>
        </div>
        <a href="/work/graphic-design" class="hero-cta" id="hero-cta" data-magnetic="0.3">
          <span>View design work</span>
          <span class="hero-cta-arrow">→</span>
        </a>
      </div>

    </div><!-- /.hero-stage -->
  </div><!-- /.hero-runway -->

  <div class="hero-curtain" id="hero-curtain" aria-hidden="true"></div>

  <!-- ============ TAGLINE (light) ============ -->
  <section class="tagline atmo-warmth-tl">
    <p class="tagline-text" id="tagline-text">
      UX/UI designer and graphic designer. <span class="accent">Making complicated things feel obvious.</span>
    </p>
  </section>

  <!-- ============ VISUAL BREAK (dark parallax strip) ============ -->
  <section class="vbreak is-dark" data-section-mode="dark" aria-hidden="true">
    <div class="vbreak-bg" id="vbreak-bg"></div>
  </section>

  <!-- ============ SELECTED WORK (horizontal pinned, light) ============ -->
  <HorizontalWork />

  <!-- ============ TIMELINE (light) ============ -->
  <section class="timeline" id="timeline">
    <div class="timeline-stage" id="timeline-stage">
      <div class="timeline-pin" id="timeline-pin">
        <div class="timeline-top">
          <span id="timeline-progress">01 / 05</span>
        </div>
        <div class="timeline-mid">
          <div class="timeline-num" id="timeline-num">2018</div>
        </div>
        <div>
          <div class="timeline-cap">
            <div class="label" data-reveal>Marker</div>
            <div class="text" id="timeline-text" data-reveal>First freelance esports overlay. Discord DMs, forty bucks, learning Photoshop the hard way.</div>
            <div class="right" id="timeline-tag" data-reveal>Self-taught</div>
          </div>
          <div class="timeline-bar"><i id="timeline-fill"></i></div>
          <div class="timeline-ticks" id="timeline-ticks">
            <span class="active">2018</span><span>2019</span><span>2021</span><span>2024</span><span>2026</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PROCESS (light) ============ -->
  <section class="process atmo-warmth-br">
    <div class="wrap">
      <div class="process-header">
        <p class="text-eyebrow-accent" data-reveal>Process</p>
        <h2 class="process-title" data-process-title>
          <span class="process-word"><span>Fewer</span></span>
          <span class="process-word"><span>surprises,</span></span>
          <span class="process-word"><span>better</span></span>
          <span class="process-word"><span>work.</span></span>
        </h2>
        <p class="process-sub" data-reveal>
          Four phases. Every project, every time — so you always know what's happening and why.
        </p>
      </div>
      <div class="process-grid-wrap">
        <div class="process-connector" aria-hidden="true"><span class="process-connector-line"></span></div>
        <div class="process-grid">
          <div class="process-step" data-process-card>
            <span class="process-num">01</span>
            <h3 class="process-step-title">Absorb</h3>
            <p class="process-step-body">Stakeholder interviews, user research, competitive audit. Learning enough to design with conviction — not just familiarity.</p>
            <button class="process-expand-hint" aria-expanded="false">Deliverables <span aria-hidden="true">+</span></button>
            <div class="process-deliverables" aria-hidden="true">
              <ul>
                <li>Research synthesis doc</li>
                <li>Stakeholder interview notes</li>
                <li>Competitive audit</li>
                <li>Defined success metrics</li>
              </ul>
            </div>
          </div>
          <div class="process-step" data-process-card>
            <span class="process-num">02</span>
            <h3 class="process-step-title">Reduce</h3>
            <p class="process-step-body">Distilling the problem to its sharpest possible version. Architecture, flows, and design principles before a single pixel moves.</p>
            <button class="process-expand-hint" aria-expanded="false">Deliverables <span aria-hidden="true">+</span></button>
            <div class="process-deliverables" aria-hidden="true">
              <ul>
                <li>Problem statement</li>
                <li>Information architecture</li>
                <li>User flows</li>
                <li>Design principles</li>
              </ul>
            </div>
          </div>
          <div class="process-step" data-process-card>
            <span class="process-num">03</span>
            <h3 class="process-step-title">Make</h3>
            <p class="process-step-body">Screens, systems, motion. Every detail earns its place. No placeholder copy, no "we'll fix it in dev."</p>
            <button class="process-expand-hint" aria-expanded="false">Deliverables <span aria-hidden="true">+</span></button>
            <div class="process-deliverables" aria-hidden="true">
              <ul>
                <li>Wireframes + prototypes</li>
                <li>High-fidelity screens</li>
                <li>Design system / component library</li>
                <li>Motion spec</li>
              </ul>
            </div>
          </div>
          <div class="process-step" data-process-card>
            <span class="process-num">04</span>
            <h3 class="process-step-title">Align</h3>
            <p class="process-step-body">Specs and the reasoning behind them. Still available through build — because a handoff document doesn't answer Slack messages.</p>
            <button class="process-expand-hint" aria-expanded="false">Deliverables <span aria-hidden="true">+</span></button>
            <div class="process-deliverables" aria-hidden="true">
              <ul>
                <li>Annotated Figma handoff</li>
                <li>Component documentation</li>
                <li>QA review</li>
                <li>Post-launch check-in</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA (dark + radial halos) ============ -->
  <section class="cta is-dark has-halos" id="cta" data-section-mode="dark">
    <h2 class="cta-title" id="cta-title">
      <span class="line"><span>Have something</span></span>
      <span class="line"><span><span class="accent">worth making?</span></span></span>
    </h2>
    <div class="cta-row">
      <a href="mailto:hello@benlaclair.com" data-magnetic="0.4" class="cta-link">
        hello@benlaclair.com
        <span class="cta-arrow">→</span>
      </a>
      <p class="cta-side" data-reveal>Replies usually within a day. The shorter your brief, the faster I can be useful — three sentences is plenty.</p>
    </div>
  </section>

</BaseLayout>

<style is:global>
  /* loader — dark bg */
  .loader { position: fixed; inset: 0; background: var(--color-dark-bg); z-index: 10000; display: flex; flex-direction: column; justify-content: space-between; padding: 40px; }
  .loader-top, .loader-bot { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-dark-ink-2); }
  .loader-mid { flex: 1; display: grid; place-items: center; }
  .loader-svg { display: grid; place-items: center; }
  .loader-b { width: clamp(80px, 14vw, 160px); height: clamp(80px, 14vw, 160px); }
  .loader-path { stroke-dasharray: 240; stroke-dashoffset: 240; }
  .loader-foot { display: flex; flex-direction: column; gap: 20px; }
  .loader-bar { height: 1px; background: rgba(244, 239, 228, 0.15); position: relative; overflow: hidden; }
  .loader-bar i { position: absolute; left: 0; top: 0; bottom: 0; width: 0%; background: var(--color-dark-ink); }

  /* ── Hero 3-screen scroll ── */
  .hero-runway {
    height: 300vh;
    background: var(--color-dark-bg);
  }
  .hero-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
  }
  /* Each panel fills the stage, stacked absolutely */
  .hero-panel {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-dark-bg);
  }
  /* Central radial glow — the main aesthetic element from the reference */
  .hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(55% 65% at 50% 52%, rgba(91, 108, 171, 0.28) 0%, transparent 70%),
      radial-gradient(35% 45% at 50% 52%, rgba(91, 108, 171, 0.18) 0%, transparent 60%);
    filter: blur(2px);
  }

  /* Screen 1 — logo */
  .hero-s1-logo {
    position: relative;
    z-index: 2;
    width: clamp(80px, 14vw, 180px);
    opacity: 0;
  }

  /* Screen 2 — "Hi, I'm Ben." */
  .hero-s2-content {
    position: relative;
    z-index: 2;
    text-align: center;
  }
  .hero-s2-eyebrow {
    font-family: var(--font-mono);
    font-size: clamp(10px, 1vw, 13px);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-dark-muted);
    margin-bottom: clamp(20px, 3vw, 36px);
    opacity: 0;
  }
  .hero-s2-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(56px, 10vw, 160px);
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--color-dark-ink);
  }
  /* Words clip for reveal */
  .hero-s2-name .word {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
    margin-right: 0.18em;
  }
  .hero-s2-name .word > span {
    display: inline-block;
    transform: translateY(110%);
    opacity: 0;
  }

  /* Screen 3 — gallery + tagline */
  .hero-gallery {
    position: absolute;
    inset: 6vh 5vw;
    z-index: 1;
    opacity: 0;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(244, 239, 228, 0.10);
    box-shadow: 0 0 100px rgba(0, 0, 0, 0.5);
  }
  .hero-gallery-scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }
  .hero-gallery-scrim::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 50% at 50% 60%, rgba(13, 12, 10, 0) 0%, rgba(13, 12, 10, 0.45) 100%),
      linear-gradient(180deg, rgba(13, 12, 10, 0.3) 0%, rgba(13, 12, 10, 0.4) 50%, rgba(13, 12, 10, 0.65) 100%);
  }
  .hero-gallery-scrim::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(91, 108, 171, 0.38);
    mix-blend-mode: color;
  }
  .hero-phrase {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 40px;
    pointer-events: none;
  }
  .hero-phrase-text {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(40px, 8vw, 140px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    text-align: center;
    color: var(--color-dark-ink);
    max-width: 1200px;
  }
  .hero-cta {
    position: absolute;
    left: 50%;
    bottom: 64px;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 16px 26px;
    background: var(--color-accent);
    color: var(--color-dark-ink);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 999px;
    text-decoration: none;
    z-index: 4;
    opacity: 0;
    transition: background 0.3s ease;
  }
  .hero-cta:hover { background: var(--color-accent-hover); }
  .hero-cta-arrow {
    display: inline-block;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hero-cta:hover .hero-cta-arrow { transform: translateX(4px); }
  .hero-s3 .hero-cta { color: var(--color-dark-ink); }

  /* Scroll indicator — dot + extending line */
  .hero-scroll-indicator {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    opacity: 0;
  }
  .hero-scroll-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-dark-ink-2);
  }
  .hero-scroll-line {
    width: 1px;
    height: 0px;
    background: var(--color-dark-ink-2);
    transition: height 0.6s ease;
  }
  .hero-scroll-indicator.is-visible .hero-scroll-line {
    height: 32px;
  }

  /* Curtain that wipes bottom→top across the hero-to-tagline scroll boundary.
     Sits as a fixed overlay so it animates against the viewport, not document flow.
     Lives outside .hero so the section's overflow: hidden doesn't clip it. */
  .hero-curtain {
    position: fixed;
    inset: 0;
    background: var(--color-dark-bg);
    pointer-events: none;
    z-index: 8000;
    transform: translateY(100%);
    will-change: transform;
  }

  .divider { height: 1px; background: var(--color-line); margin: 0 40px; }

  /* tagline — light, mid-tone canvas (3-value rhythm) */
  .tagline { padding: 120px 40px; background: var(--color-bg-2); }
  .tagline-text { font-family: var(--font-body); font-weight: 400; font-size: clamp(28px, 3.4vw, 52px); line-height: 1.15; letter-spacing: -0.025em; color: var(--color-ink); max-width: 1200px; }
  .tagline-text .tag-word { display: inline-block; opacity: 0.18; transition: opacity 0.4s ease; will-change: opacity; }

  /* timeline */
  .timeline { padding: 200px 40px 200px; position: relative; }
  .timeline-stage { height: 280vh; position: relative; }
  .timeline-stage.is-static { height: auto; }
  .timeline-stage.is-static .timeline-pin { height: auto; min-height: 60vh; }
  .timeline-pin {
    height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 40px;
    align-items: stretch;
    padding: 48px clamp(28px, 4vw, 64px);
    background: var(--color-paper);
    border-radius: 22px;
    box-shadow: var(--shadow-card);
  }
  .timeline-top { display: flex; justify-content: flex-end; align-items: baseline; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; color: var(--color-ink-2); text-transform: uppercase; }
  .timeline-mid { display: grid; place-items: center; position: relative; }
  .timeline-num { font-family: var(--font-display); font-weight: 500; font-style: normal; font-size: clamp(160px, 30vw, 460px); line-height: 0.9; letter-spacing: -0.02em; color: var(--color-ink); position: relative; }
  .timeline-cap { display: grid; grid-template-columns: 1fr 2fr 1fr; gap: 40px; align-items: end; padding-bottom: 20px; }
  .timeline-cap .label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-2); text-transform: uppercase; }
  .timeline-cap .text { font-size: clamp(18px, 2.2vw, 28px); line-height: 1.3; letter-spacing: -0.015em; max-width: 700px; font-family: var(--font-body); }
  .timeline-cap .right { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; color: var(--color-muted); text-transform: uppercase; text-align: right; }
  .timeline-bar { height: 1px; background: var(--color-line); position: relative; }
  .timeline-bar i { position: absolute; left: 0; top: 0; bottom: 0; width: 0%; background: var(--color-ink); }
  .timeline-ticks { display: flex; justify-content: space-between; margin-top: 12px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; color: var(--color-muted); }
  .timeline-ticks span { transition: color 0.5s ease; }
  .timeline-ticks span.active { color: var(--color-accent); }

  /* process — light chapter */
  .process { padding: clamp(80px, 12vh, 160px) 40px; }
  .process-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px 80px;
    align-items: start;
    margin-bottom: clamp(60px, 8vw, 100px);
  }
  .process-header .text-eyebrow-accent { grid-column: 1 / -1; }
  .process-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(40px, 5.5vw, 88px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }
  /* Each word clips upward — GSAP drives the reveal */
  .process-word {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
    margin-right: 0.22em;
  }
  .process-word > span {
    display: inline-block;
    transform: translateY(110%);
    opacity: 0;
  }
  .process-sub {
    font-size: clamp(14px, 1.4vw, 18px);
    line-height: 1.6;
    color: var(--color-muted);
    max-width: 360px;
    padding-top: 0.5em;
    align-self: end;
  }
  /* Connector sits above the grid, full-width */
  .process-grid-wrap { position: relative; }
  .process-connector {
    height: 32px;
    display: flex;
    align-items: center;
    margin-bottom: -1px;
    padding: 0 1px;
  }
  .process-connector-line {
    display: block;
    height: 1px;
    width: 0%;
    background: var(--color-accent);
    opacity: 0.5;
  }
  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-line);
    border: 1px solid var(--color-line);
    border-radius: 0 0 12px 12px;
    overflow: hidden;
  }
  .process-step {
    background: var(--color-bg);
    padding: clamp(28px, 3vw, 48px) clamp(24px, 2.5vw, 40px);
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: background 0.3s ease;
    cursor: pointer;
    /* Cards start hidden for GSAP entrance */
    opacity: 0;
    transform: translateY(24px);
  }
  .process-step:hover { background: var(--color-panel); }
  .process-num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--color-accent);
  }
  .process-step-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(24px, 2.4vw, 36px);
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-ink);
  }
  .process-step-body {
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-muted);
    flex: 1;
  }
  /* Expand hint button */
  .process-expand-hint {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease, color 0.2s ease;
  }
  .process-step:hover .process-expand-hint { opacity: 1; }
  .process-expand-hint[aria-expanded="true"] {
    opacity: 1;
    color: var(--color-accent);
  }
  .process-expand-hint[aria-expanded="true"] span { content: '−'; }
  /* Deliverables panel — max-height collapse */
  .process-deliverables {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .process-deliverables.is-open {
    max-height: 200px;
  }
  .process-deliverables ul {
    list-style: none;
    padding: 0;
    margin: 0;
    padding-top: 16px;
    border-top: 1px solid var(--color-line);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .process-deliverables li {
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-ink-2);
    display: flex;
    gap: 10px;
  }
  .process-deliverables li::before {
    content: '—';
    color: var(--color-accent);
    flex-shrink: 0;
  }
  @media (max-width: 900px) {
    .process-header { grid-template-columns: 1fr !important; }
    .process-grid { grid-template-columns: repeat(2, 1fr) !important; border-radius: 0 0 12px 12px; }
  }
  @media (max-width: 600px) {
    .process-grid { grid-template-columns: 1fr !important; }
    .process { padding: 60px 24px !important; }
  }
  @media (prefers-reduced-motion: reduce) {
    .process-word > span { transform: none; opacity: 1; }
    .process-step { opacity: 1; transform: none; }
    .process-connector-line { width: 100%; }
    .process-deliverables { transition: none; }
  }

  /* cta — dark chapter */
  .cta { padding: 200px 40px 120px; }
  .cta-title { font-family: var(--font-display); font-weight: 500; font-size: clamp(64px, 11.5vw, 200px); line-height: 0.96; letter-spacing: -0.025em; color: var(--color-dark-ink); }
  .cta-title .accent { color: var(--color-accent); }
  .cta-row { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end; margin-top: 80px; }
  .cta-link { display: inline-flex; align-items: center; gap: 18px; font-size: 22px; font-weight: 500; font-family: var(--font-body); letter-spacing: -0.01em; padding: 18px 0; border-bottom: 1px solid var(--color-dark-ink); color: var(--color-dark-ink); }
  /* Override .is-dark a specificity (0,1,1) — same fix pattern as .hero .hero-cta */
  .cta .cta-link { color: var(--color-dark-ink); }
  .cta-arrow { width: 44px; height: 44px; border-radius: 50%; background: var(--color-dark-ink); color: var(--color-dark-bg); display: grid; place-items: center; transition: transform 0.6s cubic-bezier(.7,0,.2,1), background 0.4s ease; flex-shrink: 0; }
  .cta-link:hover .cta-arrow { transform: rotate(-45deg); background: var(--color-accent); }
  .cta-side { font-size: 14px; line-height: 1.6; color: var(--color-dark-ink-2); max-width: 360px; padding-bottom: 24px; font-family: var(--font-body); }

  @media (max-width: 900px) {
    .cta-row { grid-template-columns: 1fr !important; gap: 32px !important; }
    .timeline-cap { grid-template-columns: 1fr !important; }
    .timeline-num { font-size: clamp(120px, 22vw, 280px) !important; }
    .hero-cta { bottom: 40px; padding: 14px 20px; font-size: 11px; }
  }
</style>

<script>
  import { gsap, ScrollTrigger, ease, reduceMotion } from '../lib/motion';

  // ============ LOADER → 3-SCREEN HERO ============
  if (!reduceMotion.current) {
    // Loader controls #site-nav visibility on the homepage only;
    // hide it now so the timeline can fade it in after the wipe.
    gsap.set('#site-nav', { opacity: 0 });
    // Pre-hide all hero panels; S1 fades in after loader exits.
    gsap.set('#hero-s1 .hero-s1-logo', { opacity: 0 });
    gsap.set('#hero-s2', { opacity: 0 });
    gsap.set('#hero-s3', { opacity: 0 });
    gsap.set('#hero-gallery', { opacity: 0 });
    gsap.set('#hero-cta', { opacity: 0, y: 20 });
    gsap.set('.hero-phrase-text .word > span', { y: '110%', opacity: 0 });
    gsap.set('.hero-s2-name .word > span', { y: '110%', opacity: 0 });
    // S2 scroll indicators start hidden
    gsap.set('.hero-scroll-indicator', { opacity: 0 });
    // Curtain stays below viewport until needed
    gsap.set('#hero-curtain', { y: 0, yPercent: 100 });

    const runway = document.getElementById('hero-runway');

    const intro = gsap.timeline({ defaults: { ease: ease.expo } });
    const pct = { v: 0 };
    intro
      .to(pct, {
        v: 100, duration: 1.4, ease: 'power1.inOut',
        onUpdate: () => {
          const el = document.getElementById('loader-pct');
          if (el) el.textContent = Math.floor(pct.v).toString().padStart(3, '0');
        }
      }, 0)
      .to('#loader-bar-fill', { width: '100%', duration: 1.4, ease: 'power1.inOut' }, 0)
      .to('.loader-path', { strokeDashoffset: 0, duration: 0.7, stagger: 0.06, ease: 'power3.out' }, 0)
      .to('#loader', { yPercent: -100, duration: 1.0, ease: 'expo.inOut' }, '+=0.6')
      .set('#loader', { display: 'none' })
      .to('#site-nav', { opacity: 1, duration: 0.6, ease: ease.out }, '-=0.5')
      // Screen 1: logo fades in as loader exits
      .to('#hero-s1 .hero-s1-logo', { opacity: 1, duration: 0.9, ease: ease.out }, '-=0.4')
      // Scroll indicator appears 0.6s later with extending line; unlock scroll sequencer here
      .to('#hero-s1 .hero-scroll-indicator', {
        opacity: 1, duration: 0.5, ease: ease.out,
        onComplete: () => {
          document.querySelector<HTMLElement>('#hero-s1 .hero-scroll-indicator')?.classList.add('is-visible');
          // Enable ScrollTrigger now that intro is complete
          if (runway) {
            const st = ScrollTrigger.getById('hero-sequencer');
            if (st) st.enable();
          }
        }
      }, '+=0.3');

    // ============ 3-SCREEN SCROLL SEQUENCER ============
    // .hero-runway is 300vh; .hero-stage is sticky so the viewport always shows
    // the stage while scrolling through the runway. ScrollTrigger scrubs progress
    // 0→1 across the full 300vh, mapping thirds to S1→S2→S3 transitions.
    // Curtain wipe fires on leave (scroll past 300vh) → reveals tagline section.
    if (runway) {
      // Track which screen is current to avoid re-triggering transitions
      let currentScreen = 1;

      const showScreen2 = () => {
        if (currentScreen === 2) return;
        currentScreen = 2;
        // Collapse S1 scroll indicator
        document.querySelector<HTMLElement>('#hero-s1 .hero-scroll-indicator')?.classList.remove('is-visible');
        gsap.to('#hero-s1 .hero-scroll-indicator', { opacity: 0, duration: 0.3, ease: 'power2.in' });
        // S1 logo fades out
        gsap.to('#hero-s1 .hero-s1-logo', { opacity: 0, duration: 0.4, ease: 'power2.in' });
        // S2 fades in
        gsap.set('#hero-s2', { opacity: 1 });
        gsap.to('.hero-s2-eyebrow', { opacity: 1, duration: 0.6, ease: ease.out, delay: 0.1 });
        gsap.to('.hero-s2-name .word > span', {
          y: '0%', opacity: 1, duration: 0.9, stagger: 0.08, ease: 'expo.out', delay: 0.2,
        });
        gsap.to('#hero-s2 .hero-scroll-indicator', {
          opacity: 1, duration: 0.5, ease: ease.out, delay: 0.6,
          onComplete: () => {
            document.querySelector<HTMLElement>('#hero-s2 .hero-scroll-indicator')?.classList.add('is-visible');
          }
        });
      };

      const showScreen1 = () => {
        if (currentScreen === 1) return;
        currentScreen = 1;
        // Reverse: hide S2, restore S1
        gsap.to('#hero-s2', { opacity: 0, duration: 0.35, ease: 'power2.in' });
        gsap.to('#hero-s1 .hero-s1-logo', { opacity: 1, duration: 0.5, ease: ease.out });
        gsap.to('#hero-s1 .hero-scroll-indicator', {
          opacity: 1, duration: 0.4, ease: ease.out,
          onComplete: () => {
            document.querySelector<HTMLElement>('#hero-s1 .hero-scroll-indicator')?.classList.add('is-visible');
          }
        });
      };

      const showScreen3 = () => {
        if (currentScreen === 3) return;
        currentScreen = 3;
        // S2 scroll indicator collapses
        document.querySelector<HTMLElement>('#hero-s2 .hero-scroll-indicator')?.classList.remove('is-visible');
        gsap.to('#hero-s2 .hero-scroll-indicator', { opacity: 0, duration: 0.25, ease: 'power2.in' });
        // S2 slides up as S3 fades in
        gsap.to('#hero-s2', { yPercent: -6, opacity: 0, duration: 0.55, ease: 'expo.in' });
        gsap.set('#hero-s3', { opacity: 1 });
        gsap.to('#hero-gallery', { opacity: 1, duration: 1.0, ease: ease.out, delay: 0.1 });
        gsap.to('.hero-phrase-text .word > span', {
          y: '0%', opacity: 1, duration: 1.0, stagger: 0.06, ease: 'expo.out', delay: 0.3,
        });
        gsap.to('#hero-cta', { opacity: 1, y: 0, duration: 0.7, ease: ease.out, delay: 0.7 });
      };

      const showScreen2from3 = () => {
        if (currentScreen === 2) return;
        currentScreen = 2;
        // Reverse: hide S3, restore S2
        gsap.to('#hero-s3', { opacity: 0, duration: 0.4, ease: 'power2.in' });
        gsap.set('.hero-s2-name .word > span', { y: '0%', opacity: 1 });
        gsap.set('.hero-s2-eyebrow', { opacity: 1 });
        gsap.to('#hero-s2', { yPercent: 0, opacity: 1, duration: 0.5, ease: ease.out });
        gsap.to('#hero-s2 .hero-scroll-indicator', {
          opacity: 1, duration: 0.4, ease: ease.out, delay: 0.3,
          onComplete: () => {
            document.querySelector<HTMLElement>('#hero-s2 .hero-scroll-indicator')?.classList.add('is-visible');
          }
        });
      };

      // Breakpoints: 0–33% = S1, 33–66% = S2, 66–100% = S3
      // Disabled until the loader intro finishes so mid-load scroll doesn't
      // trigger transitions before S1 is even visible.
      ScrollTrigger.create({
        id: 'hero-sequencer',
        trigger: runway,
        start: 'top top',
        end: 'bottom bottom',
        enabled: false,
        onUpdate: (self) => {
          const p = self.progress;
          if (p < 0.33) {
            if (currentScreen !== 1) showScreen1();
          } else if (p < 0.66) {
            if (currentScreen === 1) showScreen2();
            else if (currentScreen === 3) showScreen2from3();
          } else {
            if (currentScreen !== 3) showScreen3();
          }
        },
        onLeave: () => {
          // Brief decorative wipe as the hero runway exits — tagline is next in document flow.
          gsap.set('#hero-curtain', { display: 'block', yPercent: 100 });
          gsap.timeline({ onComplete: () => gsap.set('#hero-curtain', { display: 'none', yPercent: 100 }) })
            .to('#hero-curtain', { yPercent: 0, duration: 0.35, ease: 'expo.out' })
            .to('#hero-curtain', { yPercent: -100, duration: 0.45, ease: 'expo.in' });
        },
      });
    }
  } else {
    // Reduced motion: skip loader, show S3 (gallery + CTA) immediately.
    const loader = document.getElementById('loader');
    if (loader) loader.style.display = 'none';
    gsap.set('#site-nav', { opacity: 1 });
    gsap.set('#hero-s1, #hero-s2', { opacity: 0 });
    gsap.set('#hero-s3', { opacity: 1 });
    gsap.set('#hero-gallery', { opacity: 1 });
    gsap.set('#hero-cta', { opacity: 1, y: 0 });
    gsap.set('.hero-phrase-text .word > span', { y: '0%', opacity: 1 });
  }

  // ============ VBREAK PARALLAX ============
  if (!reduceMotion.current) {
    gsap.fromTo('#vbreak-bg',
      { yPercent: -14 },
      {
        yPercent: 14,
        ease: 'none',
        scrollTrigger: { trigger: '.vbreak', start: 'top bottom', end: 'bottom top', scrub: true },
      }
    );
  }

  // ============ TAGLINE WORD SCRUB ============
  (function setupTagline() {
    const el = document.getElementById('tagline-text');
    if (!el) return;

    // Wrap each word in a .tag-word, descending into element nodes (e.g. .accent)
    // so phrases like "measurably simpler" scrub per-word instead of as a unit.
    const wrapWords = (parent: Node) => {
      const children = Array.from(parent.childNodes);
      children.forEach((node) => {
        if (node.nodeType === 3) {
          const text = node.nodeValue || '';
          if (!text.trim()) return;
          const frag = document.createDocumentFragment();
          text.split(/(\s+)/).forEach((part) => {
            if (!part) return;
            if (/^\s+$/.test(part)) {
              frag.appendChild(document.createTextNode(part));
            } else {
              const span = document.createElement('span');
              span.className = 'tag-word';
              span.textContent = part;
              frag.appendChild(span);
            }
          });
          (node as ChildNode).replaceWith(frag);
        } else if (node.nodeType === 1) {
          // Recurse into element nodes (preserves .accent and other inline styling)
          wrapWords(node);
        }
      });
    };
    wrapWords(el);

    if (reduceMotion.current) {
      // Static fallback: ensure all words are fully visible.
      el.querySelectorAll<HTMLElement>('.tag-word').forEach((w) => { w.style.opacity = '1'; });
      return;
    }

    const words = el.querySelectorAll('.tag-word');
    gsap.to(words, {
      opacity: 1,
      stagger: { each: 0.04 },
      ease: 'none',
      scrollTrigger: { trigger: el, start: 'top 80%', end: 'top 30%', scrub: 0.6 },
    });
  })();

  // ============ TIMELINE PINNED ============
  const tlData = [
    { y: '2018', text: 'First freelance esports overlay. Discord DMs, forty bucks, learning Photoshop the hard way.', tag: 'Self-taught' },
    { y: '2019', text: 'Pivot to UX. First paid web project for a community nonprofit; learned Figma overnight.', tag: 'Pivot' },
    { y: '2021', text: 'Joined the Gazelle Group. Brand systems for ESPN-affiliated tournaments touching ten million screens.', tag: 'Studio' },
    { y: '2024', text: 'Vlier and YMCA — first proper enterprise UX engagements. Deliverables that actually shipped.', tag: 'Enterprise' },
    { y: '2026', text: 'AI-generated TV spot for the Winter Olympics. Now rebuilding everything — in public.', tag: 'Today' },
  ];
  const tlNum = document.getElementById('timeline-num');
  const tlText = document.getElementById('timeline-text');
  const tlTag = document.getElementById('timeline-tag');
  const tlFill = document.getElementById('timeline-fill') as HTMLElement | null;
  const tlProg = document.getElementById('timeline-progress');
  const tlTicks = document.querySelectorAll<HTMLElement>('#timeline-ticks span');
  let tlIdx = 0;

  function setTimeline(idx: number) {
    if (idx === tlIdx || !tlNum || !tlText || !tlTag || !tlProg) return;
    tlIdx = idx;
    const cur = tlData[idx];
    if (!reduceMotion.current) {
      gsap.fromTo(tlNum, { y: 30, opacity: 0 }, { y: 0, opacity: 1, duration: 0.65, ease: ease.expo });
      gsap.fromTo([tlText, tlTag], { y: 18, opacity: 0 }, { y: 0, opacity: 1, duration: 0.6, stagger: 0.05, ease: ease.expo, delay: 0.08 });
    }
    tlNum.textContent = cur.y;
    tlText.textContent = cur.text;
    tlTag.textContent = cur.tag;
    tlProg.textContent = `${(idx + 1).toString().padStart(2, '0')} / ${tlData.length.toString().padStart(2, '0')}`;
    tlTicks.forEach((s, i) => s.classList.toggle('active', i === idx));
  }

  // Pinning is desktop-only and disabled under reduced motion; without the pin
  // the timeline-stage still scrolls naturally and the entries swap in via the
  // onUpdate progress mapping.
  const isMobile = window.matchMedia('(max-width: 900px)').matches;
  if (!reduceMotion.current && !isMobile) {
    ScrollTrigger.create({
      trigger: '#timeline-stage',
      start: 'top top',
      end: 'bottom bottom',
      pin: '#timeline-pin',
      onUpdate: (self) => {
        const idx = Math.min(tlData.length - 1, Math.floor(self.progress * tlData.length));
        setTimeline(idx);
        if (tlFill) tlFill.style.width = (self.progress * 100).toFixed(2) + '%';
      },
    });
  } else {
    // Static fallback: render the final entry so reduced-motion / mobile users
    // see populated copy instead of the 2018 placeholder, and collapse the
    // 280vh pin runway so the section doesn't leave a blank scroll gap.
    document.getElementById('timeline-stage')?.classList.add('is-static');
    setTimeline(tlData.length - 1);
    if (tlFill) tlFill.style.width = '100%';
  }

  // ============ PROCESS ============
  {
    const section = document.querySelector<HTMLElement>('.process');
    if (section && !reduceMotion.current) {
      const words = section.querySelectorAll<HTMLElement>('.process-word > span');
      const cards = section.querySelectorAll<HTMLElement>('[data-process-card]');
      const connectorLine = section.querySelector<HTMLElement>('.process-connector-line');

      // 1. Word-by-word headline reveal
      gsap.to(words, {
        y: 0,
        opacity: 1,
        duration: 0.7,
        stagger: 0.1,
        ease: ease.expo,
        scrollTrigger: { trigger: '[data-process-title]', start: 'top 85%', once: true },
      });

      // 2. Staggered card entrance (left to right, 100ms stagger)
      gsap.to(cards, {
        y: 0,
        opacity: 1,
        duration: 0.7,
        stagger: 0.1,
        ease: ease.out,
        scrollTrigger: { trigger: '.process-grid', start: 'top 88%', once: true },
        onComplete() {
          // 3. Connector line draws after last card lands
          if (connectorLine) {
            gsap.to(connectorLine, {
              width: '100%',
              duration: 0.8,
              ease: 'power2.out',
            });
          }
        },
      });
    }

    // 4. Click-to-expand deliverables
    document.querySelectorAll<HTMLElement>('[data-process-card]').forEach((card) => {
      const btn = card.querySelector<HTMLButtonElement>('.process-expand-hint');
      const panel = card.querySelector<HTMLElement>('.process-deliverables');
      const indicator = btn?.querySelector<HTMLElement>('span');
      if (!btn || !panel) return;

      btn.addEventListener('click', () => {
        const isOpen = panel.classList.contains('is-open');

        // Collapse any other open panel first
        document.querySelectorAll<HTMLElement>('.process-deliverables.is-open').forEach((p) => {
          p.classList.remove('is-open');
          p.setAttribute('aria-hidden', 'true');
          const b = p.previousElementSibling as HTMLButtonElement | null;
          if (b) {
            b.setAttribute('aria-expanded', 'false');
            const ind = b.querySelector<HTMLElement>('span');
            if (ind) ind.textContent = '+';
          }
        });

        if (!isOpen) {
          panel.classList.add('is-open');
          panel.setAttribute('aria-hidden', 'false');
          btn.setAttribute('aria-expanded', 'true');
          if (indicator) indicator.textContent = '−';
        }
      });
    });
  }

  // ============ CTA ============
  if (!reduceMotion.current) {
    gsap.set('.cta-title .line span', { y: '110%' });
    gsap.to('.cta-title .line span', {
      y: '0%', duration: 1.2, stagger: 0.1, ease: ease.expo,
      scrollTrigger: { trigger: '.cta-title', start: 'top 80%' },
    });
    gsap.from('.cta-row > *', {
      y: 30, opacity: 0, duration: 0.9, stagger: 0.1, ease: ease.out,
      scrollTrigger: { trigger: '.cta-row', start: 'top 85%' },
    });
  }

</script>
