---
import BaseLayout from '../layouts/BaseLayout.astro';
import HorizontalWork from '../components/HorizontalWork.astro';
import HeroGallery from '../components/HeroGallery.astro';
---

<BaseLayout initialMode="dark">

  <!-- ============ LOADER (dark) ============ -->
  <div class="loader" id="loader">
    <div class="loader-top">
      <span>Index — 2026</span>
      <span id="loader-pct">000</span>
    </div>
    <div class="loader-mid">
      <div class="loader-svg">
        <svg
          class="loader-b"
          viewBox="0 0 96 96"
          aria-hidden="true"
          style="stroke: var(--color-dark-ink); fill: none; stroke-linecap: round; stroke-linejoin: round;"
        >
          <path class="loader-path" d="M20 68V22h24c10 0 16 5 16 12.5 0 4.8-2.5 8.3-6.8 10.2C59 46.4 63 50.7 63 57c0 8-6.4 11-17.2 11H20Z" stroke-width="3"/>
          <path class="loader-path" d="M32 41h10c3.5 0 5.4-1.5 5.4-4.2 0-2.6-2-4-5.6-4H32v8.2Z" stroke-width="3"/>
          <path class="loader-path" d="M32 58h12.5c3.8 0 5.8-1.7 5.8-4.7 0-2.8-2.1-4.5-6.1-4.5H32V58Z" stroke-width="3"/>
          <circle cx="70" cy="25" r="7" fill="var(--color-accent)" stroke="none"/>
        </svg>
      </div>
    </div>
    <div class="loader-foot">
      <div class="loader-bar"><i id="loader-bar-fill"></i></div>
      <div class="loader-bot">
        <span>Loading portfolio</span>
        <span>Astro &middot; GSAP</span>
      </div>
    </div>
  </div>

  <!-- ============ HERO (dark) — phrase → gallery + CTA ============ -->
  <section class="hero is-dark" id="hero" data-section-mode="dark">
    <div class="hero-gallery" id="hero-gallery">
      <HeroGallery />
      <div class="hero-gallery-scrim" aria-hidden="true"></div>
    </div>

    <div class="hero-phrase" id="hero-phrase">
      <h1 class="hero-phrase-text" id="hero-phrase-text">
        <span class="word"><span>Type</span></span> <span class="word"><span>that</span></span> <span class="word"><span>reads.</span></span>
        <br/>
        <span class="word"><span>Motion</span></span> <span class="word"><span>that</span></span> <span class="word"><span>means</span></span> <span class="word"><span>something.</span></span>
      </h1>
    </div>

    <a
      href="/work/graphic-design"
      class="hero-cta"
      id="hero-cta"
      data-cursor="browse"
      data-magnetic="0.3"
    >
      <span>View design work</span>
      <span class="hero-cta-arrow">→</span>
    </a>
  </section>

  <div class="hero-curtain" id="hero-curtain" aria-hidden="true"></div>

  <!-- ============ TAGLINE (light) ============ -->
  <section class="tagline atmo-warmth-tl">
    <p class="tagline-text" id="tagline-text">
      I help teams turn complicated ideas into <span class="accent">measurably simpler</span> products — with type that reads, motion that means something, and details that hold up under scrutiny.
    </p>
  </section>

  <div class="divider"></div>

  <!-- ============ VISUAL BREAK (dark parallax strip) ============ -->
  <section class="vbreak is-dark" data-section-mode="dark" aria-hidden="true">
    <div class="vbreak-bg" id="vbreak-bg">
      <p class="vbreak-quote" data-reveal>Details that hold up under scrutiny.</p>
    </div>
  </section>

  <!-- ============ SELECTED WORK (horizontal pinned, light) ============ -->
  <HorizontalWork />

  <!-- ============ TIMELINE (light) ============ -->
  <section class="timeline" id="timeline">
    <div class="timeline-stage" id="timeline-stage">
      <div class="timeline-pin" id="timeline-pin">
        <div class="timeline-top">
          <span id="timeline-progress">01 / 05</span>
        </div>
        <div class="timeline-mid">
          <div class="timeline-num" id="timeline-num">2018</div>
        </div>
        <div>
          <div class="timeline-cap">
            <div class="label" data-reveal>Marker</div>
            <div class="text" id="timeline-text" data-reveal>First freelance esports overlay. Discord DMs, forty bucks, learning Photoshop the hard way.</div>
            <div class="right" id="timeline-tag" data-reveal>Self-taught</div>
          </div>
          <div class="timeline-bar"><i id="timeline-fill"></i></div>
          <div class="timeline-ticks" id="timeline-ticks">
            <span class="active">2018</span><span>2019</span><span>2021</span><span>2024</span><span>2026</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA (dark + radial halos) ============ -->
  <section class="cta is-dark has-halos" id="cta" data-section-mode="dark">
    <h2 class="cta-title" id="cta-title">
      <span class="line"><span>Have something</span></span>
      <span class="line"><span><span class="accent">worth making?</span></span></span>
    </h2>
    <div class="cta-row">
      <a href="mailto:hello@benlaclair.com" data-cursor="email" data-magnetic="0.4" class="cta-link">
        hello@benlaclair.com
        <span class="cta-arrow">→</span>
      </a>
      <p class="cta-side" data-reveal>Replies usually within a day. The shorter your brief, the faster I can be useful — three sentences is plenty.</p>
    </div>
  </section>

</BaseLayout>

<style is:global>
  /* loader — dark bg */
  .loader { position: fixed; inset: 0; background: var(--color-dark-bg); z-index: 10000; display: flex; flex-direction: column; justify-content: space-between; padding: 40px; }
  .loader-top, .loader-bot { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-dark-ink-2); }
  .loader-mid { flex: 1; display: grid; place-items: center; }
  .loader-svg { display: grid; place-items: center; }
  .loader-b { width: clamp(80px, 14vw, 160px); height: clamp(80px, 14vw, 160px); }
  .loader-path { stroke-dasharray: 240; stroke-dashoffset: 240; }
  .loader-foot { display: flex; flex-direction: column; gap: 20px; }
  .loader-bar { height: 1px; background: rgba(244, 239, 228, 0.15); position: relative; overflow: hidden; }
  .loader-bar i { position: absolute; left: 0; top: 0; bottom: 0; width: 0%; background: var(--color-dark-ink); }

  /* hero — dark chapter; phrase first, then gallery + CTA */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
  }
  .hero-gallery {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0;
  }
  .hero-gallery-scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      radial-gradient(60% 50% at 50% 60%, rgba(13, 12, 10, 0) 0%, rgba(13, 12, 10, 0.55) 100%),
      linear-gradient(180deg, rgba(13, 12, 10, 0.35) 0%, rgba(13, 12, 10, 0.45) 50%, rgba(13, 12, 10, 0.7) 100%);
    pointer-events: none;
  }
  .hero-phrase {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: grid;
    place-items: center;
    padding: 0 40px;
    pointer-events: none;
  }
  .hero-phrase-text {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(40px, 8vw, 140px);
    line-height: 0.96;
    letter-spacing: -0.04em;
    text-align: center;
    color: var(--color-dark-ink);
    max-width: 1200px;
  }
  .hero-cta {
    position: absolute;
    left: 50%;
    bottom: 64px;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 16px 26px;
    background: var(--color-accent);
    color: var(--color-dark-ink);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 999px;
    text-decoration: none;
    z-index: 4;
    opacity: 0;
    transition: background 0.3s ease;
  }
  .hero-cta:hover { background: var(--color-accent-hover); }
  .hero-cta-arrow {
    display: inline-block;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hero-cta:hover .hero-cta-arrow { transform: translateX(4px); }

  /* Curtain that wipes bottom→top across the hero-to-tagline scroll boundary.
     Sits as a fixed overlay so it animates against the viewport, not document flow.
     Lives outside .hero so the section's overflow: hidden doesn't clip it. */
  .hero-curtain {
    position: fixed;
    inset: 0;
    background: var(--color-dark-bg);
    pointer-events: none;
    z-index: 8000;
    transform: translateY(100%);
    will-change: transform;
  }

  .divider { height: 1px; background: var(--color-line); margin: 0 40px; }

  /* tagline — light, mid-tone canvas (3-value rhythm) */
  .tagline { padding: 120px 40px; background: var(--color-bg-2); }
  .tagline-text { font-family: var(--font-body); font-weight: 400; font-size: clamp(28px, 3.4vw, 52px); line-height: 1.15; letter-spacing: -0.025em; color: var(--color-ink); max-width: 1200px; }
  .tagline-text .tag-word { display: inline-block; opacity: 0.18; transition: opacity 0.4s ease; will-change: opacity; }

  /* timeline */
  .timeline { padding: 200px 40px 200px; position: relative; }
  .timeline-stage { height: 280vh; position: relative; }
  .timeline-stage.is-static { height: auto; }
  .timeline-stage.is-static .timeline-pin { height: auto; min-height: 60vh; }
  .timeline-pin {
    height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 40px;
    align-items: stretch;
    padding: 48px clamp(28px, 4vw, 64px);
    background: var(--color-paper);
    border-radius: 22px;
    box-shadow: var(--shadow-card);
  }
  .timeline-top { display: flex; justify-content: flex-end; align-items: baseline; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; color: var(--color-ink-2); text-transform: uppercase; }
  .timeline-mid { display: grid; place-items: center; position: relative; }
  .timeline-num { font-family: var(--font-display); font-weight: 500; font-style: normal; font-size: clamp(160px, 30vw, 460px); line-height: 0.85; letter-spacing: -0.04em; color: var(--color-ink); position: relative; }
  .timeline-cap { display: grid; grid-template-columns: 1fr 2fr 1fr; gap: 40px; align-items: end; padding-bottom: 20px; }
  .timeline-cap .label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-2); text-transform: uppercase; }
  .timeline-cap .text { font-size: clamp(18px, 2.2vw, 28px); line-height: 1.3; letter-spacing: -0.015em; max-width: 700px; font-family: var(--font-body); }
  .timeline-cap .right { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; color: var(--color-muted); text-transform: uppercase; text-align: right; }
  .timeline-bar { height: 1px; background: var(--color-line); position: relative; }
  .timeline-bar i { position: absolute; left: 0; top: 0; bottom: 0; width: 0%; background: var(--color-ink); }
  .timeline-ticks { display: flex; justify-content: space-between; margin-top: 12px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; color: var(--color-muted); }
  .timeline-ticks span { transition: color 0.5s ease; }
  .timeline-ticks span.active { color: var(--color-accent); }

  /* cta — dark chapter */
  .cta { padding: 200px 40px 120px; }
  .cta-title { font-family: var(--font-display); font-weight: 500; font-size: clamp(64px, 11.5vw, 200px); line-height: 0.92; letter-spacing: -0.05em; color: var(--color-dark-ink); }
  .cta-title .accent { color: var(--color-accent); }
  .cta-row { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end; margin-top: 80px; }
  .cta-link { display: inline-flex; align-items: center; gap: 18px; font-size: 22px; font-weight: 500; font-family: var(--font-body); letter-spacing: -0.01em; padding: 18px 0; border-bottom: 1px solid var(--color-dark-ink); color: var(--color-dark-ink); }
  .cta-arrow { width: 44px; height: 44px; border-radius: 50%; background: var(--color-dark-ink); color: var(--color-dark-bg); display: grid; place-items: center; transition: transform 0.6s cubic-bezier(.7,0,.2,1), background 0.4s ease; flex-shrink: 0; }
  .cta-link:hover .cta-arrow { transform: rotate(-45deg); background: var(--color-accent); }
  .cta-side { font-size: 14px; line-height: 1.6; color: var(--color-dark-ink-2); max-width: 360px; padding-bottom: 24px; font-family: var(--font-body); }

  @media (max-width: 900px) {
    .cta-row { grid-template-columns: 1fr !important; gap: 32px !important; }
    .timeline-cap { grid-template-columns: 1fr !important; }
    .timeline-num { font-size: clamp(120px, 22vw, 280px) !important; }
    .hero-cta { bottom: 40px; padding: 14px 20px; font-size: 11px; }
  }
</style>

<script>
  import { gsap, ScrollTrigger, ease, reduceMotion } from '../lib/motion';

  // ============ LOADER → HERO PHRASE → GALLERY + CTA ============
  if (!reduceMotion.current) {
    // Loader controls #site-nav visibility on the homepage only;
    // hide it now so the timeline can fade it in after the wipe.
    gsap.set('#site-nav', { opacity: 0 });
    gsap.set('#hero-cta', { y: 20 });

    const intro = gsap.timeline({ defaults: { ease: ease.expo } });
    const pct = { v: 0 };
    intro
      .to(pct, {
        v: 100, duration: 1.4, ease: 'power1.inOut',
        onUpdate: () => {
          const el = document.getElementById('loader-pct');
          if (el) el.textContent = Math.floor(pct.v).toString().padStart(3, '0');
        }
      }, 0)
      .to('#loader-bar-fill', { width: '100%', duration: 1.4, ease: 'power1.inOut' }, 0)
      .to('.loader-path', { strokeDashoffset: 0, duration: 0.7, stagger: 0.06, ease: 'power3.out' }, 0)
      .to('#loader', { yPercent: -100, duration: 1.0, ease: 'expo.inOut' }, '+=0.6')
      .set('#loader', { display: 'none' })
      .to('#site-nav', { opacity: 1, duration: 0.6, ease: ease.out }, '-=0.5')
      // Hero phrase word-reveal (global .word > span CSS hides at translateY 115%; tween to 0).
      .fromTo('#hero-phrase-text .word > span',
        { yPercent: 115, y: 0 },
        { yPercent: 0, y: 0, stagger: 0.04, duration: 1.0, ease: 'expo.out' },
        '-=0.4'
      )
      // Brief dwell — long enough to read in one beat, short enough not to outstay
      .to({}, { duration: 1.4 })
      // Phrase exits upward as gallery + CTA fade in
      .to('#hero-phrase', { yPercent: -15, opacity: 0, duration: 0.7, ease: 'expo.in' })
      .to('#hero-gallery', { opacity: 1, duration: 0.9, ease: ease.out }, '-=0.55')
      .to('#hero-cta', { opacity: 1, y: 0, duration: 0.6, ease: ease.out }, '-=0.35');
  } else {
    // Reduced motion: skip loader, show gallery + CTA immediately, hide phrase.
    const loader = document.getElementById('loader');
    if (loader) loader.style.display = 'none';
    gsap.set('#site-nav', { opacity: 1 });
    gsap.set('#hero-phrase', { opacity: 0 });
    gsap.set('#hero-gallery, #hero-cta', { opacity: 1 });
  }

  // ============ HERO → TAGLINE CURTAIN WIPE ============
  // One-shot: as soon as the user starts scrolling past the hero, a dark
  // panel rises from below, briefly covers the viewport, then exits upward —
  // revealing the tagline beneath. Total runtime ~1.3s. Scrub was rejected
  // because a scrub-bound curtain stalled at full cover whenever the user
  // paused mid-scroll, and the rise was invisible until ~30% scroll.
  if (!reduceMotion.current) {
    ScrollTrigger.create({
      trigger: '#hero',
      start: 'bottom 85%', // fires after ~15vh of scroll past hero's start
      once: true,
      onEnter: () => {
        const tl = gsap.timeline();
        tl.set('#hero-curtain', { yPercent: 100, display: 'block' });
        tl.to('#hero-curtain', { yPercent: 0, duration: 0.55, ease: 'expo.inOut' });
        tl.to('#hero-curtain', { yPercent: -100, duration: 0.7, ease: 'expo.inOut' }, '+=0.05');
        tl.set('#hero-curtain', { display: 'none' });
      },
    });
  }

  // ============ VBREAK PARALLAX ============
  if (!reduceMotion.current) {
    gsap.fromTo('#vbreak-bg',
      { yPercent: -14 },
      {
        yPercent: 14,
        ease: 'none',
        scrollTrigger: { trigger: '.vbreak', start: 'top bottom', end: 'bottom top', scrub: true },
      }
    );
  }

  // ============ TAGLINE WORD SCRUB ============
  (function setupTagline() {
    const el = document.getElementById('tagline-text');
    if (!el) return;

    // Wrap each word in a .tag-word, descending into element nodes (e.g. .accent)
    // so phrases like "measurably simpler" scrub per-word instead of as a unit.
    const wrapWords = (parent: Node) => {
      const children = Array.from(parent.childNodes);
      children.forEach((node) => {
        if (node.nodeType === 3) {
          const text = node.nodeValue || '';
          if (!text.trim()) return;
          const frag = document.createDocumentFragment();
          text.split(/(\s+)/).forEach((part) => {
            if (!part) return;
            if (/^\s+$/.test(part)) {
              frag.appendChild(document.createTextNode(part));
            } else {
              const span = document.createElement('span');
              span.className = 'tag-word';
              span.textContent = part;
              frag.appendChild(span);
            }
          });
          (node as ChildNode).replaceWith(frag);
        } else if (node.nodeType === 1) {
          // Recurse into element nodes (preserves .accent and other inline styling)
          wrapWords(node);
        }
      });
    };
    wrapWords(el);

    if (reduceMotion.current) {
      // Static fallback: ensure all words are fully visible.
      el.querySelectorAll<HTMLElement>('.tag-word').forEach((w) => { w.style.opacity = '1'; });
      return;
    }

    const words = el.querySelectorAll('.tag-word');
    gsap.to(words, {
      opacity: 1,
      stagger: { each: 0.04 },
      ease: 'none',
      scrollTrigger: { trigger: el, start: 'top 80%', end: 'top 30%', scrub: 0.6 },
    });
  })();

  // ============ TIMELINE PINNED ============
  const tlData = [
    { y: '2018', text: 'First freelance esports overlay. Discord DMs, forty bucks, learning Photoshop the hard way.', tag: 'Self-taught' },
    { y: '2019', text: 'Pivot to UX. First paid web project for a community nonprofit; learned Figma overnight.', tag: 'Pivot' },
    { y: '2021', text: 'Joined the Gazelle Group. Brand systems for ESPN-affiliated tournaments touching ten million screens.', tag: 'Studio' },
    { y: '2024', text: 'Vlier and YMCA — first proper enterprise UX engagements. Deliverables that actually shipped.', tag: 'Enterprise' },
    { y: '2026', text: 'AI-generated TV spot for the Winter Olympics. Now rebuilding everything — in public.', tag: 'Today' },
  ];
  const tlNum = document.getElementById('timeline-num');
  const tlText = document.getElementById('timeline-text');
  const tlTag = document.getElementById('timeline-tag');
  const tlFill = document.getElementById('timeline-fill') as HTMLElement | null;
  const tlProg = document.getElementById('timeline-progress');
  const tlTicks = document.querySelectorAll<HTMLElement>('#timeline-ticks span');
  let tlIdx = 0;

  function setTimeline(idx: number) {
    if (idx === tlIdx || !tlNum || !tlText || !tlTag || !tlProg) return;
    tlIdx = idx;
    const cur = tlData[idx];
    if (!reduceMotion.current) {
      gsap.fromTo(tlNum, { y: 30, opacity: 0 }, { y: 0, opacity: 1, duration: 0.65, ease: ease.expo });
      gsap.fromTo([tlText, tlTag], { y: 18, opacity: 0 }, { y: 0, opacity: 1, duration: 0.6, stagger: 0.05, ease: ease.expo, delay: 0.08 });
    }
    tlNum.textContent = cur.y;
    tlText.textContent = cur.text;
    tlTag.textContent = cur.tag;
    tlProg.textContent = `${(idx + 1).toString().padStart(2, '0')} / ${tlData.length.toString().padStart(2, '0')}`;
    tlTicks.forEach((s, i) => s.classList.toggle('active', i === idx));
  }

  // Pinning is desktop-only and disabled under reduced motion; without the pin
  // the timeline-stage still scrolls naturally and the entries swap in via the
  // onUpdate progress mapping.
  const isMobile = window.matchMedia('(max-width: 900px)').matches;
  if (!reduceMotion && !isMobile) {
    ScrollTrigger.create({
      trigger: '#timeline-stage',
      start: 'top top',
      end: 'bottom bottom',
      pin: '#timeline-pin',
      onUpdate: (self) => {
        const idx = Math.min(tlData.length - 1, Math.floor(self.progress * tlData.length));
        setTimeline(idx);
        if (tlFill) tlFill.style.width = (self.progress * 100).toFixed(2) + '%';
      },
    });
  } else {
    // Static fallback: render the final entry so reduced-motion / mobile users
    // see populated copy instead of the 2018 placeholder, and collapse the
    // 280vh pin runway so the section doesn't leave a blank scroll gap.
    document.getElementById('timeline-stage')?.classList.add('is-static');
    setTimeline(tlData.length - 1);
    if (tlFill) tlFill.style.width = '100%';
  }

  // ============ CTA ============
  if (!reduceMotion.current) {
    gsap.set('.cta-title .line span', { y: '110%' });
    gsap.to('.cta-title .line span', {
      y: '0%', duration: 1.2, stagger: 0.1, ease: ease.expo,
      scrollTrigger: { trigger: '.cta-title', start: 'top 80%' },
    });
    gsap.from('.cta-row > *', {
      y: 30, opacity: 0, duration: 0.9, stagger: 0.1, ease: ease.out,
      scrollTrigger: { trigger: '.cta-row', start: 'top 85%' },
    });
  }

</script>
