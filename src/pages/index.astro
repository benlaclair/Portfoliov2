---
import BaseLayout from '../layouts/BaseLayout.astro';
import HorizontalWork from '../components/HorizontalWork.astro';
import SectionNav from '../components/SectionNav.astro';
---

<BaseLayout initialMode="light">

  <!-- Reset scroll position before the browser can restore it -->
  <script is:inline>
    if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
    window.scrollTo(0, 0);
  </script>

  <!-- ============ LOADER (dark) ============ -->
  <div class="loader" id="loader">
    <p class="loader-greeting" id="loader-greeting">
      <span class="word"><span>Hi,</span></span>
      <span class="word"><span>I'm</span></span>
      <span class="word"><span>Ben.</span></span>
    </p>
    <div class="loader-bar-wrap">
      <div class="loader-bar" id="loader-bar"></div>
    </div>
  </div>

  <SectionNav />

  <!-- ============ INTRO STAGE (pinned hero recede + scroll-scrubbed sweep) ============ -->
  <section class="intro-stage" id="intro-stage">
    <div class="intro-pin">

      <!-- Hero text layer (z:2, recedes via scrubbed timeline) -->
      <div class="hero" id="intro" data-intro-hero>
        <div class="hero-inner">
          <p class="hero-eyebrow" data-reveal>Ben LaClair · Designer</p>
          <h1 class="stage-headline hero-headline" data-headline-text="A designer who makes complicated things feel obvious." aria-label="A designer who makes complicated things feel obvious."></h1>
          <a href="#work" class="hero-cue" aria-label="Jump to selected work">
            <span>Selected work</span>
            <span class="hero-cue-arrow" aria-hidden="true">↓</span>
          </a>
        </div>
        <div class="hero-noise" aria-hidden="true"></div>
      </div>

      <!-- Sweep overlay (z:3, strip slides R→L across viewport during scroll) -->
      <div class="sweep" id="sweep" aria-hidden="true"></div>

    </div>
  </section>

  <!-- ============ SELECTED WORK (normal stack variant) ============ -->
  <div id="work">
    <HorizontalWork />
  </div>

  <!-- ============ TIMELINE (light) ============ -->
  <section class="timeline" id="timeline">
    <div class="timeline-stage" id="timeline-stage">
      <div class="timeline-pin" id="timeline-pin">
        <div class="timeline-top">
          <span id="timeline-progress">01 / 05</span>
        </div>
        <div class="timeline-mid">
          <div class="timeline-num" id="timeline-num">2018</div>
        </div>
        <div>
          <div class="timeline-cap">
            <div class="label" data-reveal>Marker</div>
            <div class="text" id="timeline-text" data-reveal>First freelance esports overlay. Discord DMs, forty bucks, learning Photoshop the hard way.</div>
            <div class="right" id="timeline-tag" data-reveal>Self-taught</div>
          </div>
          <div class="timeline-bar"><i id="timeline-fill"></i></div>
          <div class="timeline-ticks" id="timeline-ticks">
            <span class="active">2018</span><span>2019</span><span>2021</span><span>2024</span><span>2026</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PROCESS (light) ============ -->
  <section class="process atmo-warmth-br" id="process">
    <div class="wrap">
      <div class="process-header">
        <p class="text-eyebrow-accent" data-reveal>Process</p>
        <h2 class="process-title" data-process-title>
          <span class="process-word"><span>Fewer</span></span>
          <span class="process-word"><span>surprises,</span></span>
          <span class="process-word"><span>better</span></span>
          <span class="process-word"><span>work.</span></span>
        </h2>
        <p class="process-sub" data-reveal>
          Four phases. Every project, every time — so you always know what's happening and why.
        </p>
      </div>
      <div class="process-grid-wrap">
        <div class="process-connector" aria-hidden="true"><span class="process-connector-line"></span></div>
        <div class="process-grid">
          <div class="process-step" data-process-card>
            <span class="process-num">01</span>
            <h3 class="process-step-title">Absorb</h3>
            <p class="process-step-body">Stakeholder interviews, user research, competitive audit. Learning enough to design with conviction — not just familiarity.</p>
            <button class="process-expand-hint" aria-expanded="false">Deliverables <span aria-hidden="true">+</span></button>
            <div class="process-deliverables" aria-hidden="true">
              <ul>
                <li>Research synthesis doc</li>
                <li>Stakeholder interview notes</li>
                <li>Competitive audit</li>
                <li>Defined success metrics</li>
              </ul>
            </div>
          </div>
          <div class="process-step" data-process-card>
            <span class="process-num">02</span>
            <h3 class="process-step-title">Reduce</h3>
            <p class="process-step-body">Distilling the problem to its sharpest possible version. Architecture, flows, and design principles before a single pixel moves.</p>
            <button class="process-expand-hint" aria-expanded="false">Deliverables <span aria-hidden="true">+</span></button>
            <div class="process-deliverables" aria-hidden="true">
              <ul>
                <li>Problem statement</li>
                <li>Information architecture</li>
                <li>User flows</li>
                <li>Design principles</li>
              </ul>
            </div>
          </div>
          <div class="process-step" data-process-card>
            <span class="process-num">03</span>
            <h3 class="process-step-title">Make</h3>
            <p class="process-step-body">Screens, systems, motion. Every detail earns its place. No placeholder copy, no "we'll fix it in dev."</p>
            <button class="process-expand-hint" aria-expanded="false">Deliverables <span aria-hidden="true">+</span></button>
            <div class="process-deliverables" aria-hidden="true">
              <ul>
                <li>Wireframes + prototypes</li>
                <li>High-fidelity screens</li>
                <li>Design system / component library</li>
                <li>Motion spec</li>
              </ul>
            </div>
          </div>
          <div class="process-step" data-process-card>
            <span class="process-num">04</span>
            <h3 class="process-step-title">Align</h3>
            <p class="process-step-body">Specs and the reasoning behind them. Still available through build — because a handoff document doesn't answer Slack messages.</p>
            <button class="process-expand-hint" aria-expanded="false">Deliverables <span aria-hidden="true">+</span></button>
            <div class="process-deliverables" aria-hidden="true">
              <ul>
                <li>Annotated Figma handoff</li>
                <li>Component documentation</li>
                <li>QA review</li>
                <li>Post-launch check-in</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA (dark + radial halos) ============ -->
  <section class="cta is-dark has-halos" id="contact" data-section-mode="dark">
    <h2 class="cta-title" id="cta-title">
      <span class="line"><span>Have something</span></span>
      <span class="line"><span><span class="accent">worth making?</span></span></span>
    </h2>
    <div class="cta-row">
      <a href="mailto:hello@benlaclair.com" data-magnetic="0.4" class="cta-link">
        hello@benlaclair.com
        <span class="cta-arrow">→</span>
      </a>
      <p class="cta-side" data-reveal>Replies usually within a day. The shorter your brief, the faster I can be useful — three sentences is plenty.</p>
    </div>
  </section>

</BaseLayout>

<style is:global>
  /* loader */
  .loader { position: fixed; inset: 0; background: #0a1230; z-index: 10000; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 32px; }
  .loader-greeting { margin: 0; font-family: var(--font-display); font-weight: 500; font-size: clamp(32px, 5vw, 72px); letter-spacing: -0.02em; line-height: 1; color: var(--color-dark-ink); }
  .loader-greeting .word { display: inline-block; overflow: hidden; vertical-align: bottom; margin-right: 0.22em; }
  .loader-greeting .word > span { display: inline-block; transform: translateY(110%); }
  .loader-bar-wrap { width: clamp(160px, 30vw, 320px); height: 1px; background: rgba(244, 239, 228, 0.12); }
  .loader-bar { height: 1px; width: 0%; background: var(--color-dark-ink); }

  /* INTRO STAGE — 200svh scroll context, parchment bg.
     .intro-pin is sticky-pinned 100svh viewport holding both hero + sweep. */
  .intro-stage {
    position: relative;
    background: var(--color-bg);
    height: 200svh;
  }
  .intro-pin {
    position: sticky;
    top: 0;
    height: 100svh;
    width: 100%;
    overflow: hidden;
    perspective: 1400px;
    perspective-origin: 50% 45%;
  }

  /* HERO — absolutely positioned layer inside the pin. z:2.
     GSAP drives Z-translate + opacity + blur during scroll. */
  .hero {
    position: absolute;
    inset: 0;
    z-index: 2;
    padding: clamp(80px, 12vh, 140px) clamp(24px, 6vw, 80px) clamp(60px, 8vh, 100px);
    overflow: hidden;
    display: grid;
    transform-style: preserve-3d;
    will-change: transform, opacity, filter;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    width: 100%;
    margin: 0 auto;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: clamp(40px, 8vh, 80px);
    align-self: stretch;
  }
  .hero-noise {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.08;
    mix-blend-mode: multiply;
    pointer-events: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='100%' height='100%' filter='url(%23n)' opacity='0.85'/></svg>");
    background-repeat: repeat;
    background-size: 200px 200px;
  }

  /* SWEEP — absolutely positioned inside the pin (z:3, above hero).
     Strip slides R→L during the scrubbed timeline; --sweep-scale on each
     .sweep-img drives the depth-of-field scale (updated per frame in JS). */
  .sweep {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    overflow: hidden;
    display: grid;
    place-items: center;
  }
  .sweep-strip {
    display: flex;
    align-items: center;
    gap: clamp(24px, 3vw, 48px);
    will-change: transform;
    white-space: nowrap;
  }
  .sweep-img {
    height: clamp(280px, 50vh, 520px);
    width: auto;
    flex-shrink: 0;
    transform: scale(var(--sweep-scale, 1));
    transform-origin: center center;
    border-radius: 8px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.22);
    will-change: transform;
  }

  .hero-eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .hero-headline {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(40px, 5.5vw, 88px);
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    max-width: 16ch;
    align-self: center;
    text-align: left;
  }
  /* word-clip wrappers injected by the loader script use .word/.word>span */
  .hero-headline .word { display: inline-block; overflow: hidden; vertical-align: bottom; margin-right: 0.22em; }
  .hero-headline .word > span { display: inline-block; }
  .hero-cue {
    display: inline-flex;
    gap: 12px;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-2);
    text-decoration: none;
    border-bottom: 1px solid rgba(22, 21, 18, 0.25);
    padding-bottom: 8px;
    width: max-content;
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .hero-cue:hover { color: var(--color-ink); border-bottom-color: rgba(22, 21, 18, 0.55); }
  .hero-cue-arrow { display: inline-block; transition: transform 0.3s cubic-bezier(.7,0,.2,1); }
  .hero-cue:hover .hero-cue-arrow { transform: translateY(3px); }

  @media (prefers-reduced-motion: reduce) {
    /* Collapse pin to static: hero is a normal 100svh section, sweep hidden */
    .intro-stage { height: auto; }
    .intro-pin { position: relative; height: auto; min-height: 100svh; perspective: none; }
    .hero { position: relative; inset: auto; transform: none !important; opacity: 1 !important; filter: none !important; }
    .sweep { display: none; }
  }

  .divider { height: 1px; background: var(--color-line); margin: 0 40px; }

  /* timeline */
  .timeline { padding: 200px 40px 200px; position: relative; }
  .timeline-stage { height: 280vh; position: relative; }
  .timeline-stage.is-static { height: auto; }
  .timeline-stage.is-static .timeline-pin { height: auto; min-height: 60vh; }
  .timeline-pin {
    height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 40px;
    align-items: stretch;
    padding: 48px clamp(28px, 4vw, 64px);
    background: var(--color-paper);
    border-radius: 22px;
    box-shadow: var(--shadow-card);
  }
  .timeline-top { display: flex; justify-content: flex-end; align-items: baseline; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; color: var(--color-ink-2); text-transform: uppercase; }
  .timeline-mid { display: grid; place-items: center; position: relative; }
  .timeline-num { font-family: var(--font-display); font-weight: 500; font-style: normal; font-size: clamp(160px, 30vw, 460px); line-height: 0.9; letter-spacing: -0.02em; color: var(--color-ink); position: relative; }
  .timeline-cap { display: grid; grid-template-columns: 1fr 2fr 1fr; gap: 40px; align-items: end; padding-bottom: 20px; }
  .timeline-cap .label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-2); text-transform: uppercase; }
  .timeline-cap .text { font-size: clamp(18px, 2.2vw, 28px); line-height: 1.3; letter-spacing: -0.015em; max-width: 700px; font-family: var(--font-body); }
  .timeline-cap .right { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; color: var(--color-muted); text-transform: uppercase; text-align: right; }
  .timeline-bar { height: 1px; background: var(--color-line); position: relative; }
  .timeline-bar i { position: absolute; left: 0; top: 0; bottom: 0; width: 0%; background: var(--color-ink); }
  .timeline-ticks { display: flex; justify-content: space-between; margin-top: 12px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; color: var(--color-muted); }
  .timeline-ticks span { transition: color 0.5s ease; }
  .timeline-ticks span.active { color: var(--color-accent); }

  /* process — light chapter */
  .process { padding: clamp(80px, 12vh, 160px) 40px; }
  .process-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px 80px;
    align-items: start;
    margin-bottom: clamp(60px, 8vw, 100px);
  }
  .process-header .text-eyebrow-accent { grid-column: 1 / -1; }
  .process-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(40px, 5.5vw, 88px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }
  .process-word {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
    margin-right: 0.22em;
  }
  .process-word > span {
    display: inline-block;
    transform: translateY(110%);
    opacity: 0;
  }
  .process-sub {
    font-size: clamp(14px, 1.4vw, 18px);
    line-height: 1.6;
    color: var(--color-muted);
    max-width: 360px;
    padding-top: 0.5em;
    align-self: end;
  }
  .process-grid-wrap { position: relative; }
  .process-connector {
    height: 32px;
    display: flex;
    align-items: center;
    margin-bottom: -1px;
    padding: 0 1px;
  }
  .process-connector-line {
    display: block;
    height: 1px;
    width: 0%;
    background: var(--color-accent);
    opacity: 0.5;
  }
  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-line);
    border: 1px solid var(--color-line);
    border-radius: 0 0 12px 12px;
    overflow: hidden;
  }
  .process-step {
    background: var(--color-bg);
    padding: clamp(28px, 3vw, 48px) clamp(24px, 2.5vw, 40px);
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: background 0.3s ease;
    cursor: pointer;
    opacity: 0;
    transform: translateY(24px);
  }
  .process-step:hover { background: var(--color-panel); }
  .process-num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--color-accent);
  }
  .process-step-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(24px, 2.4vw, 36px);
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-ink);
  }
  .process-step-body {
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-muted);
    flex: 1;
  }
  .process-expand-hint {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease, color 0.2s ease;
  }
  .process-step:hover .process-expand-hint { opacity: 1; }
  .process-expand-hint[aria-expanded="true"] {
    opacity: 1;
    color: var(--color-accent);
  }
  .process-expand-hint[aria-expanded="true"] span { content: '−'; }
  .process-deliverables {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .process-deliverables.is-open {
    max-height: 200px;
  }
  .process-deliverables ul {
    list-style: none;
    padding: 0;
    margin: 0;
    padding-top: 16px;
    border-top: 1px solid var(--color-line);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .process-deliverables li {
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-ink-2);
    display: flex;
    gap: 10px;
  }
  .process-deliverables li::before {
    content: '—';
    color: var(--color-accent);
    flex-shrink: 0;
  }
  @media (max-width: 900px) {
    .process-header { grid-template-columns: 1fr !important; }
    .process-grid { grid-template-columns: repeat(2, 1fr) !important; border-radius: 0 0 12px 12px; }
  }
  @media (max-width: 600px) {
    .process-grid { grid-template-columns: 1fr !important; }
    .process { padding: 60px 24px !important; }
  }
  @media (prefers-reduced-motion: reduce) {
    .process-word > span { transform: none; opacity: 1; }
    .process-step { opacity: 1; transform: none; }
    .process-connector-line { width: 100%; }
    .process-deliverables { transition: none; }
  }

  /* cta — dark chapter */
  .cta { padding: 200px 40px 120px; }
  .cta-title { font-family: var(--font-display); font-weight: 500; font-size: clamp(64px, 11.5vw, 200px); line-height: 0.96; letter-spacing: -0.025em; color: var(--color-dark-ink); }
  .cta-title .accent { color: var(--color-accent); }
  .cta-row { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end; margin-top: 80px; }
  .cta-link { display: inline-flex; align-items: center; gap: 18px; font-size: 22px; font-weight: 500; font-family: var(--font-body); letter-spacing: -0.01em; padding: 18px 0; border-bottom: 1px solid var(--color-dark-ink); color: var(--color-dark-ink); }
  .cta .cta-link { color: var(--color-dark-ink); }
  .cta-arrow { width: 44px; height: 44px; border-radius: 50%; background: var(--color-dark-ink); color: var(--color-dark-bg); display: grid; place-items: center; transition: transform 0.6s cubic-bezier(.7,0,.2,1), background 0.4s ease; flex-shrink: 0; }
  .cta-link:hover .cta-arrow { transform: rotate(-45deg); background: var(--color-accent); }
  .cta-side { font-size: 14px; line-height: 1.6; color: var(--color-dark-ink-2); max-width: 360px; padding-bottom: 24px; font-family: var(--font-body); }

  @media (max-width: 900px) {
    .cta-row { grid-template-columns: 1fr !important; gap: 32px !important; }
    .timeline-cap { grid-template-columns: 1fr !important; }
    .timeline-num { font-size: clamp(120px, 22vw, 280px) !important; }
  }
</style>

<script>
  import { gsap, ScrollTrigger, ease, reduceMotion } from '../lib/motion';
  import { SWEEP_IMAGES } from '../data/sweepImages';

  // ============ LOADER ============
  // ── Split first headline into word spans for clip wipe ──────────────────
  const firstHeadline = document.querySelector<HTMLElement>('#intro .stage-headline');
  let wordSpans: HTMLElement[] = [];
  if (firstHeadline) {
    const text = firstHeadline.dataset.headlineText ?? '';
    wordSpans = text.split(' ').map((w) => {
      const outer = document.createElement('span');
      outer.className = 'word';
      const inner = document.createElement('span');
      inner.textContent = w;
      outer.appendChild(inner);
      return outer;
    });
    // Interleave spaces between word spans
    const nodes: Node[] = [];
    wordSpans.forEach((ws, i) => {
      nodes.push(ws);
      if (i < wordSpans.length - 1) nodes.push(document.createTextNode(' '));
    });
    firstHeadline.replaceChildren(...nodes);
    gsap.set(wordSpans.map(w => w.firstElementChild), { y: '110%' });
    // Mark as already handled so scramble observer skips it
    firstHeadline.dataset.introDone = 'true';
  }

  if (!reduceMotion.current) {
    gsap.set('#site-nav', { opacity: 0 });
    const intro = gsap.timeline();
    intro
      .to('#loader-greeting .word > span', { y: '0%', duration: 0.7, stagger: 0.1, ease: ease.expo })
      .to('#loader-bar', { width: '100%', duration: 1.4, ease: 'power2.inOut' }, '+=0.1')
      .to('#loader', { opacity: 0, duration: 0.7, ease: 'power2.inOut' }, '+=0.2')
      .set('#loader', { display: 'none' })
      .to('#site-nav', { opacity: 1, duration: 0.6, ease: ease.out }, '-=0.2')
      .to(wordSpans.map(w => w.firstElementChild), { y: '0%', duration: 0.8, stagger: 0.08, ease: ease.expo }, '-=0.6');
  } else {
    const loader = document.getElementById('loader');
    if (loader) loader.style.display = 'none';
    // Reduced motion: just show the words
    wordSpans.forEach(w => { (w.firstElementChild as HTMLElement).style.transform = 'none'; });
  }

  // ============ SCROLL-DRIVEN INTRO (hero recede + sweep) ============
  // Single scrubbed timeline anchored to #intro-stage (200svh tall):
  //   0→50%   hero recedes (z: -900, opacity 1→0, blur 0→2px)
  //   40→100% sweep strip slides R→L across viewport (depth-of-field via --sweep-scale)
  //   10% overlap at 40-50% so hero fade-out and sweep entry cross-fade
  // User controls pace by scrolling; when pin releases, Work is in viewport.
  if (!reduceMotion.current) {
    const stageEl = document.getElementById('intro-stage');
    const heroEl = document.querySelector<HTMLElement>('[data-intro-hero]');
    const sweepEl = document.getElementById('sweep');
    if (stageEl && heroEl && sweepEl) {
      // Build the strip
      const strip = document.createElement('div');
      strip.className = 'sweep-strip';
      sweepEl.appendChild(strip);

      const imgs = SWEEP_IMAGES.map((entry) => {
        const img = document.createElement('img');
        img.src = entry.src;
        img.alt = entry.alt;
        img.className = 'sweep-img';
        img.loading = 'eager';
        img.decoding = 'async';
        strip.appendChild(img);
        return img;
      });

      // Depth-of-field: per-image scale based on distance from viewport center.
      // Center → SCALE_MAX, edges → SCALE_MIN, with 1 - t^2 falloff so the
      // center holds its larger scale longer than a linear ramp would.
      const SCALE_MAX = 1.2;
      const SCALE_MIN = 0.4;
      const updateDepth = () => {
        const cx = window.innerWidth / 2;
        const halfVw = cx;
        imgs.forEach((img) => {
          const rect = img.getBoundingClientRect();
          const imgCx = rect.left + rect.width / 2;
          const dist = Math.abs(imgCx - cx);
          const t = Math.min(dist / halfVw, 1);
          const eased = 1 - t * t;
          const scale = SCALE_MIN + (SCALE_MAX - SCALE_MIN) * eased;
          img.style.setProperty('--sweep-scale', scale.toFixed(3));
        });
      };

      // Initial states
      gsap.set(heroEl, { z: 0, opacity: 1, filter: 'blur(0px)' });
      gsap.set(strip, { x: () => window.innerWidth });
      updateDepth();

      // ─── Hero recede: scrubbed, reversible, completes by 50% of pin scroll ───
      // .intro-stage is 200svh tall; pin scroll spans the inner 100svh.
      // start 'top top' = top of stage hits viewport top (pin engages)
      // end 'center top' = center of stage hits viewport top (50% of pin scroll)
      gsap.to(heroEl, {
        z: -900,
        opacity: 0,
        filter: 'blur(2px)',
        ease: 'none',
        scrollTrigger: {
          trigger: stageEl,
          start: 'top top',
          end: 'center top',
          scrub: 0.6,
          invalidateOnRefresh: true,
        },
      });

      // ─── Sweep: one-shot, auto-plays through, scroll-locked for 2.5s ───
      // Fires when scroll passes the 50% mark of intro-stage (i.e. right
      // after the hero recede completes). While the sweep plays, scroll is
      // locked (Lenis stop + wheel/touch preventDefault) so the pin can't
      // release mid-sweep. After completion, scroll unlocks and the user
      // can continue past the pin end naturally.
      const blockWheel = (e: Event) => e.preventDefault();

      const unlockScroll = () => {
        const lenis = (window as any).__lenis;
        lenis?.start();
        window.removeEventListener('wheel', blockWheel as EventListener);
        window.removeEventListener('touchmove', blockWheel as EventListener);
      };

      const fireSweep = () => {
        const lenis = (window as any).__lenis;
        lenis?.stop();
        window.addEventListener('wheel', blockWheel as EventListener, { passive: false });
        window.addEventListener('touchmove', blockWheel as EventListener, { passive: false });

        const workEl = document.getElementById('work');
        const sweepTl = gsap.timeline({ onComplete: unlockScroll });

        // Single sweep tween with SlowMo ease: dramatic slow start,
        // fast middle burst, dramatic slow end. 4.5s total.
        // slow(linearRatio, power, yoyo): 0.4 = 40% of duration at full
        // speed (the fast middle), 0.8 = how aggressively the slow
        // start/end ramp (higher = more dramatic).
        sweepTl.to(strip, {
          x: () => -strip.scrollWidth,
          duration: 4.5,
          ease: 'slow(0.4, 0.8, false)',
          onUpdate: updateDepth,
        });

        // Fade-out overlaps the slow-end phase
        sweepTl.to(strip, {
          opacity: 0,
          duration: 1.4,
          ease: 'power1.in',
          onStart: () => {
            unlockScroll();
            if (workEl) {
              const target = workEl.getBoundingClientRect().top + window.scrollY;
              window.scrollTo({ top: target, behavior: 'smooth' });
            }
          },
        }, '-=1.8');
      };

      ScrollTrigger.create({
        trigger: stageEl,
        start: 'center top',
        once: true,
        onEnter: fireSweep,
      });
    }
  }

  // ============ TIMELINE PINNED ============
  const tlData = [
    { y: '2018', text: 'First freelance esports overlay. Discord DMs, forty bucks, learning Photoshop the hard way.', tag: 'Self-taught' },
    { y: '2019', text: 'Pivot to UX. First paid web project for a community nonprofit; learned Figma overnight.', tag: 'Pivot' },
    { y: '2021', text: 'Joined the Gazelle Group. Brand systems for ESPN-affiliated tournaments touching ten million screens.', tag: 'Studio' },
    { y: '2024', text: 'Vlier and YMCA — first proper enterprise UX engagements. Deliverables that actually shipped.', tag: 'Enterprise' },
    { y: '2026', text: 'AI-generated TV spot for the Winter Olympics. Now rebuilding everything — in public.', tag: 'Today' },
  ];
  const tlNum = document.getElementById('timeline-num');
  const tlText = document.getElementById('timeline-text');
  const tlTag = document.getElementById('timeline-tag');
  const tlFill = document.getElementById('timeline-fill') as HTMLElement | null;
  const tlProg = document.getElementById('timeline-progress');
  const tlTicks = document.querySelectorAll<HTMLElement>('#timeline-ticks span');
  let tlIdx = 0;

  function setTimeline(idx: number) {
    if (idx === tlIdx || !tlNum || !tlText || !tlTag || !tlProg) return;
    tlIdx = idx;
    const cur = tlData[idx];
    if (!reduceMotion.current) {
      gsap.fromTo(tlNum, { y: 30, opacity: 0 }, { y: 0, opacity: 1, duration: 0.65, ease: ease.expo });
      gsap.fromTo([tlText, tlTag], { y: 18, opacity: 0 }, { y: 0, opacity: 1, duration: 0.6, stagger: 0.05, ease: ease.expo, delay: 0.08 });
    }
    tlNum.textContent = cur.y;
    tlText.textContent = cur.text;
    tlTag.textContent = cur.tag;
    tlProg.textContent = `${(idx + 1).toString().padStart(2, '0')} / ${tlData.length.toString().padStart(2, '0')}`;
    tlTicks.forEach((s, i) => s.classList.toggle('active', i === idx));
  }

  const isMobile = window.matchMedia('(max-width: 900px)').matches;
  if (!reduceMotion.current && !isMobile) {
    ScrollTrigger.create({
      trigger: '#timeline-stage',
      start: 'top top',
      end: 'bottom bottom',
      pin: '#timeline-pin',
      onUpdate: (self) => {
        const idx = Math.min(tlData.length - 1, Math.floor(self.progress * tlData.length));
        setTimeline(idx);
        if (tlFill) tlFill.style.width = (self.progress * 100).toFixed(2) + '%';
      },
    });
  } else {
    document.getElementById('timeline-stage')?.classList.add('is-static');
    setTimeline(tlData.length - 1);
    if (tlFill) tlFill.style.width = '100%';
  }

  // ============ PROCESS ============
  {
    const section = document.querySelector<HTMLElement>('.process');
    if (section && !reduceMotion.current) {
      const words = section.querySelectorAll<HTMLElement>('.process-word > span');
      const cards = section.querySelectorAll<HTMLElement>('[data-process-card]');
      const connectorLine = section.querySelector<HTMLElement>('.process-connector-line');

      gsap.to(words, {
        y: 0,
        opacity: 1,
        duration: 0.7,
        stagger: 0.1,
        ease: ease.expo,
        scrollTrigger: { trigger: '[data-process-title]', start: 'top 85%', once: true },
      });

      gsap.to(cards, {
        y: 0,
        opacity: 1,
        duration: 0.7,
        stagger: 0.1,
        ease: ease.out,
        scrollTrigger: { trigger: '.process-grid', start: 'top 88%', once: true },
        onComplete() {
          if (connectorLine) {
            gsap.to(connectorLine, { width: '100%', duration: 0.8, ease: 'power2.out' });
          }
        },
      });
    }

    document.querySelectorAll<HTMLElement>('[data-process-card]').forEach((card) => {
      const btn = card.querySelector<HTMLButtonElement>('.process-expand-hint');
      const panel = card.querySelector<HTMLElement>('.process-deliverables');
      const indicator = btn?.querySelector<HTMLElement>('span');
      if (!btn || !panel) return;

      btn.addEventListener('click', () => {
        const isOpen = panel.classList.contains('is-open');

        document.querySelectorAll<HTMLElement>('.process-deliverables.is-open').forEach((p) => {
          p.classList.remove('is-open');
          p.setAttribute('aria-hidden', 'true');
          const b = p.previousElementSibling as HTMLButtonElement | null;
          if (b) {
            b.setAttribute('aria-expanded', 'false');
            const ind = b.querySelector<HTMLElement>('span');
            if (ind) ind.textContent = '+';
          }
        });

        if (!isOpen) {
          panel.classList.add('is-open');
          panel.setAttribute('aria-hidden', 'false');
          btn.setAttribute('aria-expanded', 'true');
          if (indicator) indicator.textContent = '−';
        }
      });
    });
  }

  // ============ CTA ============
  if (!reduceMotion.current) {
    gsap.set('.cta-title .line span', { y: '110%' });
    gsap.to('.cta-title .line span', {
      y: '0%', duration: 1.2, stagger: 0.1, ease: ease.expo,
      scrollTrigger: { trigger: '.cta-title', start: 'top 80%' },
    });
    gsap.from('.cta-row > *', {
      y: 30, opacity: 0, duration: 0.9, stagger: 0.1, ease: ease.out,
      scrollTrigger: { trigger: '.cta-row', start: 'top 85%' },
    });
  }
</script>
