---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { PROJECTS } from '../data/projects';
import { TOOLS } from '../data/tools';
import { SITE, ANIMATION } from '../data/constants';
---

<BaseLayout>
  <!-- ===================== HERO ===================== -->
  <section class="min-h-[88vh] flex flex-col justify-center px-6 md:px-12 pt-16 pb-24" id="hero">
    <div class="max-w-[1200px] mx-auto w-full">
      <div class="hero-content max-w-3xl">
        <p class="eyebrow mb-6 hero-el">
          UX/UI &amp; Graphic Designer
          {SITE.available && (
            <span class="ml-3 inline-flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span>
              <span class="text-emerald-700">Available 2026</span>
            </span>
          )}
        </p>

        <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-[var(--color-ink)] mb-8 text-pretty hero-el">
          Design that makes complexity
          <em class="not-italic text-[var(--color-muted-soft)]"> feel obvious.</em>
        </h1>

        <p class="text-base md:text-lg text-[var(--color-muted)] max-w-xl leading-relaxed mb-10 hero-el">
          I'm Ben LaClair — {SITE.yearsExperience} years designing user-centered products,
          brand systems, and AI-driven creative work.
        </p>

        <div class="flex flex-wrap gap-3 hero-el">
          <a
            href="/work"
            class="bg-[var(--color-ink)] text-[var(--color-bg)] text-sm font-medium px-6 py-3 rounded-full hover:bg-[var(--color-pop)] transition-colors"
          >
            View work
          </a>
          <a
            href="/contact"
            class="border border-[var(--color-line)] text-[var(--color-ink)] text-sm font-medium px-6 py-3 rounded-full hover:border-[var(--color-ink)] transition-colors"
          >
            Get in touch
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== WORK ===================== -->
  <section class="px-6 md:px-12 py-16 md:py-24" id="work">
    <div class="max-w-[1200px] mx-auto">
      <div class="flex items-baseline justify-between mb-10 md:mb-14">
        <h2 class="font-serif text-3xl md:text-4xl text-[var(--color-ink)]">Selected work</h2>
        <a
          href="/work"
          class="text-sm text-[var(--color-muted)] hover:text-[var(--color-pop)] transition-colors"
        >
          All projects &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-16">
        {PROJECTS.map((project, i) => (
          <ProjectCard project={project} index={i} />
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== TOOLS ===================== -->
  <section class="px-6 md:px-12 py-16 md:py-24 bg-white border-y border-[var(--color-line)]" id="tools">
    <div class="max-w-[1200px] mx-auto">
      <div class="flex items-baseline justify-between mb-10 md:mb-14">
        <div>
          <h2 class="font-serif text-3xl md:text-4xl text-[var(--color-ink)] mb-2">Tools I built</h2>
          <p class="text-sm text-[var(--color-muted)] max-w-md">
            Production tools built to solve real problems in design, content, and workflow.
          </p>
        </div>
        <a
          href="/tools"
          class="text-sm text-[var(--color-muted)] hover:text-[var(--color-pop)] transition-colors shrink-0"
        >
          All tools &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {TOOLS.map((tool, i) => (
          <article class="tool-card group border border-[var(--color-line)] rounded-2xl p-6 bg-[var(--color-bg)] hover:border-[var(--color-ink)]/20 hover:shadow-sm transition-all" data-index={i}>
            <div class="flex items-start justify-between mb-4">
              <span class="font-mono text-xs text-[var(--color-muted-soft)]">{tool.number}</span>
              <span class="text-xs font-medium px-2.5 py-1 rounded-full border" style={`color: ${tool.accentColor}; border-color: ${tool.accentColor}40; background: ${tool.accentColor}10`}>
                {tool.status === 'live' ? 'Live' : tool.status === 'beta' ? 'Beta' : 'Soon'}
              </span>
            </div>
            <h3 class="font-serif text-xl text-[var(--color-ink)] mb-2 group-hover:text-[var(--color-pop)] transition-colors">{tool.name}</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed mb-5">{tool.tagline}</p>
            {tool.url && (
              <a
                href={tool.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs font-medium text-[var(--color-ink)] hover:text-[var(--color-pop)] transition-colors"
              >
                Open tool &uarr;
              </a>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="px-6 md:px-12 py-24 md:py-32" id="cta">
    <div class="max-w-[1200px] mx-auto">
      <div class="max-w-2xl">
        <p class="eyebrow mb-5">Let's collaborate</p>
        <h2 class="font-serif text-4xl md:text-5xl text-[var(--color-ink)] mb-6 text-balance">
          Got a project in mind?
        </h2>
        <p class="text-base text-[var(--color-muted)] max-w-md leading-relaxed mb-8">
          Whether it's a brand, a product, or something entirely new — I'd love to hear about it.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 bg-[var(--color-ink)] text-[var(--color-bg)] text-sm font-medium px-7 py-3.5 rounded-full hover:bg-[var(--color-pop)] transition-colors"
        >
          Start a conversation &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Hero entrance
  const heroEls = document.querySelectorAll('.hero-el');
  gsap.from(heroEls, {
    opacity: 0,
    y: 20,
    duration: 0.7,
    stagger: 0.1,
    ease: 'power3.out',
    delay: 0.1,
  });

  // Tool cards
  const toolCards = document.querySelectorAll<HTMLElement>('.tool-card');
  toolCards.forEach((card) => {
    const i = parseInt(card.dataset.index ?? '0', 10);
    gsap.from(card, {
      opacity: 0,
      y: 16,
      duration: 0.5,
      delay: i * 0.08,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: card,
        start: 'top 88%',
        once: true,
      },
    });
  });
</script>
