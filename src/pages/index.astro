---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { PROJECTS } from '../data/projects';
import { SITE } from '../data/constants';

const featuredProjects = PROJECTS.slice(0, 4);
---

<BaseLayout>

  <!-- ===================== HERO ===================== -->
  <section
    class="min-h-screen flex flex-col px-5 md:px-12 lg:px-20 pt-20 pb-10"
    style="max-width: 1360px; margin-inline: auto; width: 100%"
    id="hero"
  >
    <!-- Top label row -->
    <div class="flex items-center justify-between mb-auto pt-10">
      <span
        id="hero-label"
        class="text-[var(--color-muted)]"
        style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase"
      >UX / UI &amp; Graphic Design</span>
      {SITE.available && (
        <span
          id="hero-status"
          class="flex items-center gap-2 text-[var(--color-muted)]"
          style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.08em"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span>
          Available 2026
        </span>
      )}
    </div>

    <!-- Headline -->
    <div class="flex-1 flex flex-col justify-center py-12 md:py-16">
      <h1
        id="hero-headline"
        class="text-[var(--color-ink)]"
        style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(3.25rem, 9vw, 9.5rem); letter-spacing: -0.03em; line-height: 0.95"
      >
        Design that makes<br />
        complexity
        <span class="text-[var(--color-muted)]"> feel obvious.</span>
      </h1>
    </div>

    <!-- Bottom row: bio + CTAs -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 pb-10">
      <p
        id="hero-bio"
        class="text-base text-[var(--color-muted)] max-w-sm leading-relaxed"
      >
        I'm Ben LaClair — {SITE.yearsExperience} years designing user-centered products,
        brand systems, and AI-driven creative work.
      </p>
      <div id="hero-cta" class="flex items-center gap-8">
        <a
          href="/work"
          class="text-sm text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors duration-200"
        >View work →</a>
        <a
          href="/contact"
          class="text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)] transition-colors duration-200"
        >Get in touch</a>
      </div>
    </div>

    <!-- Scroll rule -->
    <div
      id="hero-rule"
      class="border-t border-[var(--color-line)] pt-5 flex items-center justify-between"
    >
      <span
        class="text-[var(--color-muted)]"
        style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase"
      >Scroll</span>
      <span class="text-[var(--color-muted)] text-sm">↓</span>
    </div>
  </section>

  <!-- ===================== WORK ===================== -->
  <section class="px-5 md:px-12 lg:px-20 pb-4" id="work">
    <div style="max-width: 1360px; margin-inline: auto">
      <div class="flex items-baseline justify-between py-9 border-t border-[var(--color-line)]">
        <span
          class="text-[var(--color-muted)]"
          style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase"
        >Selected work</span>
        <a
          href="/work"
          class="text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors duration-200"
          style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.06em"
        >All projects →</a>
      </div>

      {featuredProjects.map((project, i) => (
        <ProjectCard project={project} index={i} />
      ))}
    </div>
  </section>

  <!-- ===================== ABOUT STRIP ===================== -->
  <section
    class="px-5 md:px-12 lg:px-20 py-20 md:py-32 mt-20 md:mt-28"
    style="background: var(--color-surface)"
    id="about-strip"
  >
    <div
      class="grid md:grid-cols-[1fr_auto] gap-10 md:gap-16 items-end"
      style="max-width: 1360px; margin-inline: auto"
    >
      <div>
        <p
          id="about-label"
          class="text-[var(--color-muted)] mb-10"
          style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase"
        >About</p>
        <h2
          id="about-text"
          class="text-[var(--color-ink)]"
          style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(1.75rem, 4.5vw, 4rem); letter-spacing: -0.03em; line-height: 1.1"
        >
          5+ years designing user-centered products, brand systems, and AI-driven creative work.
        </h2>
      </div>
      <a
        href="/about"
        class="shrink-0 text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors duration-200 whitespace-nowrap"
      >More about me →</a>
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="px-5 md:px-12 lg:px-20 py-24 md:py-40" id="cta">
    <div style="max-width: 1360px; margin-inline: auto">
      <div class="border-t border-[var(--color-line)] pt-16 md:pt-20 flex flex-col md:flex-row md:items-end md:justify-between gap-10">
        <h2
          id="cta-text"
          class="text-[var(--color-ink)]"
          style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(2.75rem, 7vw, 7.5rem); letter-spacing: -0.03em; line-height: 0.95"
        >
          Got a project<br />in mind?
        </h2>
        <div class="shrink-0 flex flex-col gap-4 items-start md:items-end pb-1">
          <a
            href="/contact"
            class="text-sm text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors duration-200"
          >Start a conversation →</a>
          <a
            href="/work"
            class="text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)] transition-colors duration-200"
          >See the work →</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Hero entrance — staggered, snappy
  const tl = gsap.timeline({ delay: 0.05 });
  tl.from(['#hero-label', '#hero-status'], {
    opacity: 0,
    duration: 0.4,
    ease: 'power2.out',
  })
  .from('#hero-headline', {
    opacity: 0,
    y: 48,
    duration: 0.9,
    ease: 'power4.out',
  }, '-=0.1')
  .from('#hero-bio', {
    opacity: 0,
    y: 20,
    duration: 0.5,
    ease: 'power3.out',
  }, '-=0.5')
  .from('#hero-cta', {
    opacity: 0,
    y: 20,
    duration: 0.5,
    ease: 'power3.out',
  }, '-=0.4')
  .from('#hero-rule', {
    opacity: 0,
    duration: 0.4,
    ease: 'power2.out',
  }, '-=0.3');

  // About strip
  gsap.from('#about-label', {
    opacity: 0, y: 12, duration: 0.5, ease: 'power3.out',
    scrollTrigger: { trigger: '#about-label', start: 'top 90%', once: true },
  });
  gsap.from('#about-text', {
    opacity: 0, y: 36, duration: 0.85, ease: 'power4.out',
    scrollTrigger: { trigger: '#about-text', start: 'top 88%', once: true },
  });

  // CTA
  gsap.from('#cta-text', {
    opacity: 0, y: 48, duration: 0.85, ease: 'power4.out',
    scrollTrigger: { trigger: '#cta-text', start: 'top 86%', once: true },
  });
</script>
