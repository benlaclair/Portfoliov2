# Default: treat as text, normalize line endings to LF on commit
* text=auto eol=lf

# Binary types — don't normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
*.pdf   binary
*.mp4   binary
*.webm  binary
*.mov   binary
*.zip   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
